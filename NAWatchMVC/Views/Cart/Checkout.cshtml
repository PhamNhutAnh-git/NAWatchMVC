@model IEnumerable<NAWatchMVC.ViewModels.CartItemVM>
@{
    ViewData["Title"] = "Thanh toán";
    Layout = "_LayoutCustomer";

    // Lấy thông tin khách hàng từ ViewBag để điền sẵn vào form
    var khachHang = ViewBag.ThongTinKhachHang as NAWatchMVC.Data.KhachHang;

    // Tính tổng tiền tongThanhToan đơn hàng (Sử dụng thuộc tính ThanhTien tự tính trong VM)
    double subtotal = Model.Sum(p => p.ThanhTien);
    double phiShip = (subtotal >= 1000000) ? 0 : 50000; // Phí ship cố định cho All đơn
    double tongThanhToan = subtotal + phiShip;
}

<div class="container-fluid page-header py-5" style="background: linear-gradient(rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.5)), url('/Hinh/banner-watch.jpg'); background-size: cover;">
    <h1 class="text-center text-white display-6">Thanh Toán Đơn Hàng</h1>
    <ol class="breadcrumb justify-content-center mb-0">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
        <li class="breadcrumb-item"><a asp-controller="Cart" asp-action="Index">Giỏ hàng</a></li>
        <li class="breadcrumb-item active text-white">Thanh toán</li>
    </ol>
</div>

<div class="container-fluid py-5">
    <div class="container py-5">
        <h1 class="mb-4 fw-bold text-primary">Thông Tin Giao Nhận</h1>

        <form asp-action="Checkout" asp-controller="Cart" method="post">
            <div class="row g-5">
                @* --- CỘT TRÁI: THÔNG TIN KHÁCH HÀNG --- *@
                <div class="col-md-12 col-lg-6 col-xl-7">
                    <div class="form-item w-100 mb-3">
                        <label class="form-label my-2 fw-bold">Họ và tên người nhận<sup>*</sup></label>
                        <input type="text" class="form-control rounded-pill" name="hoten" value="@khachHang?.HoTen" placeholder="Ví dụ: Phạm Nhựt Anh" required>
                    </div>

                    <div class="form-item mb-3">
                        <label class="form-label my-2 fw-bold">Địa chỉ nhận hàng <sup>*</sup></label>
                        <input type="text" class="form-control rounded-pill" name="diachi" value="@khachHang?.DiaChi" placeholder="Số nhà, tên đường, phường/xã..." required>
                    </div>

                    <div class="row">
                        <div class="col-md-12 col-lg-6">
                            <div class="form-item mb-3">
                                <label class="form-label my-2 fw-bold">Điện thoại liên hệ<sup>*</sup></label>
                                <input type="tel" class="form-control rounded-pill" name="dienthoai" value="@khachHang?.DienThoai" placeholder="098..." required>
                            </div>
                        </div>
                        <div class="col-md-12 col-lg-6">
                            <div class="form-item mb-3">
                                <label class="form-label my-2 fw-bold">Email nhận thông báo<sup>*</sup></label>
                                <input type="email" class="form-control rounded-pill" name="email" value="@khachHang?.Email" placeholder="email@example.com" required>
                            </div>
                        </div>
                    </div>

                    <div class="form-check my-3">
                        <input class="form-check-input" type="checkbox" id="GhiChuKhac" name="GiaoGioHanhChinh" value="true">
                        <label class="form-check-label" for="GhiChuKhac">Giao hàng trong giờ hành chính?</label>
                    </div>

                    <div class="form-item mt-3">
                        <label class="form-label my-2 fw-bold">Ghi chú thêm</label>
                        <textarea name="ghichu" class="form-control rounded-3" spellcheck="false" cols="30" rows="4" placeholder="Ví dụ: Giao sau 5h chiều..."></textarea>
                    </div>
                </div>

                @* --- CỘT PHẢI: TÓM TẮT ĐƠN HÀNG --- *@
                <div class="col-md-12 col-lg-6 col-xl-5">
                    <div class="table-responsive rounded shadow-sm p-3 bg-light">
                        <table class="table align-middle">
                            <thead class="text-uppercase small fw-bold">
                                <tr>
                                    <th scope="col">Đồng hồ</th>
                                    <th scope="col">Tên</th>
                                    <th scope="col">Số lượng</th>
                                    <th scope="col" class="text-end">Thành tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <th scope="row">
                                            <img src="~/anhall/@item.Hinh" class="img-fluid rounded shadow-sm" style="width: 50px; height: 50px; object-fit: cover;">
                                        </th>
                                        <td class="small">@item.TenHH</td>
                                        <td class="text-center">x @item.SoLuong</td>
                                        <td class="text-end fw-bold text-dark">@item.ThanhTien.ToString("#,##0") đ</td>
                                    </tr>
                                }

                                <tr class="border-top">
                                    <td colspan="3" class="pt-3 text-end fw-bold">Tạm tính:</td>
                                    <td class="pt-3 text-end"><span id="subtotal">@subtotal.ToString("#,##0")</span> đ</td>
                                </tr>

                                @* --- PHẦN VOUCHER (MỚI THÊM) --- *@
                                <tr>
                                    <td colspan="4" class="py-3">
                                        <div class="input-group">
                                            <input type="text" id="voucherCode" class="form-control border-primary" placeholder="Nhập mã giảm giá...">
                                            <button type="button" id="btnApplyVoucher" class="btn btn-primary px-3">Áp dụng</button>
                                        </div>
                                        <div id="voucherMessage" class="small mt-1"></div>
                                    </td>
                                </tr>

                                <tr class="text-danger">
                                    <td colspan="3" class="text-end fw-bold">Giảm giá:</td>
                                    <td class="text-end fw-bold">- <span id="discountValue">0</span> đ</td>
                                </tr>

                                <tr>
                                    <td colspan="3" class="text-end fw-bold text-info">Phí vận chuyển:</td>
                                    <td class="text-end text-info fw-bold">
                                        @* 2. Thêm ID shipValue để JavaScript có thể đổi chữ thành "Miễn phí" *@
                                        <span id="shipValue">@(phiShip == 0 ? "Miễn phí" : phiShip.ToString("#,##0") + " đ")</span>
                                    </td>
                                </tr>

                                <tr class="bg-white border-top border-primary border-2">
                                    <td colspan="3" class="py-3 text-end fw-bold text-uppercase fs-5">Tổng cộng:</td>
                                    <td class="py-3 text-end fw-bold text-danger fs-4">
                                        <span id="finalTotal">@tongThanhToan.ToString("#,##0")</span> đ
                                    </td>
                                </tr>
                            </tbody>
                            @* <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <th scope="row">
                                            <img src="~/anhall/@item.Hinh" class="img-fluid rounded shadow-sm" style="width: 50px; height: 50px; object-fit: cover;" alt="@item.TenHH">
                                        </th>
                                        <td class="small">@item.TenHH</td>
                                        <td class="text-center">@item.SoLuong</td>
                                        <td class="text-end fw-bold text-dark">@item.ThanhTien.ToString("#,##0") đ</td>
                                    </tr>
                                }
                                <tr class="border-top">
                                    <td colspan="3" class="py-3 text-end fw-bold">Tạm tính:</td>
                                    <td class="py-3 text-end">@tongTien.ToString("#,##0") đ</td>
                                </tr>
                                <tr>
                                    <td colspan="3" class="text-end fw-bold text-success">Vận chuyển:</td>
                                    <td class="text-end text-success">Miễn phí</td>
                                </tr>
                                <tr class="bg-white">
                                    <td colspan="3" class="py-3 text-end fw-bold text-uppercase fs-5">Tổng cộng:</td>
                                    <td class="py-3 text-end fw-bold text-danger fs-5">@tongTien.ToString("#,##0") đ</td>
                                </tr>
                            </tbody> *@
                        </table>
                    </div>

                    @* --- PHƯƠNG THỨC THANH TOÁN --- *@
                    <div class="mt-4 p-4 border rounded shadow-sm">
                        <h5 class="fw-bold mb-3">Phương thức thanh toán</h5>

                        <div class="form-check mb-3">
                            <input type="radio" class="form-check-input" id="pay-cod" name="CachThanhToan" value="COD" checked>
                            <label class="form-check-label fw-bold" for="pay-cod">Thanh toán khi nhận hàng (COD)</label>
                            <p class="small text-muted ms-1">Bạn chọn thanh toán tiền mặt khi Shipper giao đồng hồ tới tận tay.</p>
                        </div>

                        <div class="form-check mb-4">
                            <input type="radio" class="form-check-input" id="pay-vnpay" name="CachThanhToan" value="VNPAY">
                            <label class="form-check-label fw-bold" for="pay-vnpay">Cổng thanh toán VNPAY</label>
                            <p class="small text-muted ms-1">Thanh toán nhanh qua QR-Code hoặc thẻ ngân hàng.</p>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 py-3 text-uppercase fw-bold rounded-pill shadow hover-zoom" style="background-color: #1E88E5; border: none;">
                            Xác nhận đặt hàng
                        </button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>
@section Scripts {
    <script>
        $(document).ready(function () {
            $("#btnApplyVoucher").click(function () {
                var code = $("#voucherCode").val();
                var subtotal = parseFloat($("#subtotal").text().replace(/,/g, ''));

                if (!code) {
                    $("#voucherMessage").html("<span class='text-warning'>Bạn chưa nhập mã mà!</span>");
                    return;
                }

                $.ajax({
                    url: "/Voucher/CheckVoucher",
                    type: "POST",
                    data: { code: code, subtotal: subtotal },
                    success: function (res) {
                        if (res.success) {
                            $("#voucherMessage").html("<span class='text-success'>" + res.message + "</span>");
                            $("#discountValue").text(res.discount.toLocaleString());

                            // 3. Lấy phí ship từ Controller trả về (đã tính logic đơn 1 triệu)
                            var phiShipMoi = res.phiShip;

                            // Cập nhật hiển thị phí ship
                            if (phiShipMoi == 0) {
                                $("#shipValue").text("Miễn phí");
                            } else {
                                $("#shipValue").text(phiShipMoi.toLocaleString() + " đ");
                            }

                            // 4. Tính toán tổng tiền dựa trên phí ship thực tế
                            var newTotal = subtotal + phiShipMoi - res.discount;
                            $("#finalTotal").text(newTotal.toLocaleString());
                        } else {
                            $("#voucherMessage").html("<span class='text-danger'>" + res.message + "</span>");
                            $("#discountValue").text("0");
                            // Nếu lỗi, vẫn phải tính lại tổng tiền dựa trên ship (đề phòng đơn 1 triệu)
                            var hienTaiShip = (subtotal >= 1000000) ? 0 : 50000;
                            $("#finalTotal").text((subtotal + hienTaiShip).toLocaleString());
                        }
                    },
                    error: function () {
                        alert("Lỗi kết nối rồi bạn ơi!");
                    }
                });
            });
        });
    </script>
}
