@model List<NAWatchMVC.ViewModels.CartItemVM>
@{
    ViewData["Title"] = "Giỏ hàng";
    Layout = "_LayoutCustomer";

    // GIẢI THÍCH: Tổng tiền() giờ đây cực kỳ đơn giản vì ThanhTien đã được tính sẵn trong VM
    // 1. Tính toán lại logic tiền dựa trên con số 1 triệu
    double subtotal = Model?.Sum(p => p.ThanhTien) ?? 0;
    double phiShip = (subtotal >= 1000000 || subtotal == 0) ? 0 : 50000;
    double finalTotal = subtotal + phiShip;
}

<div class="container-fluid page-header py-5" style="background: linear-gradient(rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.5)), url('/Hinh/banner-cart.jpg'); background-size: cover;">
    <h1 class="text-center text-white display-6">Giỏ Hàng Của Ní</h1>
    <ol class="breadcrumb justify-content-center mb-0">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
        <li class="breadcrumb-item active text-white">Giỏ hàng</li>
    </ol>
</div>

<div class="container-fluid py-5">
    <div class="container py-5">
        @if (Model != null && Model.Count > 0)
        {
            <div class="table-responsive shadow-sm rounded">
                <table class="table align-middle">
                    <thead class="bg-light">
                        <tr class="text-center">
                            <th scope="col" class="py-3">Đồng hồ</th>
                            <th scope="col" class="py-3 text-start">Tên sản phẩm</th>
                            <th scope="col" class="py-3">Giá bán</th>
                            <th scope="col" class="py-3">Số lượng</th>
                            <th scope="col" class="py-3">Thành tiền</th>
                            <th scope="col" class="py-3">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr class="text-center">
                                <td>
                                    @* Đã đổi đường dẫn sang thư mục anhall *@
                                    <img src="~/anhall/@item.Hinh" class="img-fluid rounded shadow-sm" style="width: 70px; height: 70px; object-fit: cover;" alt="@item.TenHH">
                                </td>
                                <td class="text-start">
                                    <a asp-controller="HangHoa" asp-action="Detail" asp-route-id="@item.MaHH" class="text-dark fw-bold text-decoration-none hover-primary">
                                        @item.TenHH
                                    </a>
                                    @if (item.GiamGia > 0)
                                    {
                                        <div class="badge bg-danger">Giảm @item.GiamGia%</div>
                                    }
                                </td>
                                <td>
                                    <p class="mb-0 fw-bold">@item.GiaBan.ToString("#,##0") đ</p>
                                    @if (item.GiamGia > 0)
                                    {
                                        <small class="text-muted text-decoration-line-through">@item.DonGia.ToString("#,##0") đ</small>
                                    }
                                </td>
                                <td>
                                    <div class="input-group quantity mx-auto" style="width: 110px;">
                                        <div class="input-group-btn">
                                            <a asp-action="GiamSoLuong" asp-route-id="@item.MaHH" class="btn btn-sm btn-outline-secondary rounded-circle">
                                                <i class="fa fa-minus"></i>
                                            </a>
                                        </div>
                                        <input type="text" class="form-control form-control-sm text-center border-0 fw-bold" value="@item.SoLuong" readonly>
                                        <div class="input-group-btn">
                                            <a asp-action="TangSoLuong" asp-route-id="@item.MaHH" class="btn btn-sm btn-outline-secondary rounded-circle">
                                                <i class="fa fa-plus"></i>
                                            </a>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <p class="mb-0 fw-bold text-primary">@item.ThanhTien.ToString("#,##0") đ</p>
                                </td>
                                <td>
                                    <a asp-action="RemoveCart" asp-route-id="@item.MaHH" class="btn btn-sm btn-light border text-danger rounded-circle shadow-sm" onclick="return confirm('Ní có chắc muốn bỏ chiếc đồng hồ này ra khỏi giỏ?');">
                                        <i class="fa fa-times"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @* --- PHẦN TỔNG ĐƠN HÀNG --- *@
            <div class="row g-4 justify-content-end mt-4">
                <div class="col-sm-8 col-md-7 col-lg-6 col-xl-4">
                    <div class="bg-light rounded p-4 shadow-sm border">
                        <h2 class="h4 mb-4 fw-bold border-bottom pb-2">Tóm tắt đơn hàng</h2>
                        <div class="d-flex justify-content-between mb-3">
                            <h5 class="mb-0 small">Tạm tính:</h5>
                            <p class="mb-0">@subtotal.ToString("#,##0") đ</p>
                        </div>
                        <div class="d-flex justify-content-between mb-3">
                            <h5 class="mb-0 small">Vận chuyển:</h5>
                            @if (phiShip == 0 && subtotal > 0)
                            {
                                <p class="mb-0 text-success fw-bold">Miễn phí</p>
                            }
                            else
                            {
                                <p class="mb-0 text-info fw-bold">@phiShip.ToString("#,##0") đ</p>
                            }
                        </div>
                        @if (subtotal > 0 && subtotal < 1000000)
                        {
                            <div class="alert alert-warning py-2 small mb-3">
                                <i class="fa fa-info-circle me-1"></i> Mua thêm <b>@((1000000 - subtotal).ToString("#,##0"))đ</b> để được Freeship ní nhé!
                            </div>
                        }
                        <div class="py-3 mb-4 border-top border-bottom d-flex justify-content-between align-items-center">
                            <h5 class="mb-0 fw-bold">TỔNG CỘNG:</h5>
                            <p class="mb-0 fw-bold text-danger fs-4">@finalTotal.ToString("#,##0") đ</p>
                        </div>
                        <a asp-controller="Cart" asp-action="Checkout" class="btn btn-primary w-100 py-3 text-uppercase fw-bold rounded-pill shadow-sm" style="background-color: #1E88E5; border: none;">
                            Tiến hành thanh toán <i class="fa fa-chevron-right ms-2 small"></i>
                        </a>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <div class="mb-4">
                    <i class="fa fa-shopping-basket fa-6x text-muted opacity-25"></i>
                </div>
                <h3 class="fw-bold">Giỏ hàng của ní đang trống huơ!</h3>
                <p class="text-muted">Đừng để cổ tay mình trống trải, hãy chọn ngay một chiếc đồng hồ ní nhé.</p>
                <a asp-controller="Home" asp-action="Index" class="btn btn-primary rounded-pill px-5 py-3 mt-3 fw-bold">
                    QUAY LẠI CỬA HÀNG
                </a>
            </div>
        }
    </div>
</div>