@model IEnumerable<NAWatchMVC.Data.HangHoa>
@{
    // Lấy danh sách Tag động từ ViewBag mà mình đã xử lý ở Controller
    var tags = ViewBag.DynamicTags as List<string> ?? new List<string>();
}

<div class="mb-3">
    <small class="text-muted d-block mb-2">Gợi ý từ khóa cho ní:</small>
    <div class="d-flex flex-wrap gap-2">
        @foreach (var tag in tags)
        {
            <span class="mini-tag" onclick="fillSearch('@tag')" style="cursor:pointer; background-color: #f1f3f5; padding: 4px 12px; border-radius: 20px; font-size: 0.8rem; border: 1px solid #dee2e6;">
                @tag
            </span>
        }
    </div>
</div>

<hr class="my-3 opacity-10" />

<small class="text-muted d-block mb-2">Sản phẩm hợp gu:</small>
<div class="search-results-list">
    @foreach (var item in Model)
    {
        <a asp-controller="HangHoa" asp-action="Detail" asp-route-id="@item.MaHh"
           class="d-flex align-items-center p-2 mb-2 text-decoration-none rounded search-item-hover"
           style="transition: 0.2s;">

            <img src="~/anhall/@item.Hinh" alt="@item.TenHh"
                 style="width: 48px; height: 48px; object-fit: cover;" class="rounded border">

            <div class="ms-3 flex-grow-1">
                <div class="text-dark fw-bold text-truncate" style="max-width: 200px; font-size: 0.85rem;">
                    @item.TenHh
                </div>
                <div class="text-danger small fw-bold">
                    @item.DonGia?.ToString("#,##0") đ
                </div>
            </div>

            <i class="fas fa-chevron-right text-muted" style="font-size: 0.7rem;"></i>
        </a>
    }
</div>

<style>
    .search-item-hover:hover {
        background-color: #f8f9fa;
        transform: translateX(5px);
    }

    .mini-tag:hover {
        background-color: #e9ecef !important;
        color: #0d6efd;
    }
</style>