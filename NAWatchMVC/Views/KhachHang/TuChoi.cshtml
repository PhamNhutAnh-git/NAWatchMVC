@{
    Layout = "_LayoutCustomer"; // Dùng đúng Layout của khách hàng như Bạn yêu cầu
    ViewData["Title"] = "Truy cập bị từ chối";
}

<div class="container access-denied-container text-center">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8 text-center">
            <div class="error-illustration mb-5">
                <div class="icon-box shadow-lg mx-auto d-flex align-items-center justify-content-center">
                    <i class="fas fa-user-lock text-white"></i>
                </div>
            </div>

            <h2 class="fw-bold text-dark mb-3" style="letter-spacing: -1px;">KHU VỰC GIỚI HẠN!</h2>
            <p class="text-muted fs-5 mb-5 px-md-5">
                Rất tiếc bạn ơi, trang này chỉ dành cho <strong>Ban quản trị NAWatch</strong>.
                Tài khoản của Bạn không có quyền "vượt rào" vào đây đâu nhé!
            </p>

            <div class="d-flex flex-column flex-sm-row justify-content-center gap-3">
                <a href="/" class="btn btn-dark btn-lg px-5 py-3 shadow">
                    <i class="fas fa-shopping-bag me-2"></i>Tiếp tục mua sắm
                </a>
                <button onclick="history.back()" class="btn btn-outline-dark btn-lg px-5 py-3">
                    <i class="fas fa-arrow-left me-2"></i>Quay lại trang trước
                </button>
            </div>

            <div class="mt-5 pt-4 border-top">
                <small class="text-secondary">Nếu Bạn nghĩ đây là một sự nhầm lẫn, hãy liên hệ với bộ phận kỹ thuật để được hỗ trợ.</small>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        /* Tùy chỉnh khoảng cách dựa trên cái Header của Bạn */
        .access-denied-container {
            margin-top: 155px; /* Thử tăng số này lên nếu vẫn bị che */
            padding-bottom: 50px;
        }
        /* Tông màu tối sang trọng cho NAWatch */
        :root {
            --primary-dark: #1a1a1a;
        }

        .icon-box {
            width: 120px;
            height: 120px;
            background: var(--primary-dark);
            border-radius: 30% 70% 70% 30% / 30% 30% 70% 70%;
            font-size: 50px;
            animation: morphing 10s infinite alternate ease-in-out;
        }

        .btn-dark {
            background-color: var(--primary-dark);
            border: none;
            transition: transform 0.2s;
        }

            .btn-dark:hover {
                transform: translateY(-3px);
                background-color: #333;
            }

        /* Hiệu ứng chuyển động cho Icon nhìn cho Pro */
        @@keyframes morphing {
            0% {
                border-radius: 30% 70% 70% 30% / 30% 30% 70% 70%;
            }

            25% {
                border-radius: 58% 42% 75% 25% / 76% 46% 54% 24%;
            }

            50% {
                border-radius: 50% 50% 33% 67% / 55% 27% 73% 45%;
            }

            75% {
                border-radius: 33% 67% 58% 42% / 63% 68% 32% 37%;
            }

            100% {
                border-radius: 30% 70% 70% 30% / 30% 30% 70% 70%;
            }
        }
    </style>
}