@model NAWatchMVC.Data.KhachHang
@{
    ViewData["Title"] = "Hồ sơ của tôi";
    Layout = "_LayoutCustomer";
}

<div class="container-fluid page-header py-5">
    <h1 class="text-center text-white display-6">Hồ Sơ Cá Nhân</h1>
    <ol class="breadcrumb justify-content-center mb-0">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
        <li class="breadcrumb-item active text-white">Thông tin tài khoản</li>
    </ol>
</div>

<div class="container-fluid py-5">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                    @* --- Header Profile --- *@
                    <div class="card-header p-4 text-center" style="background-color: #1E88E5;">
                        <div class="rounded-circle bg-white d-inline-flex align-items-center justify-content-center mb-3 shadow" style="width: 120px; height: 120px; border: 4px solid rgba(255,255,255,0.2);">
                            @if (string.IsNullOrEmpty(Model.Hinh) || Model.Hinh == "default.jpg")
                            {
                                <i class="fas fa-user fa-5x" style="color: #1E88E5;"></i>
                            }
                            else
                            {
                                <img src="~/anhKH/@Model.Hinh" class="rounded-circle w-100 h-100 object-fit-cover">
                            }
                        </div>
                        <h3 class="mb-0 fw-bold text-white">@Model.HoTen</h3>
                        <p class="mb-0 text-white-50 small">Thành viên chính thức NAWatch</p>
                    </div>

                    <div class="card-body p-5 bg-white">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h4 class="text-primary fw-bold mb-0">
                                <i class="fas fa-info-circle me-2"></i>Thông tin cá nhân
                            </h4>
                            <a asp-action="EditProfile" class="btn btn-outline-primary btn-sm rounded-pill px-4">
                                <i class="fas fa-edit me-1"></i> Chỉnh sửa hồ sơ
                            </a>
                        </div>

                        <div class="row g-4">
                            @* --- Hiển thị Tên đăng nhập thay cho Mã KH cho khách dễ nhớ --- *@
                            <div class="col-md-6">
                                <label class="form-label fw-bold text-secondary small text-uppercase">Tên đăng nhập</label>
                                <p class="form-control-plaintext border-bottom fw-bold text-dark">@Model.TenDangNhap</p>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold text-secondary small text-uppercase">Số điện thoại</label>
                                <p class="form-control-plaintext border-bottom text-dark">@(string.IsNullOrEmpty(Model.DienThoai) ? "Chưa cập nhật" : Model.DienThoai)</p>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold text-secondary small text-uppercase">Email</label>
                                <p class="form-control-plaintext border-bottom text-dark">@Model.Email</p>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold text-secondary small text-uppercase">Giới tính</label>
                                <p class="form-control-plaintext border-bottom text-dark">
                                    <i class="fas @(Model.GioiTinh == true ? "fa-mars text-info" : "fa-venus text-danger") me-1"></i>
                                    @(Model.GioiTinh == true ? "Nam" : "Nữ")
                                </p>
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-bold text-secondary small text-uppercase">Địa chỉ giao hàng mặc định</label>
                                <p class="form-control-plaintext border-bottom text-dark">
                                    <i class="fas fa-map-marker-alt text-danger me-1"></i>
                                    @(string.IsNullOrEmpty(Model.DiaChi) ? "Bạn vui lòng cập nhật địa chỉ để NAWatch giao hàng tận nơi nhé!" : Model.DiaChi)
                                </p>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between mt-5 pt-3 border-top">
                            <a asp-controller="HangHoa" asp-action="Index" class="btn btn-light rounded-pill px-4 fw-bold">
                                <i class="fas fa-shopping-cart me-2"></i>Tiếp tục mua sắm
                            </a>
                            <div class="gap-2 d-flex">
                                <a asp-action="DoiMatKhau" class="btn btn-outline-warning rounded-pill px-4 fw-bold">
                                    <i class="fas fa-lock me-2"></i>Đổi mật khẩu
                                </a>
                                <a asp-action="DangXuat" class="btn btn-danger rounded-pill px-4 fw-bold shadow-sm" onclick="return confirm('Bạn chắc chắn muốn đăng xuất không?')">
                                    <i class="fas fa-sign-out-alt me-2"></i>Thoát
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
