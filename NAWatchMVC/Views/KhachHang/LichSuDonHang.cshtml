@model IEnumerable<NAWatchMVC.Data.HoaDon> 
@{
    ViewData["Title"] = "Lịch sử đơn hàng";
    Layout = "_LayoutCustomer";
}
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<div class="container-fluid page-header py-5">
    <h1 class="text-center text-white display-6">Đơn Hàng Của Tôi</h1>
    <ol class="breadcrumb justify-content-center mb-0">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
        <li class="breadcrumb-item active text-white">Lịch sử mua hàng</li>
    </ol>
</div>

<div class="container-fluid pt-3 pb-5">
    <div class="container">
        @* TRẢ LẠI CHỮ DANH SÁCH ĐƠN HÀNG ĐÂY NÍ ƠI *@
        <h3 class="text-center fw-bold text-primary mb-3 text-uppercase">Danh Sách Đơn Hàng Của Bạn</h3>
        @if (Model != null && Model.Any())
        {
            @* ÉP CỨNG MÀU XANH DƯƠNG CHO THEAD *@
            <div class="table-responsive shadow-lg rounded-4 overflow-hidden">
                <table class="table table-hover align-middle mb-0 bg-white text-center">
                    <thead style="background-color: #1E88E5 !important;" class="text-white border-0">
                        <tr>
                            <th class="py-3">Mã đơn</th>
                            <th class="py-3">Ngày đặt</th>
                            <th class="py-3">Tổng tiền</th>
                            <th class="py-3">Trạng thái</th>
                            <th class="py-3">Xem</th>
                            <th class="py-3">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold">#@item.MaHd</td>
                                <td>@item.NgayDat?.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="fw-bold text-danger">@item.TongTien?.ToString("#,##0") đ</td>
                                <td class="text-center">
                                    @if (item.MaTrangThai == 0)
                                    {
                                        @* Đơn mới đặt: Cho phép khách tự hủy *@
                                        <span class="badge bg-warning text-dark">Mới đặt, chờ xác nhận</span>
                                    }
                                    else if (item.MaTrangThai == 1)
                                    {
                                        <span class="badge bg-primary"> Đơn VNPAY chờ xác nhận</span>   
                                    }
                                    else if (item.MaTrangThai == 2)
                                    {
                                        <span class="badge bg-primary"> Đã xác nhận đang giao</span>  
                                    }
                                    else
                                    {
                                        @* Các trạng thái khác: Show tên trạng thái bằng Badge cho Pro *@
                                        @switch (item.MaTrangThai)
                                        {
                                            case 3:
                                                <span class="badge rounded-pill bg-success px-3">Giao thành công</span>
                                                break;
                                            case 4:
                                                <span class="badge rounded-pill bg-secondary px-3">Đã hủy đơn</span>
                                                break;
                                            case 5:
                                                <span class="badge bg-warning text-dark">Đã hoàn tiền</span>
                                                break;
                                            default:
                                                <span class="badge rounded-pill bg-dark px-3">Hệ thống xử lý</span>
                                                break;
                                        }
                                    }
                                </td>
                                <td>
                                    <a asp-action="ChiTietDonHang" asp-route-id="@item.MaHd" class="btn btn-sm btn-outline-primary rounded-circle">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                </td>
                                <td>
                                    @if (item.MaTrangThai == 0)
                                    {
                                        <button onclick="confirmCancel(@item.MaHd)" class="btn btn-sm btn-danger rounded-pill px-3 fw-bold shadow-sm">Hủy đơn</button>
                                    }
                                    else if (item.MaTrangThai == 1)
                                    {
                                        @* Đơn đã thanh toán VNPay: Dẫn về trang Contact để nhắn Zalo *@
                                        <a asp-controller="Contact" asp-action="Index"
                                           class="btn btn-sm btn-info text-dark rounded-pill px-3 shadow-sm"
                                           title="Bấm để liên hệ Zalo hủy đơn và hoàn tiền">
                                            <i class="fas fa-headset me-1"></i> Liên hệ hủy
                                        </a>
                                    }
                                    else if (item.MaTrangThai == 2)
                                    {
                                        @* Đang giao: Dẫn về trang Contact để hỏi thăm shipper *@
                                        <a asp-controller="Contact" asp-action="Index"
                                           class="btn btn-sm btn-outline-primary rounded-pill px-3 shadow-sm">
                                            <i class="fas fa-truck me-1"></i> Theo dõi đơn
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">Không thể hủy</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="mt-4">
                <nav aria-label="Page navigation">
                    <ul class="pagination justify-content-center d-flex flex-row list-unstyled">
                        @for (int i = 1; i <= ViewBag.TotalPages; i++)
                        {
                            <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "") mx-1">
                                <a class="page-link rounded shadow-sm border-0"
                                   style="@(i == ViewBag.CurrentPage ? "background-color: #1E88E5; color: white;" : "color: #1E88E5;")"
                                   asp-action="LichSuDonHang" asp-route-page="@i">@i</a>
                            </li>
                        }
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>

<style>
    .badge {
        font-weight: 500;
        font-size: 0.85rem;
        min-width: 100px;
    }

    .btn-sm {
        font-size: 0.8rem;
    }
</style>
<script>
    // 1. Thông báo khi Hủy thành công (Lấy từ TempData)
    @if (TempData["Message"] != null)
    {
        <text>
                Swal.fire({
                    icon: 'success',
                title: 'Thông báo!',
                text: '@Html.Raw(TempData["Message"])', // Thêm Html.Raw ở đây ní nhé
                timer: 3000,
                showConfirmButton: false
                });
        </text>
    }

        // 2. Hàm xác nhận Hủy đơn
        function confirmCancel(id) {
            Swal.fire({
                title: 'Bạn chắc chưa?',
                text: "Hủy rồi là hàng bay về kho lại đó nha!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Ừ, Hủy đi!',
                cancelButtonText: 'Thôi, bấm nhầm'
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = '/Cart/CancelOrder/' + id;
                }
            })
        }
</script>