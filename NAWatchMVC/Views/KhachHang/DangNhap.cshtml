@model NAWatchMVC.ViewModels.LoginVM
@{
    ViewData["Title"] = "Đăng nhập";
    // Bạn kiểm tra xem project mới dùng _Layout hay _LayoutCustomer nhé
    Layout = "_LayoutCustomer";
}

<div class="container-fluid page-header py-5">
    <h1 class="text-center text-white display-6">Đăng Nhập</h1>
    <ol class="breadcrumb justify-content-center mb-0">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
        <li class="breadcrumb-item active text-white">Đăng nhập</li>
    </ol>
</div>

@if (!ViewData.ModelState.IsValid)
{
    <div class="d-flex justify-content-center w-100 mb-4">
        <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm text-center py-3 px-4"
             style="max-width: 500px; border-radius: 15px; background-color: #fff5f5;" role="alert">

            @* Thêm cái icon cho nó sinh động *@
            <i class="fas fa-exclamation-circle mb-2 d-block fa-2x" style="color: #dc3545;"></i>

            <strong class="d-block mb-1" style="font-size: 1.1rem;">Đăng nhập thất bại rồi ní ơi!</strong>

            @* Thêm class list-unstyled để dẹp mấy dấu chấm đầu dòng *@
            <div asp-validation-summary="All" class="text-danger small list-unstyled"></div>

            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    </div>
}

<div class="container-fluid py-5">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-5">
                <div class="bg-light rounded p-5 shadow-sm border border-secondary" style="border-style: dashed !important;">

                    <h2 class="text-center mb-4 text-primary fw-bold">Đăng Nhập</h2>

                    @if (TempData["Message"] != null)
                    {
                        <div class="alert alert-warning text-center">@TempData["Message"]</div>
                    }

                    <form asp-action="DangNhap" asp-route-returnurl="@ViewBag.ReturnUrl" method="post">
                        <input type="hidden" name="ReturnUrl" value="@Context.Request.Query["ReturnUrl"]" />
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Tên đăng nhập/ email / Mã NV</label>
                            @* Đổi UserName thành TenDangNhap *@
                            <input asp-for="TenDangNhap" class="form-control border-secondary py-3 rounded-pill" placeholder="Nhập tên tài khoản">
                            <span asp-validation-for="TenDangNhap" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Mật khẩu</label>
                            <div class="input-group">
                                @* Đổi Password thành MatKhau và giữ nguyên ID để Script chạy *@
                                <input asp-for="MatKhau" type="password" class="form-control border-secondary py-3 rounded-pill" id="passwordInput" placeholder="Nhập mật khẩu">
                                <button class="btn btn-outline-secondary border-secondary py-3 rounded-pill" type="button" id="togglePassword">
                                    <i class="fas fa-eye"></i>
                                </button>
                            </div>
                            <span asp-validation-for="MatKhau" class="text-danger"></span>
                        </div>

                        <div class="d-flex justify-content-between mb-4">
                            <div class="form-check">
                                <input class="form-check-input" asp-for="RememberMe">
                                <label class="form-check-label" asp-for="RememberMe">Ghi nhớ tôi</label>
                            </div>
                            <a asp-action="QuenMatKhau" class="text-primary text-decoration-none">Quên mật khẩu?</a>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary text-white rounded-pill py-3 fw-bold fs-5 shadow-sm">ĐĂNG NHẬP</button>
                        </div>

                        <div class="text-center mt-4">
                            <span>Bạn chưa có tài khoản? </span>
                            <a asp-action="DangKy" class="text-primary fw-bold">Đăng ký ngay</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @* 1. Load Validation mặc định của ASP.NET *@
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    @* 2. Load thư viện SweetAlert2 (Nếu Layout chưa có thì ní thêm dòng này)= đã co *@
    

    <script>
        $(document).ready(function () {
            // --- A. LOGIC ẨN/HIỆN MẬT KHẨU CỦA NÍ ---
            $("#togglePassword").click(function () {
                var input = $("#passwordInput");
                var icon = $(this).find("i");

                if (input.attr("type") === "password") {
                    input.attr("type", "text");
                    icon.removeClass("fa-eye").addClass("fa-eye-slash");
                } else {
                    input.attr("type", "password");
                    icon.removeClass("fa-eye-slash").addClass("fa-eye");
                }
            });

            // --- B. HIỆN POPUP LỖI (SAI USER, SAI PASS, KHÓA TK) ---
        @if (!ViewData.ModelState.IsValid)
        {
            // Lấy thông báo lỗi từ key "loi" mà mình đã đặt ở Controller
            var error = ViewData.ModelState["loi"]?.Errors.FirstOrDefault()?.ErrorMessage;
            if (!string.IsNullOrEmpty(error))
            {
                <text>
                            Swal.fire({
                                icon: 'error',
                            title: 'Lỗi một chút!',
                            text: '@Html.Raw(error)', // Thêm Html.Raw vào đây nè ní
                            confirmButtonColor: '#1E88E5', // Màu xanh NAWatch của ní
                            background: '#fff',
                            timer: 5000 // Tự đóng sau 5s nếu ní lười bấm
                                    });
                </text>
            }
        }

                // --- C. HIỆN POPUP THÀNH CÔNG (KHI ĐỔI PASS XONG NHẢY VỀ) ---
        @if (TempData["Message"] != null)
        {
            <text>
                        Swal.fire({
                            icon: 'success',
                        title: 'Ngon lành!',
                        text: '@TempData["Message"]',
                        showConfirmButton: false,
                        timer: 3000
                            });
            </text>
        }
                });
    </script>
}