@{
    ViewData["Title"] = "Thông báo quyền truy cập";
    // Kiểm tra lại nếu project mới chỉ có _Layout thì sửa lại tên nhé ní
    Layout = "_LayoutCustomer";
}

<div class="container-fluid py-5" style="margin-top: 100px;">
    <div class="container text-center py-5">
        <div class="card shadow-lg border-0 rounded-4 p-5 mx-auto" style="max-width: 650px; background: #ffffff;">
            <div class="mb-4">
                @* Đổi màu icon sang xanh đặc trưng của NAWatch cho đồng bộ *@
                <i class="fas fa-user-shield fa-6x" style="color: #1E88E5;"></i>
            </div>

            <h2 class="fw-bold text-dark mb-3">Dừng lại tí nhé, Quản trị viên!</h2>

            <p class="lead text-muted px-3">
                Bạn đang đăng nhập với tư cách là <strong>@User.Identity.Name (Admin/Nhân viên)</strong>.<br>
                Trang này (Lịch sử đơn hàng/Giỏ hàng) chỉ dành riêng cho khách hàng cá nhân thôi nè.
            </p>

            <div class="alert alert-info border-0 rounded-pill mx-4 py-2 mt-3">
                <i class="fas fa-info-circle me-2"></i>
                Hãy sử dụng tài khoản <strong>Khách hàng</strong> để trải nghiệm tính năng mua sắm.
            </div>

            <div class="d-grid gap-3 mt-4 px-5">
                @* Sửa đường dẫn về đúng trang HomeAdmin của ní *@
                <a href="/Admin/HomeAdmin" class="btn btn-primary text-white rounded-pill py-3 fw-bold shadow-sm">
                    <i class="fas fa-tachometer-alt me-2"></i> Về Trang Quản Trị
                </a>

                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary rounded-pill py-2 fw-bold">
                    <i class="fas fa-home me-2"></i> Quay lại Trang Chủ
                </a>
            </div>
        </div>
    </div>
</div>
