@model IEnumerable<NAWatchMVC.Data.HangHoa>
@{
    ViewData["Title"] = "Sản phẩm ní đã mua";
}

<div class="container py-5" style="margin-top: 150px;">
    <div class="text-center mb-5">
        <h2 class="fw-bold text-uppercase" style="color: #1E88E5;">Sản phẩm đã đồng hành cùng ní</h2>
        <p class="text-muted">Dưới đây là những chiếc đồng hồ ní đã sở hữu. Muốn mua thêm cái nữa không ní?</p>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="fas fa-history fa-4x text-light mb-3"></i>
            <p class="text-muted">Chưa có sản phẩm nào được giao thành công hết ní ơi!</p>
            <a asp-controller="HangHoa" asp-action="Index" class="btn btn-primary rounded-pill px-4">Đến Cửa Hàng</a>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4">
            @foreach (var item in Model)
            {
                <div class="col">
                    <div class="card h-100 border-0 shadow-sm rounded-3 overflow-hidden position-relative product-card">
                        @* Ảnh sản phẩm *@
                        <div class="position-relative overflow-hidden">
                            <img src="~/anhall/@item.Hinh" class="card-img-top img-fluid" style="height: 250px; object-fit: cover;" alt="@item.TenHh">
                            <div class="badge bg-success position-absolute top-0 start-0 m-3">Đã mua</div>
                        </div>

                        @* Nội dung *@
                        <div class="card-body text-center">
                            <h6 class="fw-bold mb-2 text-truncate">@item.TenHh</h6>
                            <p class="text-danger fw-bold mb-3">@item.DonGia?.ToString("#,##0") đ</p>

                            @* Nút Mua Lại (Dùng AJAX ní đã làm) *@
                            <button class="btn btn-primary w-100 rounded-pill py-2 add-to-cart-js shadow-sm"
                                    data-id="@item.MaHh">
                                <i class="fas fa-redo me-2"></i> MUA LẠI NGAY
                            </button>
                        </div>

                        <a asp-controller="HangHoa" asp-action="Detail" asp-route-id="@item.MaHh" class="stretched-link"></a>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .product-card {
        transition: transform 0.3s ease, shadow 0.3s ease;
    }
    .product-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 10px 25px rgba(0,0,0,0.1) !important;
    }
    .add-to-cart-js {
        position: relative;
        z-index: 2; /* Để nút nằm trên cái stretched-link */
    }
</style>