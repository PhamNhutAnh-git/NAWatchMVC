@model IEnumerable<NAWatchMVC.Data.HangHoa>
@{
    ViewData["Title"] = "Gợi ý dành riêng cho ní";
}

<div class="container py-5" style="margin-top: 150px;">
    @* Banner tiêu đề cực cháy *@
    <div class="p-5 mb-5 rounded-3 shadow-sm text-white"
         style="background: linear-gradient(135deg, #1E88E5 0%, #1565C0 100%);">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h1 class="display-5 fw-bold text-white">Gợi ý dành riêng cho ní <i class="fas fa-magic"></i></h1>
                <p class="fs-5 opacity-75">Dựa trên sở thích và hành vi của ní, NAWATCH đã lựa chọn ra những mẫu đồng hồ "hợp gu" nhất đây!</p>
            </div>
            <div class="col-md-4 text-end d-none d-md-block">
                <i class="fas fa-user-sparkles fa-5x opacity-25"></i>
            </div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <p class="text-muted">Chưa có dữ liệu gợi ý. Hãy xem thêm nhiều sản phẩm để tui hiểu ní hơn nhé!</p>
            <a href="/" class="btn btn-primary rounded-pill">Khám phá cửa hàng</a>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-4 g-4">
            @foreach (var item in Model)
            {
                <div class="col">
                    <div class="card h-100 border-0 shadow-sm rounded-3 overflow-hidden position-relative product-card">
                        @* Hình ảnh *@
                        <div class="position-relative overflow-hidden">
                            <img src="~/anhall/@item.Hinh" class="card-img-top img-fluid" style="height: 250px; object-fit: cover;" alt="@item.TenHh">
                            <div class="badge bg-warning text-dark position-absolute top-0 start-0 m-3 shadow-sm">
                                <i class="fas fa-star"></i> Đề xuất
                            </div>
                        </div>

                        @* Nội dung *@
                        <div class="card-body text-center d-flex flex-column">
                            <h6 class="fw-bold mb-2 text-truncate">@item.TenHh</h6>
                            <p class="text-danger fw-bold fs-5 mb-3">@item.DonGia?.ToString("#,##0") đ</p>

                            @* Nút xem và mua nhanh *@
                            <div class="mt-auto d-grid gap-2">
                                <a asp-controller="HangHoa" asp-action="Detail" asp-route-id="@item.MaHh"
                                   class="btn btn-dark rounded-pill py-2">Xem chi tiết</a>
                                <button class="btn btn-primary rounded-pill py-2 add-to-cart-js" data-id="@item.MaHh">
                                    <i class="fas fa-cart-plus me-1"></i> Bỏ vào giỏ
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .product-card {
        transition: transform 0.3s ease;
    }
    .product-card:hover {
        transform: translateY(-10px);
    }
</style>