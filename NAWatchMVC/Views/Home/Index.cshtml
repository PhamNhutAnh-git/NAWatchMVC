@model HomeViewModel
@{
    ViewData["Title"] = "Trang Chủ - NAWatch";
    Layout = "_LayoutCustomer";
}

@section Styles {
    <style>
        /* =========================================================
                                   1. CSS VOUCHER & SECTION (GIỮ NGUYÊN BẢN GỐC CỦA NÍ)
                                   ========================================================= */
        .voucher-container {
            display: flex;
            gap: 15px;
            overflow-x: auto;
            padding: 20px 0;
            scrollbar-width: none;
        }

            .voucher-container::-webkit-scrollbar {
                display: none;
            }

        .voucher-card {
            display: flex;
            width: 300px;
            min-width: 300px;
            height: 90px;
            border-radius: 10px;
            overflow: hidden;
            box-shadow: 0 3px 10px rgba(0,0,0,0.1);
            background: #fff;
            border: 1px solid #f1f1f1;
        }

        .voucher-left {
            background: #ffc107;
            width: 25%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #000;
            font-size: 1.8rem;
        }

        .voucher-right {
            padding: 8px 12px;
            width: 75%;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        .voucher-title {
            font-weight: bold;
            font-size: 0.85rem;
            color: #333;
            line-height: 1.2;
        }

        .voucher-desc {
            font-size: 0.7rem;
            color: #777;
        }

        .voucher-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .voucher-code {
            font-size: 0.75rem;
            font-weight: bold;
            color: #0d6efd;
            border: 1px dashed #0d6efd;
            padding: 0 5px;
        }

        .btn-save-v {
            background: #0d6efd;
            color: white;
            border: none;
            padding: 2px 12px;
            border-radius: 5px;
            font-size: 0.75rem;
        }

        .section-title {
            position: relative;
            padding-bottom: 10px;
            margin-bottom: 30px;
            font-weight: bold;
        }

            .section-title::after {
                content: '';
                position: absolute;
                left: 0;
                bottom: 0;
                width: 50px;
                height: 3px;
                background: #ffc107;
            }

        /* =========================================================
                        2. BỘ HERO HEADER "NAW-" ĐỘC QUYỀN (CHỐNG XUNG ĐỘT & TEỎ SLIDE)
                 ========================================================= */
        /* --- HERO SECTION: CĂN GIỮA VÀ TRÀN NỀN --- */
        .naw-hero-section {
            height: 100vh; /* Chiều cao bằng 100% màn hình */
            min-height: 600px;
            display: flex;
            align-items: center; /* Căn giữa nội dung theo chiều dọc */
            justify-content: center;
            position: relative;
            overflow: hidden;
            padding: 0 !important; /* Xóa mọi padding để căn giữa chuẩn */
        }

        .naw-hero-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(224, 242, 255, 0.6) !important;
            z-index: 1;
        }

        .naw-hero-content {
            position: relative;
            z-index: 5;
            width: 100%;
        }

        .naw-slogan-title {
            font-size: 3.8rem;
            font-weight: 800;
            color: #1a2a3a;
            line-height: 1.1;
            text-shadow: 2px 2px 0px #fff;
        }

        /* --- SLIDE: XÓA KHUNG VÀ CĂNG NGANG --- */
        .naw-slider-frame {
            background: transparent !important; /* XÓA KHUNG TRẮNG */
            padding: 0 !important; /* XÓA PADDING */
            box-shadow: none !important; /* XÓA ĐỔ BÓNG */
            overflow: hidden !important;
            width: 100% !important;
        }

        #nawTopCarousel, .carousel-inner, .carousel-item {
            width: 100% !important;
            height: 480px !important; /* Tăng chiều cao lên chút cho cân với chiều dài */
            border-radius: 20px; /* Bo góc trực tiếp cho ảnh */
        }

        .naw-carousel-img {
            width: 100% !important;
            height: 100% !important;
            object-fit: cover !important;
            border-radius: 20px;
        }

        /* --- NÚT ĐIỀU HƯỚNG: ĐẨY XUỐNG DƯỚI CÙNG --- */
        #nawTopCarousel .carousel-control-prev,
        #nawTopCarousel .carousel-control-next {
            top: auto !important; /* Tắt căn giữa dọc */
            bottom: 30px !important; /* Đẩy cách đáy 30px */
            width: 45px;
            height: 45px;
            background-color: rgba(13, 110, 253, 0.8) !important; /* Màu xanh Primary */
            border-radius: 50%;
            transform: none !important;
            z-index: 10;
            opacity: 0;
            transition: all 0.3s ease-in-out; /* Hiệu ứng hiện lên mượt mà */
        }

        /* --- BƯỚC 2: MỖI NÚT NẰM 1 GÓC --- */
        #nawTopCarousel .carousel-control-prev {
            left: 20px !important; /* Góc dưới bên trái */
            right: auto !important;
        }

        #nawTopCarousel .carousel-control-next {
            right: 20px !important; /* Góc dưới bên phải */
            left: auto !important;
        }
        /* --- BƯỚC 3: RÊ CHUỘT VÀO SLIDE THÌ HIỆN NÚT --- */
        #nawTopCarousel:hover .carousel-control-prev,
        #nawTopCarousel:hover .carousel-control-next {
            opacity: 1;
        }
        /* --- SUB-SLOGAN: ĐẬM ĐEN VÀ RÕ NÉT --- */
        .naw-sub-slogan {
            font-weight: 700 !important; /* Đậm chuẩn Bold */
            color: #000000 !important; /* Đen tuyền tuyệt đối */
            letter-spacing: 0.3px; /* Khoảng cách chữ hẹp lại chút cho chắc khối */
            line-height: 1.5; /* Giãn dòng vừa đủ để không bị dính chữ */
            opacity: 0.95; /* Cho hơi trong suốt xíu để nhìn nó sang, không bị thô */
            text-shadow: 1px 1px 0px #fff;
        }
        /* Search Box */
        .naw-search-box {
            border-radius: 50px 0 0 50px !important;
            border: 2px solid #0d6efd !important;
            padding-left: 25px !important;
            background: rgba(255,255,255,0.9) !important;
        }

        .naw-btn-search {
            border-radius: 0 50px 50px 0 !important;
            font-weight: bold;
            padding: 0 30px !important;
        }
        /*  bắt đầu cho thẻ đã xem */
        /* Cuộn ngang mượt mà */
        .naw-recent-scroll-wrapper {
            display: flex;
            gap: 15px;
            overflow-x: auto;
            padding-bottom: 15px;
            scrollbar-width: none;
        }

            .naw-recent-scroll-wrapper::-webkit-scrollbar {
                display: none;
            }

        /* Thẻ ngang chuẩn TGDĐ */
        .naw-home-recent-card {
            min-width: 300px;
            background: #fff;
            border: 1px solid #eee;
            border-radius: 12px;
            padding: 12px;
            position: relative;
            text-decoration: none !important;
            transition: 0.3s;
        }

            .naw-home-recent-card:hover {
                border-color: #0D0D0D;
                box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            }

        .naw-recent-flex {
            display: flex;
            align-items: center;
        }

        .naw-recent-img-box {
            width: 80px;
            height: 80px;
            margin-right: 15px;
        }

            .naw-recent-img-box img {
                width: 100%;
                height: 100%;
                object-fit: contain;
            }

        .naw-recent-name {
            font-size: 0.9rem;
            font-weight: 600;
            color: #333;
            margin-bottom: 5px;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .naw-recent-price {
            color: #d0021c;
            font-weight: bold;
            font-size: 0.95rem;
        }

        .naw-recent-x {
            position: absolute;
            top: 5px;
            right: 8px;
            color: #bbb;
            font-size: 18px;
        }
        /* bắt đầu cho các thẻ sản phẩm trứng bài */
        .naw-cate-title {
            font-family: 'Playfair Display', serif; /* Ní nên thêm font này vào layout */
            font-size: 2.2rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 2px;
            /* Hiệu ứng chữ màu vàng kim */
            background: linear-gradient(to right, #bf953f, #fcf6ba, #b38728, #fbf5b7, #aa771c);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            /* Đổ bóng nhẹ cho chữ nổi khối */
            text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
        }
        /* 1. KHUNG TỔNG THỂ (MÀU XANH ĐEN) */
        .naw-category-block {
            background-color: #0d2e20;
            border-radius: 15px;
            overflow: visible; /* Cho phép nút navigation bay ra ngoài biên */
            margin-bottom: 50px;
            padding: 15px;
        }
        /* CỘT TRÁI: CHỨA VIDEO */
        .naw-video-banner {
            border-radius: 10px;
            overflow: hidden;
            height: 100%;
            min-height: 350px;
        }

        /* 2. KHUNG TRẮNG CHỨA SLIDER (PRODUCT BOX) */
        .naw-product-box {
            position: relative;
            background-color: #fff;
            border-radius: 12px;
            /* Rút padding ngang lại tối đa để card có thêm chiều rộng */
            padding: 15px 10px !important;
            height: 100%;
        }

        /* 3. ĐIỀU CHỈNH OWL CAROUSEL ĐỂ CARD CAO BẰNG NHAU */
        .naw-brand-carousel .owl-stage {
            display: flex !important;
            align-items: stretch !important;
        }

        .naw-brand-carousel .owl-item {
            display: flex !important;
            justify-content: center;
        }

        /* 4. CHI TIẾT THẺ SẢN PHẨM (CARD) - PHẢI TO VÀ RÕ */
        .naw-brand-carousel .fruite-item {
            width: 100% !important;
            display: flex !important;
            flex-direction: column;
            justify-content: space-between;
            background: #fff;
            border: 1px solid #f0f0f0 !important;
            border-radius: 12px;
            padding: 20px !important;
            transition: all 0.3s ease;
            margin: 0 10px; /* Khoảng cách nhỏ giữa các card */
        }

            .naw-brand-carousel .fruite-item:hover {
                box-shadow: 0 5px 15px rgba(0,0,0,0.1);
                border-color: #ffc107 !important;
                transform: translateY(-10px); /* Bay lên một chút */
                filter: drop-shadow(0 10px 20px rgba(255, 193, 7, 0.3));
            }

        /* Ép ảnh to lên để card nhìn bề thế */
        .naw-brand-carousel .fruite-img img {
            width: 100% !important;
            height: 190px !important; /* Tăng chiều cao ảnh */
            object-fit: contain !important;
            margin-bottom: 10px;
        }

        /* 5. CUSTOM NÚT BẤM (NAVIGATION) ĐÚNG CHUẨN THẾ GIỚI DI ĐỘNG */
        .naw-brand-carousel .owl-nav {
            position: absolute;
            top: 50%;
            width: 106%; /* Cho nó rộng hơn khung trắng một chút */
            left: -3%; /* Đẩy sang trái để nút nằm ngay biên */
            transform: translateY(-50%);
            pointer-events: none;
            display: flex;
            justify-content: space-between;
            z-index: 10;
        }

            .naw-brand-carousel .owl-nav button {
                width: 40px;
                height: 40px;
                background: #fff !important;
                color: #333 !important;
                border-radius: 50% !important;
                box-shadow: 0 4px 10px rgba(0,0,0,0.15) !important;
                pointer-events: auto;
                display: flex;
                align-items: center;
                justify-content: center;
                transition: 0.3s;
                border: 1px solid #eee !important;
            }

                .naw-brand-carousel .owl-nav button:hover {
                    background: #ffc107 !important;
                    color: #000 !important;
                }

        /* Ẩn dấu chấm phụ */
        .naw-brand-carousel .owl-dots {
            display: none;
        }
        /* Định nghĩa tỉ lệ 2.5 / 9.5 cho màn hình lớn (lg) */
        @@media (min-width: 992px) {
            .col-naw-25 {
                flex: 0 0 auto !important;
                width: 20.833333% !important;
            }

            .col-naw-95 {
                flex: 0 0 auto !important;
                width: 79.166667% !important;
            }
        }
        /* vide intro */
        .naw-intro-video-box {
            border: 8px solid #fff; /* Tạo khung trắng như một bức tranh */
            transition: transform 0.3s ease;
        }

            .naw-intro-video-box:hover {
                transform: scale(1.02); /* Rê chuột vào thì nó nở ra nhẹ */
            }

        /* Tùy chỉnh đoạn văn bản cho dễ đọc */
        .lh-lg {
            line-height: 1.8 !important;
            text-align: justify;
        }
        /*  sản phẩm của tháng */
        /* Hiệu ứng hào quang nhẹ cho sản phẩm của tháng */
        .naw-premium-card {
            transition: all 0.4s ease;
            border-radius: 15px;
        }

            .naw-premium-card:hover {
                transform: translateY(-10px); /* Bay lên một chút */
                filter: drop-shadow(0 10px 20px rgba(255, 193, 7, 0.3)); /* Phát sáng vàng */
            }

            /* Bo góc lại cho đồng bộ với giao diện hiện tại */
            .naw-premium-card .fruite-item {
                border: 2px solid #ffc107 !important; /* Viền vàng cho khác biệt */
            }
            /* 1. Hạ chiều cao ảnh xuống để thẻ không bị dài thòng lòng */
            .naw-premium-card .fruite-img img {
                height: 130px !important; /* Giảm từ 180px xuống 130px */
                object-fit: contain;
                padding: 5px;
            }
            /* 1. ÉP TÊN SẢN PHẨM CHỈ HIỆN 1 DÒNG + BA CHẤM */
            .naw-premium-card h4,
            .naw-premium-card .fruite-item h4,
            .naw-premium-card a.h5 {
                display: block !important;
                white-space: nowrap !important; /* Không cho xuống dòng */
                overflow: hidden !important; /* Ẩn phần dư thừa */
                text-overflow: ellipsis !important; /* Hiện dấu ... */
                width: 100%;
                font-size: 0.9rem !important; /* Chỉnh font nhỏ lại cho vừa khung 5 cột */
                margin-bottom: 8px;
            }
            /* 3. ĐẢM BẢO CÁC CARD CAO BẰNG NHAU */
            .naw-premium-card .fruite-item {
                height: 100% !important;
                display: flex;
                flex-direction: column;
                justify-content: space-between;
                padding: 10px !important;
            }
    </style>
}

@{
    var bgImage = ViewBag.TopBackground as NAWatchMVC.Data.HomePageMedia;
    var slides = ViewBag.TopSlides as List<NAWatchMVC.Data.HomePageMedia>;
}
<div style="padding-top: 156px;">
    <section class="container-fluid naw-hero-section mb-5"
             style="background: url('/images/homepage/@bgImage?.ImageUrl') no-repeat center center; background-size: cover;">

        <div class="naw-hero-overlay"></div>

        <div class="container naw-hero-content">
            <div class="row align-items-center g-5">

                <div class="col-md-12 col-lg-5">
                    <div class="ps-lg-3">
                        <h4 class="text-primary fw-bold text-uppercase mb-3" style="letter-spacing: 3px;">NAWatch Store</h4>
                        <h1 class="naw-slogan-title mb-4">Hãy trân trọng thời gian và lời hứa.</h1>
                        @* Tui đề xuất dùng fw-bold để chữ nổi bật hẳn lên trên nền xanh nhạt *@
                        <p class="text-muted fs-5 mb-5 fw-bold naw-sub-slogan">
                            Khám phá bộ sưu tập đồng hồ chính hãng,mọi lúc mọi nơi cùng NAWATCHMVC nơi mỗi giây phút đều trở nên vô giá.
                        </p>
                        <form asp-controller="HangHoa" asp-action="Search" method="get" class="input-group mb-3 shadow-sm" style="max-width: 500px;">
                            <input type="text" name="query" class="form-control naw-search-box py-3" placeholder="Tìm mẫu đồng hồ...">
                            <button class="btn btn-primary naw-btn-search text-white" type="submit">TÌM KIẾM</button>
                        </form>
                    </div>
                </div>

                <div class="col-md-12 col-lg-7">
                    <div class="naw-slider-frame">
                        @if (slides != null && slides.Any())
                        {
                            <div id="nawTopCarousel" class="carousel slide" data-bs-ride="carousel">
                                <div class="carousel-inner shadow-lg">
                                    @for (int i = 0; i < slides.Count; i++)
                                    {
                                        <div class="carousel-item @(i == 0 ? "active" : "")">
                                            <a href="@slides[i].NavigationLink" class="d-block w-100">
                                                <img src="~/images/homepage/@slides[i].ImageUrl"
                                                     class="naw-carousel-img"
                                                     alt="@slides[i].Title">
                                            </a>
                                        </div>
                                    }
                                </div>

                                <button class="carousel-control-prev" type="button" data-bs-target="#nawTopCarousel" data-bs-slide="prev">
                                    <span class="carousel-control-prev-icon" aria-hidden="true" style="width: 20px;"></span>
                                </button>
                                <button class="carousel-control-next" type="button" data-bs-target="#nawTopCarousel" data-bs-slide="next">
                                    <span class="carousel-control-next-icon" aria-hidden="true" style="width: 20px;"></span>
                                </button>
                            </div>
                        }
                    </div>
                </div>

            </div>
        </div>
    </section>
</div>

@* Mã voucher *@
<div class="container mt-5">
    <h4 class="section-title">🎁 Mã tặng Voucher cho bạn</h4>
    <div class="voucher-container">
        @foreach (var v in Model.Vouchers)
        {
            <div class="voucher-card">
                <div class="voucher-left"><i class="bi bi-gift-fill"></i></div>
                <div class="voucher-right">
                    <div class="voucher-title">GIẢM @(v.LoaiGiamGia == 1 ? v.GiaTriGiam + "%" : v.GiaTriGiam.ToString("N0") + "đ")</div>
                    <div class="voucher-desc">Đơn từ @v.GiaTriDonHangToiThieu.ToString("N0")đ. HSD: @v.NgayKetThuc.ToString("dd/MM")</div>
                    <div class="voucher-footer">
                        <span class="voucher-code">@v.MaVoucher</span>
                        <button class="btn-save-v" onclick="copyToClipboard('@v.MaVoucher')">Lưu</button>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@* sản phẩm của tháng *@
<div class="container mt-5">
    <h4 class="section-title text-uppercase fw-bold mb-4">🏆 Siêu phẩm của tháng</h4>

    @* Thêm class row-cols-lg-5 để chia 5 sản phẩm/hàng trên máy tính *@
    <div class="row g-3 row-cols-2 row-cols-md-3 row-cols-lg-5">
        @foreach (var sp in Model.MonthlyProducts)
        {
            <div class="col mb-4">
                <div class="naw-premium-card position-relative h-100">
                    @await Html.PartialAsync("_ProductItemHome", sp)

                    @if (sp.IsHot)
                    {
                        <span class="position-absolute top-0 start-0 translate-middle badge rounded-pill bg-danger shadow"
                              style="z-index: 10; margin-top: 25px; margin-left: 45px; font-size: 0.6rem;">
                            TOP BÁN CHẠY 🔥
                        </span>
                    }
                </div>
            </div>
        }
    </div>
</div>

@* sản phẩm xem gần đây Gọi giao diện Home đặc biệt Triệu hồi 6 sản phẩm đã xem gần nhất *@
@await Component.InvokeAsync("RecentlyViewed", new { limit = 6, isHome = true })

@* Nhớ gõ đúng tên file RecommendationHome (không cần đuôi .cshtml) *@
@await Component.InvokeAsync("Recommendation", new { viewName = true })

@*  Sản Phẩm của chúng tôiii *@
@* Ní hãy lặp lại cấu trúc này 4 lần cho: Nam, Nữ, Trẻ Em, Thể Thao *@
@* Ví dụ cho KHỐI ĐỒNG HỒ NAM *@
<section class="container mt-5">
    <h4 class="section-title text-uppercase fw-bold mb-4">
        ⌚ Sản phẩm của chúng tôi
    </h4>
    <div class="naw-category-block shadow-lg">

        <div class="d-flex justify-content-between align-items-center mb-3 text-white">
            <h2 class="naw-cate-title">Đồng Hồ Nam</h2>
            <a href="/HangHoa?Loai=1" class=" text-white text-decoration-none small">Xem tất cả Đồng hồ Nam <i class="fas fa-chevron-right ms-1"></i></a>
        </div>

        <div class="row g-3">
            <div class="col-lg-2 d-none d-lg-block">
                <div class="naw-video-banner shadow">
                    @if (!string.IsNullOrEmpty(Model.VideoIdNam))
                    {
                        <iframe width="100%" height="100%"
                        @* Ghép link Embed + ID + Playlist (để Loop tự động chạy) *@
                                src="https://www.youtube.com/embed/@Model.VideoIdNam?autoplay=1&mute=1&loop=1&playlist=@Model.VideoIdNam"
                                title="Đồng hồ Nam Review" frameborder="0"
                                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                                allowfullscreen style="object-fit: cover;">
                        </iframe>
                    }
                    else
                    {
                        <img src="~/images/banners/banner-nam-default.jpg" class="img-fluid w-100 h-100" style="object-fit: cover;" />
                    }
                </div>
            </div>

            <div class="col-lg-10 col-md-12">
                <div class="naw-product-box">
                    <div class="owl-carousel naw-brand-carousel">
                        @* Giả sử ní truyền List<HangHoaVM> theo từng loại vào Model *@
                        @foreach (var sp in Model.NamProducts.Take(10))
                        {
                            <div class="item">
                                @* Dùng lại cái "Nhẫn thuật" partial xịn xò của ní nè *@
                                @await Html.PartialAsync("_ProductItemHome", sp)
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@* tiếp theo là thẻ ncc *@
@foreach (var brand in Model.BrandSections)
{
    <section class="container mt-5">
        @* Khung màu đen sang trọng *@
        <div class="naw-brand-block shadow-lg" style="background-color: #000; border-radius: 15px; padding: 20px;">

            <div class="d-flex justify-content-between align-items-center mb-3 text-white">
                <h2 class="naw-cate-title" style="color: #fff;">@brand.BrandName</h2>
                <a href="/HangHoa?Ncc=@brand.BrandName" class="text-white text-decoration-none small">
                    Xem tất cả @brand.BrandName <i class="fas fa-chevron-right ms-1"></i>
                </a>
            </div>

            <div class="row g-3">
                <div class="col-lg-2 d-none d-lg-block">
                    <div class="naw-video-banner">
                        <img src="~/anhncc/@brand.BrandLogo" class="img-fluid rounded w-100 h-100"
                             style="object-fit: cover;" onerror="this.src='/img/brand-default.jpg'">
                    </div>
                </div>

                <div class="col-lg-10 col-md-12">
                    <div class="naw-product-box" style="background: #fff; border-radius: 10px; padding: 15px;">
                        <div class="owl-carousel naw-brand-carousel">
                            @foreach (var sp in brand.Products)
                            {
                                <div class="item">
                                    @* Dùng lại cái "Nhẫn thuật" partial xịn xò của ní nè *@
                                    @await Html.PartialAsync("_ProductItemHome", sp)
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
}

@* Tiếu sử cửa hàng *@
<section class="container mt-5 mb-5">
    <div class="row align-items-center g-5">

        <div class="col-lg-5">
            <h4 class="section-title text-uppercase fw-bold mb-4">✨ Câu chuyện NAWatch</h4>
            <h2 class="display-6 fw-bold mb-3" style="color: #1a2a3a;">Hơn cả một cỗ máy thời gian</h2>
            <p class="text-muted lh-lg">
                Được thành lập từ niềm đam mê với những bánh răng và lò xo, <strong>NAWatch</strong> không chỉ cung cấp những chiếc đồng hồ chính hãng mà còn là nơi lưu giữ những khoảnh khắc vô giá của bạn.
            </p>
            <p class="text-muted lh-lg">
                Chúng tôi tin rằng, mỗi chiếc đồng hồ trên cổ tay là một lời khẳng định về phong cách và giá trị của bản thân. Từ những dòng Casio bền bỉ đến Citizen tinh tế, mỗi sản phẩm tại đây đều được kiểm duyệt khắt khe trước khi đến tay ní.
            </p>
            <div class="mt-4">
                <a href="/Home/About" class="btn btn-outline-dark px-4 py-2 rounded-pill">Tìm hiểu thêm về chúng tôi</a>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="naw-intro-video-box shadow-lg rounded-4 overflow-hidden">
                @if (!string.IsNullOrEmpty(Model.VideoIdIntro))
                {
                    <div class="ratio ratio-16x9">
                        <iframe width="100%" height="100%"
                        @* Giải thích tham số:
                            - autoplay=1: Tự động phát.
                            - mute=1: Tắt tiếng (BẮT BUỘC để autoplay hoạt động).
                            - loop=1 & playlist=ID: Để video tự lặp lại vô hạn. *@
                                src="https://www.youtube.com/embed/@Model.VideoIdIntro?autoplay=1&mute=1&loop=1&playlist=@Model.VideoIdIntro&start=60"
                                title="NAWatch Intro Video"
                                frameborder="0"
                                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                                allowfullscreen>
                        </iframe>
                    </div>
                }
                else
                {
                    <div class="p-5 text-center bg-light">
                        <i class="bi bi-play-circle display-1 text-muted"></i>
                        <p>Video giới thiệu đang được cập nhật...</p>
                    </div>
                }
            </div>
            <p class="text-center mt-3 text-muted small italic">🎬 Video: Cận cảnh sự tinh tế trên từng tuyệt phẩm</p>
        </div>

    </div>
</section>

@if (Model.Videos.Any())
{
    <div class="container mt-5">
        <h4 class="section-title">📺 Video Review Đồng Hồ</h4>
        <div class="row">
            @foreach (var vid in Model.Videos)
            {
                <div class="col-md-6 mb-4">
                    <div class="ratio ratio-16x9 shadow rounded-3 overflow-hidden">
                        <iframe src="@vid.YoutubeUrl" title="@vid.Title" allowfullscreen></iframe>
                    </div>
                    <p class="text-center mt-2 fw-bold">@vid.Title</p>
                </div>
            }
        </div>
    </div>
}



@foreach (var bst in Model.Collections)
{
    <div class="container mt-5">
        <div class="d-flex justify-content-between align-items-center">
            <h4 class="section-title">✨ @bst.Name</h4>
            <a href="/HangHoa?BoSuuTap=@bst.Name" class="text-decoration-none text-primary">Xem tất cả ></a>
        </div>
        <div class="row g-2">
            @foreach (var sp in bst.Products)
            {
                <div class="col-6 col-md-4 col-lg-2">
                    @await Html.PartialAsync("_ProductItemHome", sp)
                </div>
            }
        </div>
    </div>
}
<p class="text-danger">DEBUG: ID Video là [@Model.VideoIdIntro]</p>
<div class="container mt-5 mb-5">
    <h4 class="section-title">📰 Tin tức mới nhất</h4>
    <div class="row">
        @foreach (var news in Model.News)
        {
            <div class="col-md-4 mb-3">
                <div class="card h-100 border-0 shadow-sm">
                    <img src="~/images/news/@news.ImageUrl" class="card-img-top" style="height: 200px; object-fit: cover;">
                    <div class="card-body">
                        <h6 class="card-title fw-bold">@news.Title</h6>
                        <p class="card-text small text-muted">@news.Summary</p>
                        <a href="/News/Detail/@news.Id" class="btn btn-sm btn-outline-dark">Đọc thêm</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<div style="padding: 50px; background: #f8f9fa;">
    <h5 class="text-danger">DEBUG MODE:</h5>
    <p>Slides: @Model.Slides.Count | Banners: @Model.Banners.Count | Videos: @Model.Videos.Count</p>
</div>

@section Scripts {
    <script>
        function copyToClipboard(text) {
            navigator.clipboard.writeText(text);
            Swal.fire({
                title: 'Đã lưu mã!',
                text: 'Mã ' + text + ' đã sẵn sàng để dán lúc thanh toán.',
                icon: 'success',
                timer: 2000,
                showConfirmButton: false
            });
        }
        $(document).ready(function () {
            $(".naw-brand-carousel").owlCarousel({
                loop: true,
                margin: 15,
                nav: true,
                dots: false,
                autoplay: true,
                autoplayTimeout: 3000,
                navText: ["<i class='bi bi-chevron-left'></i>", "<i class='bi bi-chevron-right'></i>"], // Dùng icon Bootstrap
                responsive: {
                    0: { items: 2 },   /* Điện thoại hiện 2 */
                    768: { items: 3 }, /* Tablet hiện 3 */
                    1200: { items: 5 } /* Laptop hiện 5 cái chuẩn bài */
                }
            });
        });
    </script>
}
