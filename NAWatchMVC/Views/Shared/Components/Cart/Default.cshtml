@model int
<a asp-controller="Cart" asp-action="Index" class="position-relative me-4 my-auto text-decoration-none">
    @* Cái giỏ giữ nguyên màu xanh của ní *@
    <i class="fa fa-shopping-bag fa-2x" style="color: #1E88E5;"></i>

    @* Cái số đổi thành Vòng Vàng - Chữ Đen *@
    <span id="cart-badge-count"
          class="position-absolute rounded-circle d-flex align-items-center justify-content-center text-dark px-1 fw-bold"
          style="top: -5px; left: 15px; height: 20px; min-width: 20px; background-color: #FFD700; font-size: 12px; border: 1px solid #fff;">
        @Model
    </span>
</a>    