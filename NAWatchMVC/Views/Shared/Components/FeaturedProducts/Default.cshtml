@model IEnumerable<NAWatchMVC.ViewModels.HangHoaVM>

<div class="featured-products-sidebar mt-4">
    <h6 class="fw-bold mb-3 border-bottom pb-2 text-uppercase text-primary">
        <i class="fas fa-fire text-danger me-2"></i>Sản phẩm nổi bật
    </h6>
    @foreach (var item in Model)
    {
        <a asp-controller="HangHoa" asp-action="Detail" asp-route-id="@item.MaHh" 
           class="d-flex align-items-center mb-3 text-decoration-none text-dark product-item-side border-bottom pb-2">
            <img src="~/anhall/@item.Hinh" style="width: 60px; height: 60px; object-fit: cover;" 
                 class="rounded border me-3" alt="@item.TenHh" onerror="this.src='/img/no-image.jpg'">
            <div>
                <div class="small fw-bold text-truncate" style="max-width: 150px;">@item.TenHh</div>
                <div class="text-danger fw-bold small">@item.GiaBan.ToString("#,##0")₫</div>
                @if(item.GiamGia > 0) {
                    <del class="text-muted" style="font-size: 0.75rem;">@item.DonGia.ToString("#,##0")₫</del>
                }
            </div>
        </a>
    }
</div>