@model IEnumerable<NAWatchMVC.ViewModels.HangHoaVM>

@if (Model != null && Model.Any())
{
    <div class="container mt-5">
        <div class="d-flex justify-content-between align-items-end mb-3">
            <h4 class="naw-section-title mb-0">Sản phẩm đã xem</h4>
            <a href="javascript:void(0)" class="text-muted small text-decoration-none">Xóa lịch sử</a>
        </div>

        @* Khung cuộn ngang chuẩn TGDĐ *@
        <div class="naw-recent-scroll-wrapper">
            @foreach (var item in Model)
            {
                <a asp-controller="HangHoa" asp-action="Detail" asp-route-id="@item.MaHh" class="naw-home-recent-card">
                    @* Nút Xóa nhỏ ở góc *@
                    <div class="naw-recent-x">×</div>

                    <div class="naw-recent-flex">
                        <div class="naw-recent-img-box">
                            <img src="~/anhall/@item.Hinh" alt="@item.TenHh" onerror="this.src='/img/no-image.jpg'">
                        </div>
                        <div class="naw-recent-body">
                            <div class="naw-recent-name">@item.TenHh</div>
                            <div class="naw-recent-price">@item.DonGia.ToString("N0")đ</div>
                        </div>
                    </div>
                </a>
            }
        </div>
    </div>
}
