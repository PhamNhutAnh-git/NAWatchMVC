<!DOCTYPE html>

<html>
<head>
    <meta charset="utf-8">
    <title>NAWATCHMVC - Template</title>
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <meta content="" name="keywords">
    <meta content="" name="description">

    <!-- Google Web Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;600&family=Raleway:wght@600;800&display=swap" rel="stylesheet">

    <!-- Icon Font Stylesheet -->
    <link rel="stylesheet" href="https://use.fontawesome.com/releases/v5.15.4/css/all.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.4.1/font/bootstrap-icons.css" rel="stylesheet">

    <!-- Libraries Stylesheet -->
    <link href="~/lib/lightbox/css/lightbox.min.css" rel="stylesheet">
    <link href="~/lib/owlcarousel/assets/owl.carousel.min.css" rel="stylesheet">


    <!-- Customized Bootstrap Stylesheet -->
    <link href="~/css/bootstrap.min.css" rel="stylesheet">

    <!-- Template Stylesheet -->
    <link href="~/css/style.css" rel="stylesheet">
    @await RenderSectionAsync("Styles", required: false)

    <style>
        /* --- CSS DÙNG CHUNG CHO TOÀN BỘ WEB --- */
        .page-header {
            background: linear-gradient(rgba(30, 136, 229, 0.7), rgba(30, 136, 229, 0.7)), url('https://images.unsplash.com/photo-1523275335684-37898b6baf30?q=80&w=1999') !important;
            background-position: center center !important;
            background-repeat: no-repeat !important;
            background-size: cover !important;
            margin-top: 155px !important;
        }

        /* Màu ĐEN cho Trang chủ / Cửa hàng */
        .page-header .breadcrumb-item a {
            color: #000000 !important;
            font-weight: 500;
            text-decoration: none;
        }

        /* Màu TRẮNG cho trang hiện tại */
        .page-header .breadcrumb-item.active {
            color: #ffffff !important;
            font-weight: bold;
        }

        /* Màu xanh cho Menu "Chi Tiết" */
        .nav-link.active-detail {
            color: #1E88E5 !important;
            font-weight: bold !important;
        }
        
        @* --- CSS CHO THANH SO SÁNH (Ní dán vào file site.css nhé) --- *@
        .sticky-compare-bar {
            position: fixed;
            bottom: 0;
            left: 0;
            width: 100%;
            background-color: #f8f9fa;
            border-top: 2px solid #007bff;
            z-index: 9999;
            transition: all 0.3s ease-in-out;
        }

        .compare-item-slot {
            width: 80px;
            height: 80px;
            border: 2px dashed #ddd;
            margin-right: 15px;
            background: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
        }

        .compare-item-slot img {
          max-height: 70px;
          width: auto;
        }    

        .btn-remove-compare {
            position: absolute;
            top: -10px;
            right: -10px;
            background: red;
            color: white;
            border-radius: 50%;
            width: 20px;
            height: 20px;
            line-height: 18px;
            text-align: center;
            cursor: pointer;
            font-size: 12px;
        }

        .btn-so-sanh-ngay {
            width: 150px;
        }
        /* không theay */
        /* Nút mở rộng ở góc trái */
        .compare-expand-btn {
            position: fixed;
            bottom: 20px;
            left: 20px;
            background-color: #1E88E5; /* Màu xanh của NAWatch */
            color: white;
            padding: 10px 20px;
            border-radius: 50px;
            border: 2px solid white;
            cursor: pointer;
            z-index: 10000;
            font-weight: bold;
            box-shadow: 0 4px 15px rgba(0,0,0,0.2);
        }

        /* Nút thu gọn nằm trên đầu thanh bar */
        .collapse-trigger {
            position: absolute;
            top: -30px;
            right: 30px;
            background: #f8f9fa;
            padding: 5px 15px;
            border: 3px solid #007bff;
            border-bottom: none;
            border-radius: 10px 10px 0 0;
            cursor: pointer;
            font-size: 0.75rem;
            font-weight: bold;
            color: #007bff;
        }
    </style>
</head>

<body>
   @*  SPINNER LOAD – hiệu ứng chờ trang tải *@
    <div id="spinner" class="show w-100 vh-100 bg-white position-fixed translate-middle top-50 start-50 d-flex align-items-center justify-content-center">
        <div class="spinner-grow text-primary" role="status"></div>
    </div>

    <div>

        <!-- Navbar start thanh thông tin trên cùng layout -->
        <div class="container-fluid fixed-top ">
            <div class="container topbar d-none d-lg-block" style="background-color: #1E88E5 !important;">
                <div class="d-flex justify-content-between">
                    <div class="top-info ps-2">
                        <small class="me-3"><i class="fas fa-map-marker-alt me-2 text-white"></i> <a href="#" class="text-white">Long Xuyên, An Giang</a></small>
                        <small class="me-3"><i class="fas fa-envelope me-2 text-white"></i><a href="#" class="text-white">nawatch@example.com</a></small>
                    </div>
                    <div class="top-link pe-2">
                        <a href="#" class="text-white"><small class="text-white mx-2">Bảo mật</small>/</a>
                        <a href="#" class="text-white"><small class="text-white mx-2">Điều khoản</small>/</a>
                        <a href="#" class="text-white"><small class="text-white ms-2">Chính sách đổi trả</small></a>
                    </div>
                </div>
            </div>

            <div class="container px-0">
                <nav class="navbar navbar-light bg-white navbar-expand-xl">
                    <a asp-controller="Home" asp-action="Index" class="navbar-brand">
                        <h1 class="display-6" style="color: #1E88E5;">NAWATCHMVC</h1>
                    </a>
                    <button class="navbar-toggler py-2 px-3" type="button" data-bs-toggle="collapse" data-bs-target="#navbarCollapse">
                        <span class="fa fa-bars" style="color: #1E88E5;"></span>
                    </button>
                    <div class="collapse navbar-collapse bg-white" id="navbarCollapse">
                        <div class="navbar-nav mx-auto">

                            @* Kiểm tra nếu đang ở Home thì thêm class active, ngược lại để trống *@
                            @{
                                // Lấy tên Controller và Action hiện tại từ hệ thống
                                var controller = ViewContext.RouteData.Values["controller"]?.ToString();
                                var action = ViewContext.RouteData.Values["action"]?.ToString();
                            }
                            @* Trang Chủ: Chỉ active khi ở Home/Index *@
                            <li class="nav-item">
                            <a asp-controller="Home" asp-action="Index"
                               class="nav-link @(controller == "Home" ? "active" : "")">Trang Chủ</a>
                            </li>
                            @* Sản Phẩm: CHỈ active khi ở HangHoa/Index (Trang danh sách) *@
                            <li class="nav-item">
                            <a asp-controller="HangHoa" asp-action="Index"
                               class="nav-link @(controller == "HangHoa" && action == "Index" ? "active" : "")">Sản Phẩm</a>
                            </li>
                            @* Chi Tiết: CHỈ active khi ở HangHoa/Detail (Trang xem món đồ) *@
                            <li class="nav-item">
                                <a class="nav-link @(action == "Detail" ? "active-detail" : "")"
                                   asp-controller="HangHoa" asp-action="Detail">Chi Tiết</a>
                            </li>

                            
                            @* ... Các mục khác làm tương tự nếu có Controller riêng ... *@
                            <a href="#" class="nav-item nav-link">Liên Hệ</a>
                            <div class="nav-item dropdown">
                                <a href="#" class="nav-link dropdown-toggle" data-bs-toggle="dropdown">Tiện ích</a>
                                <div class="dropdown-menu m-0 border-0 rounded-0 shadow-sm">
                                    <a href="#" class="dropdown-item">Giỏ hàng</a>
                                    <a href="#" class="dropdown-item">Thanh toán</a>
                                    <a href="#" class="dropdown-item">Đánh giá khách hàng</a>
                                    <a href="#" class="dropdown-item">Câu hỏi thường gặp</a>
                                </div>
                            </div>
                            <a href="#" class="nav-item nav-link">Liên Hệ</a>
                        </div>
                        @* tìm kim *@
                        <div class="d-flex m-3 me-0">
                            <button class="btn border rounded-circle bg-white me-4" style="border-color: #1E88E5 !important;" data-bs-toggle="modal" data-bs-target="#searchModal">
                                <i class="fas fa-search" style="color: #1E88E5;"></i>
                            </button>
                            @await Component.InvokeAsync("Cart")
                            @* nút user *@
                            @* --- ĐOẠN CODE CẦN THAY THẾ CHO NÚT USER --- *@
                            <div class="nav-item dropdown my-auto">
                                <a href="#" class="nav-link dropdown-toggle p-0" data-bs-toggle="dropdown">
                                    <i class="fas fa-user fa-2x" style="color: #1E88E5;"></i>
                                    @if (User.Identity.IsAuthenticated)
                                    {
                                        <span class="ms-2 d-none d-xl-inline-block text-dark fw-bold">Chào, @User.Identity.Name!</span>
                                    }
                                </a>
                                <div class="dropdown-menu m-0 border-0 rounded-0 shadow-sm" style="right: 0; left: auto;">
                                    @if (User.Identity.IsAuthenticated)
                                    {
                                        @* Nếu đã đăng nhập thì hiện thông tin cá nhân *@
                                        <a asp-controller="KhachHang" asp-action="Profile" class="dropdown-item">Hồ sơ cá nhân</a>
                                        <a asp-controller="KhachHang" asp-action="LichSuDonHang" class="dropdown-item">Lịch sử đơn hàng</a>

                                        @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
                                        {
                                            <div class="dropdown-divider"></div>
                                            <a href="/Admin/HomeAdmin" class="dropdown-item admin-link">Trang quản trị</a>
                                        }

                                        <div class="dropdown-divider"></div>
                                        <a asp-controller="KhachHang" asp-action="DangXuat" class="dropdown-item logout-link">Đăng xuất</a>
                                    }
                                    else
                                    {
                                        @* Nếu chưa đăng nhập thì hiện Login/Register *@
                                        <a asp-controller="KhachHang" asp-action="DangNhap" class="dropdown-item">Đăng nhập</a>
                                        <a asp-controller="KhachHang" asp-action="DangKy" class="dropdown-item">Đăng ký thành viên</a>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </nav>
            </div>
        </div>
        <!-- Navbar End -->
        
        <div style="min-height: 1000px;">
            @RenderBody()
        </div>
        @* 1. Chân trang - hiện ra bình thường *@
        @await Html.PartialAsync("_Footer")

        @* 2. Các thành phần Overlay - Chỉ hiện khi cần *@
        <partial name="_SearchModal" />
    </div>


    <!-- Back to Top -->
    <a href="#" class="btn btn-primary border-3 border-primary rounded-circle back-to-top"><i class="fa fa-arrow-up"></i></a>


    <!-- JavaScript Libraries -->
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.4/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/easing/easing.min.js"></script>
    <script src="~/lib/waypoints/waypoints.min.js"></script>
    <script src="~/lib/lightbox/js/lightbox.min.js"></script>
    <script src="~/lib/owlcarousel/owl.carousel.min.js"></script>

    <!-- Template Javascript -->

    <script src="~/js/main.js"></script>
    @await RenderSectionAsync("Scripts", required: false)\
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    @* Nút mở rộng so sánh *@
    <div id="compare-expand-btn" class="compare-expand-btn shadow" style="display: none;" onclick="toggleCompareBar(true)">
        <i class="fas fa-balance-scale"></i>
        <span class="ms-1">So sánh (<span id="compare-count-badge">0</span>)</span>
    </div>

    @* --- GIAO DIỆN THANH SO SÁNH CỐ ĐỊNH (STICKY COMPARE BAR) --- *@
    <div id="sticky-compare-bar" class="sticky-compare-bar shadow-lg" style="display: none;">
        @* Nút Thu gọn ở góc trên bên phải thanh bar *@
        <div class="collapse-trigger" onclick="toggleCompareBar(false)">
            Thu gọn <i class="fas fa-chevron-down ms-1"></i>
        </div>
        <form asp-controller="HangHoa" asp-action="SoSanh" method="get">
        <div class="container-fluid p-0">
        <div class="row align-items-center m-0">
            @* 1. Cột trái: Trống hoặc ní có thể chèn gì đó vào đây *@
            <div class="col-3 col-lg-2"></div>
            
            @* 2. Cột giữa: Chứa 3 món so sánh và CĂN GIỮA (Centered) *@
            <div class="col-6 col-lg-8 d-flex align-items-center justify-content-center gap-3 py-2" id="compare-list-items">
                @* 3 cái slot sản phẩm sẽ được JS append vào đây *@
            </div>
            
            @* 3. Cột phải: Chứa các nút hành động (vẫn nằm bên phải) *@ 
            <div class="col-3 col-lg-2 compare-actions text-center border-start ps-3 py-2">
                <input type="hidden" id="idsCompareHidden" name="productIds" />
                @* SỬA NÚT NÀY: Dùng onclick để nó chủ động nhảy trang *@
                <button type="button" class="btn btn-primary rounded-pill mb-1" 
                        onclick="var ids = $('#idsCompareHidden').val(); if(ids) { window.location.href='/HangHoa/Compare?ids=' + ids; } else { Swal.fire('xin chọn món trước!'); }">
                    So sánh ngay
                </button>
                <a href="javascript:void(0)" class="small text-danger d-block mt-2" onclick="clearAllCompare()">
                    Xóa tất cả sản phẩm
                </a>
            </div>
        </div>
        </form>
    </div>
    </div>

    <script>
        $(document).ready(function () {
            // 1. Cấu hình kiểu Toast (Swal) - Giữ nguyên của ní nhưng dọn lại cho đẹp
            const Toast = Swal.mixin({
                toast: true,
                position: 'top-end',
                showConfirmButton: false,
                timer: 3000,
                timerProgressBar: true,
                didOpen: (toast) => {
                    toast.addEventListener('mouseenter', Swal.stopTimer)
                    toast.addEventListener('mouseleave', Swal.resumeTimer)
                }
            });

            // 2. Hàm cập nhật số lượng icon giỏ hàng
            window.updateCartBadge = function (newCount) {
                // Cập nhật số lượng vào cái span có id là cart-badge-count
                $('#cart-badge-count').text(newCount);

                // Hiệu ứng "nhảy" cho sinh động
                $('#cart-badge-count').addClass('animate__animated animate__bounceIn');
                setTimeout(() => {
                    $('#cart-badge-count').removeClass('animate__animated animate__bounceIn');
                }, 1000);
            };

            // 3. XỬ LÝ CLICK "THÊM VÀO GIỎ" (AJAX)
            $(document).on('click', '.add-to-cart-js', function (e) {
                e.preventDefault();

                var id = $(this).data("id"); // Lấy ID từ thuộc tính data-id
                // CHỖ MỚI NÈ: Tìm xem trên trang có ô input nào tên là 'quantity' không
                // Nếu ở Detail, nó sẽ lấy giá trị khách chọn. Nếu ở List, nó sẽ lấy mặc định là 1.
                var quantity = $("input[name='quantity']").val() || 1;
                $.ajax({
                    url: "/Cart/Add/" + id,
                    type: "POST",
                    data: { quantity: quantity }, // Gửi kèm số lượng lên server
                    headers: { "X-Requested-With": "XMLHttpRequest" }, // Để Controller nhận biết isAjax
                    success: function (res) {
                        if (res.success) {
                            // Gọi hàm cập nhật icon túi xách
                            window.updateCartBadge(res.soLuong);

                            // Hiện thông báo thành công
                            Toast.fire({
                                icon: 'success',
                                title: 'Đã thêm chiếc ' + res.tenHH + ' vào giỏ!'
                            });
                        }
                        else if (res.error) {
                            // Nếu hết hàng hoặc lỗi logic từ Controller
                            Swal.fire({
                                icon: 'warning',
                                title: 'Thông báo',
                                text: res.message
                            });
                        }
                    },
                    error: function () {
                        Toast.fire({
                            icon: 'error',
                            title: 'Lỗi rồi ní ơi! Không kết nối được server.'
                        });
                    }
                });
            });
            // --- 3. LOGIC SO SÁNH SẢN PHẨM (MỚI) ---
            let compareList = JSON.parse(localStorage.getItem('compareList')) || [];
            // MỚI: Lấy trạng thái thu gọn từ bộ nhớ trình duyệt
            let isCollapsed = sessionStorage.getItem('compareCollapsed') === 'true';

            // MỚI: Hàm đóng/mở thanh bar
            window.toggleCompareBar = function(show) {
                isCollapsed = !show;
                sessionStorage.setItem('compareCollapsed', isCollapsed);
                renderStickyBar();
            };
            // Hàm Thêm vào so sánh (Cái mà ní bị báo lỗi thiếu nè)
            window.addToCompare = function(id, name, img) {
                if (compareList.some(x => x.id == id)) {
                    Toast.fire({ icon: 'info', title: 'Món này đã có trong danh sách so sánh!' });
                    return;
                }
                if (compareList.length >= 3) {
                    Swal.fire({ icon: 'warning', title: 'Giới hạn', text: 'Ní chọn tối đa 3 món thôi nha!' });
                    return;
                }

                compareList.push({ id, name, img });
                localStorage.setItem('compareList', JSON.stringify(compareList));
                renderStickyBar();
            };

            // Hàm Xóa 1 món khỏi so sánh
            window.removeFromCompare = function(id) {
                compareList = compareList.filter(x => x.id != id);
                localStorage.setItem('compareList', JSON.stringify(compareList));
                renderStickyBar();
            };

            // Hàm Xóa tất cả
            window.clearAllCompare = function() {
                compareList = [];
                localStorage.removeItem('compareList');
                renderStickyBar();
            };

            // MỚI: Cập nhật hàm vẽ để xử lý Ẩn/Hiện
            function renderStickyBar() {
                const bar = $("#sticky-compare-bar");
                const expandBtn = $("#compare-expand-btn"); // Nút nhỏ ở góc trái
                const list = $("#compare-list-items");
                const inputHidden = $("#idsCompareHidden");

                if (compareList.length > 0) {
                    // Cập nhật số lượng vào nút nhỏ
                    $("#compare-count-badge").text(compareList.length);

                    if (isCollapsed) {
                        bar.hide();
                        expandBtn.fadeIn(); // Hiện nút nhỏ góc trái
                    } else {
                        expandBtn.hide();
                        bar.slideDown(); // Hiện thanh bar bự
                    
                        list.empty();
                        for (let i = 0; i < 3; i++) {
                            if (compareList[i]) {
                                const item = compareList[i];
                                list.append(`
                                    <div class="compare-item-slot border-solid d-flex flex-column align-items-center p-1">
                                        <span class="btn-remove-compare" onclick="removeFromCompare('${item.id}')">x</span>
        
                                        <img src="/anhall/${item.img}" style="max-height: 50px; width: auto; object-fit: contain;" />
        
                                        <div class="small text-truncate mt-1 w-100 text-center text-dark" 
                                             style="font-size: 10px; line-height: 1.2;" title="${item.name}">
                                            ${item.name}
                                        </div>
                                    </div>
                                `);
                                // list.append(`
                                //     <div class="compare-item-slot border-solid">
                                //         <span class="btn-remove-compare" onclick="removeFromCompare('${compareList[i].id}')">x</span>
                                //         <img src="/anhall/${compareList[i].img}" />
                                //         <div class="small text-truncate" style="width:80px; font-size:0.6rem">${compareList[i].name}</div>
                                //     </div>
                                // `);
                            } else {
                                list.append(`<div class="compare-item-slot text-muted small" style="font-size:0.6rem">Trống</div>`);
                            }
                        }
                        inputHidden.val(compareList.map(x => x.id).join(','));
                    }
                } else {
                    bar.hide();
                    expandBtn.hide();
                }
            }
            // Hàm này để thay đổi trạng thái khi bấm nút
            window.toggleCompareBar = function(show) {
                isCollapsed = !show;
                sessionStorage.setItem('compareCollapsed', isCollapsed);
                renderStickyBar();
            };

            // Tự động vẽ lại khi load trang
            renderStickyBar();

            // --- 4. THÔNG BÁO TEMP DATA ---
            @if (TempData["Success"] != null) { <text>Toast.fire({ icon: 'success', title: '@TempData["Success"]' });</text> }
            @if (TempData["Error"] != null) { <text>Toast.fire({ icon: 'error', title: '@TempData["Error"]' });</text> }
            
            //tìm kiếm chung
            // Hàm thực hiện chuyển trang tìm kiếm
            function performSearch() {
                var query = $('#searchInput').val(); // Lấy chữ ní vừa nhập
                console.log("Ní đang tìm:", query); // Dòng này để kiểm tra ở Console

                if (query && query.trim() !== "") {
                    // Chuyển hướng sang controller HangHoa, action Index
                    window.location.href = '/HangHoa?query=' + encodeURIComponent(query.trim());
                } else {
                    alert("Ní nhập từ khóa cái đã!");
                }
            }

            // 1. Bắt sự kiện Click nút
            $(document).on('click', '#search-button-modal', function () {
                performSearch();
            });

            // 2. Bắt sự kiện nhấn phím Enter
            $(document).on('keypress', '#searchInput', function (e) {
                if (e.which == 13) {
                    performSearch();
                }
            });
            // 3. nâng cấp giao diện tìm kiếm
            function fillSearch(text) {
                $('#searchInput').val(text);
                // Có thể tự động tìm luôn sau khi điền
                $('#search-button-modal').click();
            }
        });
    </script>
    
</body>

</html>
