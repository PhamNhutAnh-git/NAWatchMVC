@model NAWatchMVC.Data.NewsArticle

@{
    ViewData["Title"] = Model.Title;
    Layout = "_LayoutCustomer";
}
}

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb bg-transparent p-0">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none text-muted">Trang chủ</a></li>
            <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none text-muted">Tin tức</a></li>
            <li class="breadcrumb-item active text-dark fw-bold" aria-current="page">Chi tiết bài viết</li>
        </ol>
    </nav>
</div>

<section class="news-detail-section py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-9">
                <article class="news-post shadow-sm rounded-4 bg-white p-4 p-md-5">

                    <header class="mb-5">
                        <h1 class="display-4 fw-bold text-dark lh-sm mb-3">@Model.Title</h1>
                        <div class="d-flex align-items-center text-muted small">
                            <div class="me-4">
                                <i class="far fa-calendar-alt me-1 text-primary"></i>
                                @Model.PublishedDate.ToString("dd/MM/yyyy")
                            </div>
                            <div class="me-4">
                                <i class="far fa-user me-1 text-primary"></i>
                                Tác giả: Phạm Nhựt Anh
                            </div>
                            <div>
                                <i class="far fa-eye me-1 text-primary"></i>
                                1.2k lượt xem
                            </div>
                        </div>
                    </header>

                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <div class="news-banner mb-5 overflow-hidden rounded-4 shadow">
                            <img src="~/Hinh/TinTuc/@Model.ImageUrl" class="img-fluid w-100" style="max-height: 500px; object-fit: cover;" alt="@Model.Title">
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.Summary))
                    {
                        <div class="news-summary border-start border-primary border-4 ps-4 mb-5">
                            <p class="lead fw-bold text-secondary italic">@Model.Summary</p>
                        </div>
                    }

                    <div class="news-article-body text-dark lh-lg" style="font-size: 1.15rem; text-align: justify;">
                        @* CỰC KỲ QUAN TRỌNG: Dùng Html.Raw để hiển thị đúng định dạng TinyMCE *@
                        @Html.Raw(Model.Content)
                    </div>

                    <footer class="mt-5 pt-4 border-top">
                        <div class="d-flex flex-wrap justify-content-between align-items-center">
                            <div class="share-buttons mb-3 mb-md-0">
                                <span class="me-3 fw-bold">Chia sẻ:</span>
                                <a href="#" class="btn btn-outline-primary btn-sm rounded-circle me-2"><i class="fab fa-facebook-f"></i></a>
                                <a href="#" class="btn btn-outline-info btn-sm rounded-circle me-2"><i class="fab fa-twitter"></i></a>
                                <a href="#" class="btn btn-outline-danger btn-sm rounded-circle"><i class="far fa-envelope"></i></a>
                            </div>
                            <a asp-action="Index" class="btn btn-dark px-4 rounded-pill">
                                <i class="fas fa-chevron-left me-2"></i>Xem tin khác
                            </a>
                        </div>
                    </footer>
                </article>

                <div class="mt-5 p-4 bg-light rounded-4 border">
                    <h4 class="fw-bold mb-4">Bình luận bài viết</h4>
                    <p class="text-muted italic small">Chức năng bình luận đang được phát triển...</p>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .news-article-body img {
        max-width: 100%;
        height: auto !important;
        border-radius: 12px;
        margin: 2rem 0;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
    }

    .news-article-body p {
        margin-bottom: 1.8rem;
    }

    .news-article-body h2, .news-article-body h3 {
        margin-top: 2.5rem;
        margin-bottom: 1.2rem;
        font-weight: 700;
        color: #111;
    }

    .news-post {
        transition: transform 0.3s ease;
    }

    .news-summary p {
        font-style: italic;
        color: #555;
    }
</style>