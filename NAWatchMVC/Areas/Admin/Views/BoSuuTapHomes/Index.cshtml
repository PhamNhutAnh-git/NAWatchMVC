@model IEnumerable<NAWatchMVC.Data.BoSuuTapHome>

@{
    ViewData["Title"] = "Quản lý Bộ Sưu Tập Home";
}

<div class="container-fluid">
    @* --- HEADER CHUẨN --- *@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark">✨ Quản lý Bộ Sưu Tập Home</h2>
            <p class="text-muted">Điều khiển các nhóm hàng nổi bật hiển thị trên trang chủ</p>
        </div>
        <a asp-action="Create" class="btn btn-primary shadow-sm">
            <i class="bi bi-plus-circle-fill me-2"></i>Thêm bộ sưu tập mới
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-3">
            <div class="table-responsive">
                @* Thêm id và class datatable để nó tự chạy phân trang/tìm kiếm *@
                <table class="table table-hover align-middle mb-0 datatable" id="dataTableBST">
                    <thead class="bg-light">
                        <tr>
                            <th class="text-center" style="width: 80px;">Thứ tự</th>
                            <th style="width: 150px;">Ảnh nền</th>
                            <th>Tên bộ sưu tập</th>
                            <th style="width: 150px;">Trạng thái</th>
                            <th class="text-center" style="width: 150px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-center">
                                    <span class="fw-bold text-primary">#@item.Order</span>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.BackgroundImage))
                                    {
                                        <img src="~/images/collections/@item.BackgroundImage"
                                             class="rounded shadow-sm img-preview"
                                             alt="@item.CollectionName">
                                    }
                                    else
                                    {
                                        <div class="bg-light rounded d-flex align-items-center justify-content-center img-preview">
                                            <i class="bi bi-image text-muted"></i>
                                        </div>
                                    }
                                </td>
                                <td>
                                    <div class="fw-bold text-dark">@item.CollectionName</div>
                                    <small class="text-muted">Hiển thị các sản phẩm thuộc nhóm này</small>
                                </td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-soft-success text-success">
                                            <i class="bi bi-check-circle-fill me-1"></i> Đang hiển thị
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-soft-secondary text-secondary">
                                            <i class="bi bi-eye-slash-fill me-1"></i> Đang ẩn
                                        </span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-1">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary action-btn" title="Sửa">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info action-btn" title="Chi tiết">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger action-btn" title="Xóa">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        /* GIỮ NGUYÊN CSS TỪ TRANG MEDIA ĐỂ ĐỒNG BỘ */
        .img-preview {
            width: 120px;
            height: 65px;
            object-fit: cover;
            border: 1px solid #eee;
        }

        /* Badge Soft Style */
        .bg-soft-success { background-color: #e8f5e9; }
        .bg-soft-secondary { background-color: #f5f5f5; }

        .badge {
            font-weight: 500;
            padding: 0.5em 0.8em;
            border-radius: 6px;
        }

        /* Nút thao tác */
        .action-btn {
            width: 32px;
            height: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 0;
            border-radius: 6px;
        }

        .table th {
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: #6c757d;
        }

        .table td {
            white-space: nowrap;
        }
    </style>
}

@section Scripts {
    <script>
        $(document).ready(function () {
            // Khởi tạo bảng với DataTable (nếu đã fix lỗi Reinitialise ở Layout)
            if ($.fn.DataTable.isDataTable('#dataTableBST')) {
                $('#dataTableBST').DataTable().destroy();
            }

            $('#dataTableBST').DataTable({
                "ordering": true,
                "order": [[0, "asc"]], // Sắp xếp theo thứ tự Order tăng dần
                "columnDefs": [
                    { "orderable": false, "targets": [1, 4] } // Khóa cột ảnh và thao tác
                ]
            });
        });
    </script>
}