@model NAWatchMVC.Data.BoSuuTapHome

@{
    ViewData["Title"] = "Chỉnh sửa Bộ Sưu Tập";
}

<div class="container-fluid">
    @* --- HEADER --- *@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark">✍️ Chỉnh sửa Bộ Sưu Tập</h2>
            <p class="text-muted">Cập nhật thông tin và hình ảnh hiển thị cho trang chủ</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary shadow-sm">
            <i class="bi bi-arrow-left me-1"></i> Quay lại danh sách
        </a>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    @* LƯU Ý: Phải có enctype="multipart/form-data" mới up được ảnh *@
                    <form asp-action="Edit" method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <input type="hidden" asp-for="Id" />

                        <div class="row">
                            @* 1. Tên bộ sưu tập *@
                            <div class="col-md-12 mb-3">
                                <label class="form-label fw-bold">Tên bộ sưu tập</label>
                                <input asp-for="CollectionName" class="form-control" placeholder="Ví dụ: Đồng hồ Thụy Sỹ..." />
                                <span asp-validation-for="CollectionName" class="text-danger small"></span>
                            </div>

                            @* 2. Thứ tự hiển thị & Trạng thái *@
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Thứ tự hiển thị</label>
                                <input asp-for="Order" class="form-control" type="number" />
                                <span asp-validation-for="Order" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3 d-flex align-items-end">
                                <div class="form-check form-switch mb-2">
                                    <input class="form-check-input" type="checkbox" asp-for="IsActive">
                                    <label class="form-check-label fw-bold" for="IsActive">Kích hoạt hiển thị</label>
                                </div>
                            </div>

                            @* 3. Chọn ảnh mới *@
                            <div class="col-md-12 mb-4">
                                <label class="form-label fw-bold">Thay đổi ảnh nền (Nếu muốn)</label>
                                <input type="file" name="HinhAnh" class="form-control" id="imgInput" accept="image/*" />
                                <small class="text-muted">Nên chọn ảnh tỉ lệ 16:9 để hiển thị đẹp nhất.</small>
                            </div>

                            <div class="col-md-12">
                                <hr />
                                <button type="submit" class="btn btn-primary btn-lg px-5 shadow-sm">
                                    <i class="bi bi-save me-2"></i>Lưu thay đổi
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        @* --- CỘT XEM TRƯỚC ẢNH --- *@
        <div class="col-md-4">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3">
                    <h6 class="m-0 fw-bold text-primary">🖼️ Xem trước hình ảnh</h6>
                </div>
                <div class="card-body text-center">
                    @if (!string.IsNullOrEmpty(Model.BackgroundImage))
                    {
                        <img id="imgPreview" src="~/images/collections/@Model.BackgroundImage"
                             class="img-fluid rounded shadow-sm border"
                             style="max-height: 250px; width: 100%; object-fit: cover;"
                             alt="Preview">
                    }
                    else
                    {
                        <img id="imgPreview" src="~/images/no-image.png"
                             class="img-fluid rounded shadow-sm border"
                             style="max-height: 250px; width: 100%; object-fit: cover;"
                             alt="No Image">
                    }
                    <p class="mt-3 text-muted small" id="imgName">Ảnh hiện tại: @Model.BackgroundImage</p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // JS "Thần thánh" giúp thay đổi ảnh preview ngay khi ní chọn file
        document.getElementById('imgInput').onchange = evt => {
            const [file] = document.getElementById('imgInput').files
            if (file) {
                document.getElementById('imgPreview').src = URL.createObjectURL(file);
                document.getElementById('imgName').innerText = "Ảnh mới: " + file.name;
                document.getElementById('imgName').classList.add("text-success", "fw-bold");
            }
        }
    </script>
}

@section Styles {
    <style>
        .form-control:focus {
            border-color: #4e73df;
            box-shadow: 0 0 0 0.2rem rgba(78, 115, 223, 0.25);
        }
        .card { border-radius: 12px; }
        .btn { border-radius: 8px; }
    </style>
}