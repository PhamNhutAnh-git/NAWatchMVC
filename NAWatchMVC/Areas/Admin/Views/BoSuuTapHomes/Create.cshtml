@model NAWatchMVC.Data.BoSuuTapHome

@{
    ViewData["Title"] = "Thêm mới Bộ Sưu Tập";
}

<div class="container-fluid">
    @* --- HEADER --- *@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark">🆕 Thêm mới Bộ Sưu Tập</h2>
            <p class="text-muted">Tạo nhóm sản phẩm nổi bật để hiển thị lên trang chủ</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary shadow-sm">
            <i class="bi bi-arrow-left me-1"></i> Quay lại danh sách
        </a>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    @* QUAN TRỌNG: Phải có enctype="multipart/form-data" mới gửi được file về Controller *@
                    <form asp-action="Create" method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="row">
                            @* 1. Tên bộ sưu tập *@
                            @* Thay cái ô input cũ bằng cái select này *@
                            <div class="col-md-12 mb-3">
                                <label class="form-label fw-bold">Chọn tên bộ sưu tập (Từ dữ liệu Hàng hóa)</label>
                                <select asp-for="CollectionName" asp-items="ViewBag.CollectionList" class="form-select form-select-lg shadow-sm border-primary">
                                    <option value="">-- Chọn bộ sưu tập có sẵn --</option>
                                </select>
                                <span asp-validation-for="CollectionName" class="text-danger small"></span>
                                <div class="form-text mt-2 text-info">
                                    <i class="bi bi-info-circle-fill me-1"></i>
                                    Lưu ý: Chỉ những tên đã có trong cột BoSuuTap của bảng Hàng Hóa mới xuất hiện ở đây.
                                </div>
                            </div>

                            @* 2. Thứ tự & Trạng thái *@
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Thứ tự hiển thị</label>
                                <input asp-for="Order" class="form-control" type="number" value="1" />
                                <span asp-validation-for="Order" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3 d-flex align-items-end">
                                <div class="form-check form-switch mb-2">
                                    <input class="form-check-input" type="checkbox" asp-for="IsActive" checked>
                                    <label class="form-check-label fw-bold" for="IsActive">Kích hoạt ngay</label>
                                </div>
                            </div>

                            @* 3. Chọn ảnh nền *@
                            <div class="col-md-12 mb-4">
                                <label class="form-label fw-bold">Ảnh nền bộ sưu tập (Không bắt buộc)</label>
                                @* Đã bỏ required để ní có thể bấm "Tạo" luôn mà không cần chọn file *@
                                <input type="file" name="HinhAnh" class="form-control" id="imgInput" accept="image/*" />
                                <div class="form-text text-muted small">Mẹo: Nếu không chọn, hệ thống sẽ dùng ảnh mặc định của NAWatch.</div>
                            </div>

                            <div class="col-md-12 pt-3">
                                <hr />
                                <button type="submit" class="btn btn-primary btn-lg px-5 shadow-sm">
                                    <i class="bi bi-cloud-arrow-up-fill me-2"></i>Tạo bộ sưu tập
                                </button>
                                <button type="reset" class="btn btn-light btn-lg px-3 ms-2">Làm lại</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        @* --- CỘT XEM TRƯỚC ẢNH --- *@
        <div class="col-md-4">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3 border-bottom-0">
                    <h6 class="m-0 fw-bold text-primary">🖼️ Xem trước hình ảnh</h6>
                </div>
                <div class="card-body text-center">
                    <div class="preview-box rounded border d-flex align-items-center justify-content-center overflow-hidden bg-light" style="height: 250px;">
                        <img id="imgPreview" src="" class="img-fluid d-none" style="width: 100%; height: 100%; object-fit: cover;" />
                        <div id="previewPlaceholder" class="text-muted">
                            <i class="bi bi-images fs-1 d-block mb-2"></i>
                            <span>Chưa chọn ảnh</span>
                        </div>
                    </div>
                    <p class="mt-3 text-muted small" id="imgName">Vui lòng chọn file để xem trước</p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // Script thần thánh: Chọn ảnh phát hiện luôn!
        document.getElementById('imgInput').onchange = evt => {
            const [file] = document.getElementById('imgInput').files;
            if (file) {
                const preview = document.getElementById('imgPreview');
                const placeholder = document.getElementById('previewPlaceholder');

                preview.src = URL.createObjectURL(file);
                preview.classList.remove('d-none');
                placeholder.classList.add('d-none');

                document.getElementById('imgName').innerText = "File đã chọn: " + file.name;
                document.getElementById('imgName').classList.add("text-success", "fw-bold");
            }
        }
    </script>
}

@section Styles {
    <style>
        .form-control:focus {
            border-color: #4e73df;
            box-shadow: 0 0 0 0.2rem rgba(78, 115, 223, 0.25);
        }
        .card { border-radius: 15px; }
        .btn-lg { border-radius: 10px; font-weight: 600; }
        .preview-box { transition: all 0.3s ease; }
    </style>
}