@model NAWatchMVC.Data.NhaCungCap

@{
    ViewData["Title"] = "Chi tiết Nhà cung cấp";
}

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb small mb-1">
                    <li class="breadcrumb-item"><a asp-controller="HomeAdmin" asp-action="Index" class="text-decoration-none text-muted">Admin</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none text-muted">Nhà cung cấp</a></li>
                    <li class="breadcrumb-item active" aria-current="page">@Model.TenCongTy</li>
                </ol>
            </nav>
            <h1 class="h3 mb-0 text-gray-800 fw-bold">Thông tin đối tác</h1>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model?.MaNcc" class="btn btn-primary shadow-sm rounded-pill px-4">
                <i class="fas fa-edit me-1"></i> Chỉnh sửa
            </a>
            <a asp-action="Index" class="btn btn-outline-secondary shadow-sm rounded-pill px-4">
                <i class="fas fa-arrow-left me-1"></i> Danh sách
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-4 mb-4">
            <div class="card shadow-sm border-0 text-center h-100">
                <div class="card-body p-4">
                    <div class="mb-4">
                        <label class="form-label fw-bold text-muted small d-block text-uppercase mb-3">Logo Thương hiệu</label>
                        <div class="p-3 border rounded-3 bg-light d-inline-block shadow-sm">
                            @if (!string.IsNullOrEmpty(Model.Logo))
                            {
                                <img src="~/anhncc/@Model.Logo" class="img-fluid rounded" style="max-height: 180px; object-fit: contain;" alt="@Model.TenCongTy" />
                            }
                            else
                            {
                                <img src="~/anhloai/loaikhac.png" class="img-fluid rounded" style="max-height: 180px;" alt="No logo" />
                            }
                        </div>
                    </div>
                    <h4 class="fw-bold text-dark mb-2">@Model.TenCongTy</h4>
                    <span class="badge rounded-pill px-3 py-2 bg-primary-subtle text-primary border border-primary-subtle">
                        <i class="fas fa-globe-asia me-1"></i> @Model.QuocGia
                    </span>
                    <hr class="my-4">
                    <div class="text-start">
                        <p class="small text-muted mb-1 text-uppercase fw-bold">Mã nhà cung cấp</p>
                        <p class="h6 fw-bold">#@Model.MaNcc</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-8 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white py-3 border-bottom-0">
                    <h6 class="m-0 font-weight-bold text-dark text-uppercase">
                        <i class="fas fa-address-book me-2 text-info"></i>Thông tin liên hệ & Pháp lý
                    </h6>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-borderless">
                            <tbody>
                                <tr>
                                    <td class="fw-bold text-muted small text-uppercase py-3" style="width: 30%">Người đại diện:</td>
                                    <td class="py-3 text-dark fw-bold">@Model.NguoiLienLac</td>
                                </tr>
                                <tr>
                                    <td class="fw-bold text-muted small text-uppercase py-3">Email liên hệ:</td>
                                    <td class="py-3 text-primary"><u>@Model.Email</u></td>
                                </tr>
                                <tr>
                                    <td class="fw-bold text-muted small text-uppercase py-3">Số điện thoại:</td>
                                    <td class="py-3">@Model.DienThoai</td>
                                </tr>
                                <tr>
                                    <td class="fw-bold text-muted small text-uppercase py-3">Địa chỉ trụ sở:</td>
                                    <td class="py-3">@Model.DiaChi</td>
                                </tr>
                                <tr>
                                    <td class="fw-bold text-muted small text-uppercase py-3">Mô tả/Giới thiệu:</td>
                                    <td class="py-3">
                                        <div class="p-3 bg-light rounded-3 text-muted" style="min-height: 80px;">
                                            @if (!string.IsNullOrEmpty(Model.MoTa))
                                            {
                                                @Model.MoTa
                                            }
                                            else
                                            {
                                                <span class="fst-italic">Không có thông tin mô tả chi tiết.</span>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="card-footer bg-white border-0 py-3 text-end">
                    <small class="text-muted italic">Trạng thái: <span class="text-success fw-bold">Đang hợp tác</span></small>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .bg-primary-subtle { background-color: #e0f2fe; }
        .table td { border-bottom: 1px solid #f1f5f9; }
        .table tr:last-child td { border-bottom: none; }
        .breadcrumb-item + .breadcrumb-item::before { content: "›"; font-size: 1.2rem; vertical-align: middle; }
    </style>
}