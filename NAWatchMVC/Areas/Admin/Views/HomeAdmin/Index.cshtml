@model IEnumerable<HoaDon>
@{
    ViewData["Title"] = "Bảng điều khiển";
}

<div class="row">
    <div class="col-md-4 mb-4">
        <div class="card bg-primary text-white p-3 h-100 shadow border-0">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-uppercase small">TỔNG DOANH THU</h6>
                    <h3 class="fw-bold">@ViewBag.TongDoanhThu.ToString("#,##0")₫</h3>
                </div>
                <i class="fas fa-money-bill-wave fa-3x opacity-50"></i>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-4">
        <div class="card bg-success text-white p-3 h-100 shadow border-0">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-uppercase small">ĐƠN HÀNG MỚI</h6>
                    <h3 class="fw-bold">@ViewBag.DonHangMoi</h3>
                </div>
                <i class="fas fa-shopping-cart fa-3x opacity-50"></i>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-4">
        <div class="card bg-danger text-white p-3 h-100 shadow border-0">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-uppercase small">SẮP HẾT HÀNG</h6>
                    <h3 class="fw-bold">@ViewBag.SapHetHang</h3>
                </div>
                <i class="fas fa-exclamation-triangle fa-3x opacity-50"></i>
            </div>
        </div>
    </div>
</div>

<div class="card mt-4 shadow-sm border-0">
    <div class="card-header bg-white py-3">
        <h5 class="mb-0 fw-bold text-primary"><i class="fas fa-list me-2"></i>Đơn hàng gần đây</h5>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Mã đơn</th>
                        <th>Khách hàng</th>
                        <th>Ngày đặt</th>
                        <th>Tổng tiền</th>
                        <th>Thanh toán</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>#@item.MaHd</td>
                            <td>@item.HoTen</td>
                            <td>@item.NgayDat?.ToString("dd/MM/yyyy")</td>
                            <td class="fw-bold">@item.TongTien?.ToString("#,##0")₫</td>
                            <td>
                                <span class="badge @(item.CachThanhToan == "VNPAY" ? "bg-info" : "bg-secondary")">
                                    @item.CachThanhToan
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>