@model NAWatchMVC.Data.HomePageMedia

@{
    ViewData["Title"] = "Xác nhận xóa Media";
}

<div class="container-fluid">
    @* --- HEADER --- *@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-danger">⚠️ Xác nhận xóa Media</h2>
            <p class="text-muted">Lưu ý: Xóa dữ liệu này sẽ xóa luôn file ảnh trên máy chủ!</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary shadow-sm">
            <i class="bi bi-arrow-left me-1"></i> Quay lại danh sách
        </a>
    </div>

    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card shadow-sm border-0 border-top border-danger border-5">
                <div class="card-body p-4 text-center">

                    @* --- CẢNH BÁO --- *@
                    <div class="alert alert-danger d-inline-block px-4 py-2 rounded-pill mb-4">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        Bạn có chắc chắn muốn xóa nội dung này không?
                    </div>

                    @* --- HIỂN THỊ PREVIEW (Slide/Banner hoặc Video) --- *@
                    <div class="mb-4">
                        @if (Model.MediaType == "Video")
                        {
                            <div class="ratio ratio-16x9 mx-auto shadow rounded border" style="max-width: 400px;">
                                <iframe src="@Model.YoutubeUrl" title="YouTube video" allowfullscreen></iframe>
                            </div>
                            <p class="mt-2 text-danger fw-bold"><i class="bi bi-youtube"></i> Video YouTube</p>
                        }
                        else
                        {
                            @if (!string.IsNullOrEmpty(Model.ImageUrl))
                            {
                                <img src="~/images/homepage/@Model.ImageUrl"
                                     class="rounded shadow border"
                                     style="max-height: 250px; width: 100%; object-fit: cover;" />
                                <p class="mt-2 text-muted small">File: @Model.ImageUrl</p>
                            }
                        }
                    </div>

                    @* --- CHI TIẾT THÔNG TIN --- *@
                    <div class="row justify-content-center mb-4 text-start">
                        <div class="col-md-10">
                            <div class="p-3 bg-light rounded border">
                                <div class="row g-3">
                                    <div class="col-md-12">
                                        <span class="text-muted small">Tiêu đề:</span>
                                        <h5 class="fw-bold mb-0">@Model.Title</h5>
                                    </div>
                                    <div class="col-md-4">
                                        <span class="text-muted small">Vị trí hiển thị:</span>
                                        <p class="fw-bold text-primary mb-0">@Model.ViTri</p>
                                    </div>
                                    <div class="col-md-4">
                                        <span class="text-muted small">Loại Media:</span>
                                        <p class="fw-bold mb-0">@Model.MediaType</p>
                                    </div>
                                    <div class="col-md-4">
                                        <span class="text-muted small">Thứ tự:</span>
                                        <p class="fw-bold mb-0">#@Model.Order</p>
                                    </div>
                                    @if (!string.IsNullOrEmpty(Model.NavigationLink))
                                    {
                                        <div class="col-md-12">
                                            <span class="text-muted small">Link điều hướng:</span>
                                            <p class="mb-0 text-truncate">@Model.NavigationLink</p>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>

                    @* --- NÚT BẤM XÓA --- *@
                    <form asp-action="Delete">
                        <input type="hidden" asp-for="Id" />
                        <button type="submit" class="btn btn-danger btn-lg px-5 shadow">
                            <i class="bi bi-trash3-fill me-2"></i>Xác nhận xóa vĩnh viễn
                        </button>
                        <a asp-action="Index" class="btn btn-light btn-lg px-4 ms-2 border">Hủy bỏ</a>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .card {
            border-radius: 15px;
        }

        .btn-lg {
            border-radius: 10px;
            font-weight: 600;
        }

        /* Hiệu ứng rung nhẹ khi load trang để gây chú ý */
        .card {
            animation: shake 0.5s cubic-bezier(.36,.07,.19,.97) both;
        }

        @@keyframes shake {
            10%, 90% {
                transform: translate3d(-1px, 0, 0);
            }

            20%, 80% {
                transform: translate3d(2px, 0, 0);
            }

            30%, 50%, 70% {
                transform: translate3d(-4px, 0, 0);
            }

            40%, 60% {
                transform: translate3d(4px, 0, 0);
            }
        }
    </style>
}