@model IEnumerable<NAWatchMVC.Data.NewsArticle>

@{
    ViewData["Title"] = "Quản lý Tin tức";
    Layout = "_LayoutAdmin";
}

<div class="container-fluid">
    <div class="card shadow mb-4 border-0">
        <div class="card-header py-3 bg-primary d-flex justify-content-between align-items-center">
            <h5 class="m-0 font-weight-bold text-white">
                <i class="fas fa-newspaper me-2"></i>Danh Sách Tin Tức & Sự Kiện
            </h5>
            <a asp-action="Create" class="btn btn-light btn-sm fw-bold text-primary shadow-sm">
                <i class="fas fa-plus-circle me-1"></i>Thêm bài viết mới
            </a>
        </div>

        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle" id="dataTable" width="100%" cellspacing="0">
                    <thead class="table-light text-secondary">
                        <tr>
                            <th style="width: 100px;">Hình ảnh</th>
                            <th>Tiêu đề & Tóm tắt</th>
                            <th style="width: 150px;">Ngày đăng</th>
                            <th class="text-center" style="width: 120px;">Trạng thái</th>
                            <th class="text-center" style="width: 150px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr id="news-@item.Id">
                                <td>
                                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                                    {
                                        <img src="~/Hinh/TinTuc/@item.ImageUrl" class="rounded shadow-sm border"
                                             style="width: 80px; height: 60px; object-fit: cover;" />
                                    }
                                    else
                                    {
                                        <img src="~/Hinh/no-image.jpg" class="rounded shadow-sm border" style="width: 80px; height: 60px;" />
                                    }
                                </td>

                                <td>
                                    <div class="fw-bold text-dark text-truncate" style="max-width: 300px;">@item.Title</div>
                                    <div class="small text-muted text-truncate" style="max-width: 300px;">@item.Summary</div>
                                </td>

                                <td class="small">
                                    <i class="far fa-calendar-alt me-1 text-primary"></i>
                                    @item.PublishedDate.ToString("dd/MM/yyyy HH:mm")
                                </td>

                                <td class="text-center">
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success-soft text-success px-3 py-2 rounded-pill">
                                            <i class="fas fa-check-circle me-1"></i>Hiện
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-soft text-danger px-3 py-2 rounded-pill">
                                            <i class="fas fa-eye-slash me-1"></i>Ẩn
                                        </span>
                                    }
                                </td>

                                <td class="text-center">
                                    <div class="btn-group shadow-sm">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning btn-sm" title="Sửa">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info btn-sm" title="Chi tiết">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <button onclick="confirmDelete(@item.Id)" class="btn btn-outline-danger btn-sm" title="Xóa">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                @* Form này dùng để gửi lệnh xóa ngầm *@
                <form id="deleteForm" method="post" asp-action="Delete">
                    @Html.AntiForgeryToken() @* Bảo mật chống tấn công giả mạo *@
                    <input type="hidden" name="id" id="deleteId" />
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function confirmDelete(id) {
            Swal.fire({
                title: 'Xóa bài viết này?',
                text: "Dữ liệu tin tức sẽ mất vĩnh viễn đó ní!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Ừ, xóa đi!',
                cancelButtonText: 'Thôi, đừng xóa'
            }).then((result) => {
                if (result.isConfirmed) {
                    // Gọi Action Delete bằng form post ngầm hoặc Redirect
                    //window.location.href = "/Admin/NewsArticles/Delete/" + id;
                    // Đưa ID vào input ẩn và nhấn nút Xóa
                    document.getElementById('deleteId').value = id;
                    document.getElementById('deleteForm').submit();
                }
            })
        }
    </script>
}

<style>
    /* Custom Badge mềm mại kiểu hiện đại */
    .bg-success-soft { background-color: #e8fadf; }
    .bg-danger-soft { background-color: #fbeae9; }

    .table-hover tbody tr:hover {
        background-color: rgba(30, 136, 229, 0.05);
        transition: 0.3s;
    }

    .btn-group .btn {
        width: 38px;
        height: 34px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
</style>