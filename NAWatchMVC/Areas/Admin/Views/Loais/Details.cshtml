@model NAWatchMVC.Data.Loai

@{
    ViewData["Title"] = "Chi tiết Danh mục";
}

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb small mb-1">
                    <li class="breadcrumb-item"><a asp-controller="HomeAdmin" asp-action="Index" class="text-decoration-none">Admin</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Danh mục</a></li>
                    <li class="breadcrumb-item active" aria-current="page">@Model.TenLoai</li>
                </ol>
            </nav>
            <h1 class="h3 mb-0 text-gray-800 fw-bold">Chi tiết danh mục</h1>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model?.MaLoai" class="btn btn-primary shadow-sm rounded-pill px-4">
                <i class="fas fa-edit me-1"></i> Chỉnh sửa
            </a>
            <a asp-action="Index" class="btn btn-outline-secondary shadow-sm rounded-pill px-4">
                <i class="fas fa-list me-1"></i> Danh sách
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-4 mb-4">
            <div class="card shadow-sm border-0 text-center p-4 h-100">
                <div class="mb-3">
                    <label class="form-label fw-bold text-muted small d-block mb-3">Hình ảnh đại diện</label>
                    <div class="p-2 border rounded-3 bg-light d-inline-block">
                        @if (!string.IsNullOrEmpty(Model.Hinh))
                        {
                            <img src="~/anhloai/@Model.Hinh" class="img-fluid rounded" style="max-height: 200px; object-fit: contain;" alt="@Model.TenLoai" />
                        }
                        else
                        {
                            <img src="~/Hinh/default_category.png" class="img-fluid rounded" style="max-height: 200px;" alt="No image" />
                        }
                    </div>
                </div>
                <h4 class="fw-bold text-primary mt-2">@Model.TenLoai</h4>
                <p class="text-muted small">Mã danh mục: #@Model.MaLoai</p>

                @* Phần bonus: Hiện số lượng sản phẩm nếu ní đã làm phần thống kê *@
                <div class="mt-3 py-2 border-top border-bottom border-light">
                    <span class="text-muted small">Alias URL: </span>
                    <span class="badge bg-light text-primary border border-primary-subtle">@Model.TenLoaiAlias</span>
                </div>
            </div>
        </div>

        <div class="col-lg-8 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white py-3 border-bottom-0">
                    <h6 class="m-0 font-weight-bold text-dark text-uppercase">
                        <i class="fas fa-info-circle me-2 text-info"></i>Thông tin chi tiết
                    </h6>
                </div>
                <div class="card-body">
                    <div class="mb-4">
                        <label class="fw-bold text-muted small text-uppercase mb-2">Tên hiển thị trên Web</label>
                        <div class="fs-5 text-dark">@Model.TenLoai</div>
                    </div>

                    <div class="mb-4">
                        <label class="fw-bold text-muted small text-uppercase mb-2">Mô tả danh mục</label>
                        <div class="p-3 bg-light rounded-3 text-muted" style="min-height: 100px; line-height: 1.6;">
                            @if (!string.IsNullOrEmpty(Model.MoTa))
                            {
                                @Model.MoTa
                            }
                            else
                            {
                                <span class="fst-italic text-secondary">Không có mô tả cho danh mục này.</span>
                            }
                        </div>
                    </div>

                    <div class="row mt-4 pt-3 border-top">
                        <div class="col-md-6 mb-3">
                            <div class="d-flex align-items-center">
                                <div class="bg-info-subtle p-2 rounded-circle me-3">
                                    <i class="fas fa-link text-info"></i>
                                </div>
                                <div>
                                    <small class="text-muted d-block">Đường dẫn tĩnh (Alias)</small>
                                    <span class="fw-bold">/@Model.TenLoaiAlias</span>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div class="d-flex align-items-center">
                                <div class="bg-success-subtle p-2 rounded-circle me-3">
                                    <i class="fas fa-check-double text-success"></i>
                                </div>
                                <div>
                                    <small class="text-muted d-block">Trạng thái hiển thị</small>
                                    <span class="fw-bold text-success">Công khai</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-white border-0 py-3 text-center">
                    <small class="text-muted fst-italic">Dữ liệu được cập nhật lần cuối vào @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</small>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .bg-info-subtle { background-color: #e0f2fe; }
        .bg-success-subtle { background-color: #dcfce7; }
        .breadcrumb-item + .breadcrumb-item::before { content: "›"; font-size: 1.2rem; vertical-align: middle; }
    </style>
}