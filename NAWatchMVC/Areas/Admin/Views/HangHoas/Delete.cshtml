@model NAWatchMVC.Data.HangHoa

@{
    ViewData["Title"] = "Xóa sản phẩm";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-xl-10 col-lg-11">
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-custom-danger alert-dismissible fade show shadow-sm mb-4" role="alert">
                    <div class="d-flex align-items-center">
                        <i class="fas fa-hand-paper fa-2x me-3"></i>
                        <div>
                            <h5 class="alert-heading fw-bold mb-1">Căng à nha ní!</h5>
                            <p class="mb-0">@Html.Raw(TempData["Error"])</p>
                        </div>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <div class="card shadow-lg border-0 rounded-lg overflow-hidden">
                <div class="card-header bg-gradient-danger py-3">
                    <h5 class="m-0 font-weight-bold text-white d-flex align-items-center">
                        <i class="fas fa-trash-alt me-2"></i> XÁC NHẬN XÓA SẢN PHẨM
                    </h5>
                </div>
                <div class="card-body p-5">
                    <div class="row align-items-center">
                        <div class="col-md-4 text-center mb-4 mb-md-0">
                            <div class="bg-light p-3 rounded shadow-sm">
                                <img src="~/anhall/@(Model.Hinh ?? "default.jpg")"
                                     class="img-fluid rounded"
                                     style="max-height: 300px; object-fit: contain;" />
                            </div>
                            <div class="mt-3">
                                <span class="badge bg-dark px-3 py-2">ID: #@Model.MaHh</span>
                            </div>
                        </div>

                        <div class="col-md-8 ps-md-5">
                            <h3 class="text-danger fw-bold mb-3">@Model.TenHh</h3>

                            <div class="row mb-4">
                                <div class="col-sm-6">
                                    <p class="mb-2">
                                        <span class="text-muted small text-uppercase fw-bold d-block">Giá bán:</span>
                                        <span class="h5 text-dark fw-bold">@Model.DonGia?.ToString("#,##0")₫</span>
                                    </p>
                                    <p class="mb-2">
                                        <span class="text-muted small text-uppercase fw-bold d-block">Danh mục:</span>
                                        <span class="text-dark">@Model.MaLoaiNavigation?.TenLoai</span>
                                    </p>
                                </div>
                                <div class="col-sm-6">
                                    <p class="mb-2">
                                        <span class="text-muted small text-uppercase fw-bold d-block">Thương hiệu:</span>
                                        <span class="text-dark">@Model.MaNccNavigation?.TenCongTy</span>
                                    </p>
                                    <p class="mb-2">
                                        <span class="text-muted small text-uppercase fw-bold d-block">Tồn kho:</span>
                                        <span class="badge bg-secondary">@Model.SoLuong chiếc</span>
                                    </p>
                                </div>
                            </div>

                            <div class="alert alert-warning border-start-warning shadow-sm">
                                <div class="d-flex">
                                    <i class="fas fa-exclamation-triangle mt-1 me-2 text-warning"></i>
                                    <div>
                                        <strong>Điều kiện xóa:</strong>
                                        Hệ thống sẽ không cho xóa nếu sản phẩm này đã từng được khách đặt mua (có trong đơn hàng) để đảm bảo tính toàn vẹn của báo cáo doanh thu.
                                    </div>
                                </div>
                            </div>

                            <form asp-action="Delete" class="mt-4 d-flex justify-content-between align-items-center">
                                <input type="hidden" asp-for="MaHh" />
                                <a asp-action="Index" class="btn btn-light border px-4 rounded-pill">
                                    <i class="fas fa-chevron-left me-1"></i> Quay lại
                                </a>
                                <button type="submit" class="btn btn-danger btn-lg px-5 rounded-pill shadow-danger">
                                    <i class="fas fa-trash-alt me-1"></i> XÁC NHẬN XÓA
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .bg-gradient-danger {
            background: linear-gradient(45deg, #e74a3b 0%, #be2617 100%);
        }

        .shadow-danger {
            box-shadow: 0 4px 15px rgba(231, 74, 59, 0.4);
        }

        .border-start-warning {
            border-left: 5px solid #f6c23e !important;
        }

        .alert-custom-danger {
            background-color: #fff5f5;
            border-left: 5px solid #e74a3b;
            color: #be2617;
        }
    </style>
}