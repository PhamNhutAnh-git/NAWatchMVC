@model NAWatchMVC.Data.KhachHang

@{
    ViewData["Title"] = "Hồ sơ khách hàng";
}

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb small mb-1">
                    <li class="breadcrumb-item"><a asp-controller="HomeAdmin" asp-action="Index" class="text-decoration-none text-muted">Admin</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none text-muted">Khách hàng</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Hồ sơ: @Model.MaKh</li>
                </ol>
            </nav>
            <h1 class="h3 mb-0 text-gray-800 fw-bold">Chi tiết khách hàng</h1>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model?.MaKh" class="btn btn-primary shadow-sm rounded-pill px-4">
                <i class="fas fa-edit me-1"></i> Chỉnh sửa
            </a>
            <a asp-action="Index" class="btn btn-outline-secondary shadow-sm rounded-pill px-4">
                <i class="fas fa-list me-1"></i> Danh sách
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-4 mb-4">
            <div class="card shadow-sm border-0 text-center p-4 h-100">
                <div class="card-body">
                    <div class="mb-3">
                        @* Sử dụng ui-avatars để tạo ảnh đại diện theo tên nếu không có hình *@
                        <img src="https://ui-avatars.com/api/?name=@Model.HoTen&background=4f46e5&color=fff&size=256"
                             class="rounded-circle shadow-sm border border-4 border-white" width="150" height="150" />
                    </div>
                    <h4 class="fw-bold text-dark mb-1">@Model.HoTen</h4>
                    <p class="text-muted small mb-3">@(Model.TenDangNhap ?? "Tài khoản vãn lai")</p>
                    @* @@@Model.TenDangNhap *@
                    <div class="d-flex justify-content-center gap-2 mb-3">
                        @if (Model.HieuLuc == true)
                        {
                            <span class="badge bg-success rounded-pill px-3 py-2">Đang hoạt động</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary rounded-pill px-3 py-2">Đã bị khóa</span>
                        }
                    </div>

                    <hr class="my-4 mx-3 opacity-10">

                    <div class="text-start px-2">
                        <div class="mb-3 d-flex align-items-center">
                            <div class="bg-primary-subtle p-2 rounded me-3 text-primary"><i class="fas fa-envelope"></i></div>
                            <div>
                                <small class="text-muted d-block small fw-bold">EMAIL</small>
                                <span class="small">@Model.Email</span>mâ
                            </div>
                        </div>
                        <div class="mb-3 d-flex align-items-center">
                            <div class="bg-info-subtle p-2 rounded me-3 text-info"><i class="fas fa-phone"></i></div>
                            <div>
                                <small class="text-muted d-block small fw-bold">ĐIỆN THOẠI</small>
                                <span class="small">@Model.DienThoai</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-8 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white py-3 border-bottom-0">
                    <h6 class="m-0 font-weight-bold text-dark text-uppercase">
                        <i class="fas fa-info-circle me-2 text-primary"></i>Thông tin cá nhân & Tài khoản
                    </h6>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-borderless align-middle">
                            <tbody>
                                <tr>
                                    <td class="fw-bold text-muted small text-uppercase" style="width: 30%">Giới tính:</td>
                                    <td>
                                        @if (Model.GioiTinh == true)
                                        {
                                            <span class="text-primary"><i class="fas fa-mars me-1"></i> Nam</span>
                                        }
                                        else
                                        {
                                            <span class="text-danger"><i class="fas fa-venus me-1"></i> Nữ</span>
                                        }
                                    </td>
                                </tr>
                                <tr>
                                    <td class="fw-bold text-muted small text-uppercase">Ngày sinh:</td>
                                    <td>@Model.NgaySinh?.ToString("dd/MM/yyyy")</td>
                                </tr>
                                <tr>
                                    <td class="fw-bold text-muted small text-uppercase">Địa chỉ:</td>
                                    <td>@Model.DiaChi</td>
                                </tr>
                                <tr>
                                    <td class="fw-bold text-muted small text-uppercase">Mật khẩu:</td>
                                    <td><span class="text-muted fst-italic">******** (Đã mã hóa bảo mật)</span></td>
                                </tr>
                                <tr>
                                    <td class="fw-bold text-muted small text-uppercase">Mã bảo mật:</td>
                                    <td><span class="badge bg-light text-dark border">@Model.RandomKey</span></td>
                                </tr>
                                <tr>
                                    <td class="fw-bold text-muted small text-uppercase">Vai trò khách:</td>
                                    <td>
                                        @if (Model.VaiTro == 1)
                                        {
                                            <span class="badge bg-warning-subtle text-warning border border-warning-subtle px-3">VIP Customer</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-light text-dark border px-3">Thành viên</span>
                                        }
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="card-footer bg-light border-0 py-3 text-center">
                    <small class="text-muted">Mã định danh khách hàng: <strong>#@Model.MaKh</strong></small>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .bg-primary-subtle { background-color: #e0f2fe; }
        .bg-info-subtle { background-color: #e0f7fa; }
        .bg-warning-subtle { background-color: #fff8e1; }
        .table td { padding: 1rem 0.5rem; border-bottom: 1px solid #f1f5f9; }
        .table tr:last-child td { border-bottom: none; }
        .breadcrumb-item + .breadcrumb-item::before { content: "›"; font-size: 1.2rem; vertical-align: middle; }
    </style>
}