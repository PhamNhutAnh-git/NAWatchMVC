@model NAWatchMVC.Data.KhachHang

@{
    ViewData["Title"] = "Thêm Khách hàng mới";
}

<div class="container-fluid">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb small mb-4">
            <li class="breadcrumb-item"><a asp-controller="HomeAdmin" asp-action="Index" class="text-decoration-none text-muted">Admin</a></li>
            <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none text-muted">Khách hàng</a></li>
            <li class="breadcrumb-item active text-primary" aria-current="page">Thêm mới</li>
        </ol>
    </nav>

    <div class="row justify-content-center">
        <div class="col-lg-9">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-white py-3 border-bottom d-flex align-items-center">
                    <div class="bg-primary-subtle p-2 rounded-circle me-3">
                        <i class="fas fa-user-plus text-primary"></i>
                    </div>
                    <h5 class="m-0 font-weight-bold text-dark">Tạo Tài Khoản Khách Hàng</h5>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-4">
                            <h6 class="text-primary fw-bold text-uppercase small mb-3 border-bottom pb-2">
                                <i class="fas fa-key me-2"></i>Thông tin đăng nhập
                            </h6>
                            <div class="row">
                                <div class="col-md-4 mb-3">
                                    <label asp-for="MaKh" class="form-label fw-bold small text-muted">Mã Khách Hàng (ID)</label>
                                    <input asp-for="MaKh" class="form-control border-2" placeholder="Ví dụ: KH001" />
                                    <span asp-validation-for="MaKh" class="text-danger small"></span>
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label asp-for="TenDangNhap" class="form-label fw-bold small text-muted">Tên đăng nhập</label>
                                    <input asp-for="TenDangNhap" class="form-control border-2" placeholder="nhutanh123" />
                                    <span asp-validation-for="TenDangNhap" class="text-danger small"></span>
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label asp-for="MatKhau" class="form-label fw-bold small text-muted">Mật khẩu</label>
                                    <div class="input-group">
                                        <input asp-for="MatKhau" type="password" class="form-control border-2 border-end-0" id="passwordInput" />
                                        <button class="btn btn-outline-secondary border-2 border-start-0" type="button" id="togglePassword">
                                            <i class="fas fa-eye"></i>
                                        </button>
                                    </div>
                                    <span asp-validation-for="MatKhau" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="mb-4">
                            <h6 class="text-primary fw-bold text-uppercase small mb-3 border-bottom pb-2">
                                <i class="fas fa-id-card me-2"></i>Thông tin cá nhân
                            </h6>
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label asp-for="HoTen" class="form-label fw-bold small text-muted">Họ và Tên</label>
                                    <input asp-for="HoTen" class="form-control border-2" placeholder="Nguyễn Văn A" />
                                    <span asp-validation-for="HoTen" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="Email" class="form-label fw-bold small text-muted">Email liên hệ</label>
                                    <input asp-for="Email" type="email" class="form-control border-2" placeholder="abc@gmail.com" />
                                    <span asp-validation-for="Email" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label asp-for="DienThoai" class="form-label fw-bold small text-muted">Số điện thoại</label>
                                    <input asp-for="DienThoai" class="form-control border-2" placeholder="09xxxxxxxx" />
                                    <span asp-validation-for="DienThoai" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="RandomKey" class="form-label fw-bold small text-muted">Mã Random (Security)</label>
                                    <input asp-for="RandomKey" class="form-control border-2 bg-light" placeholder="Tự động sinh hoặc nhập mã..." />
                                </div>
                            </div>

                            <div class="mb-3">
                                <label asp-for="DiaChi" class="form-label fw-bold small text-muted">Địa chỉ thường trú</label>
                                <textarea asp-for="DiaChi" class="form-control border-2" rows="2" placeholder="Số nhà, tên đường, Phường/Xã..."></textarea>
                                <span asp-validation-for="DiaChi" class="text-danger small"></span>
                            </div>
                        </div>

                        <hr class="my-4 opacity-10">

                        <div class="d-flex justify-content-between align-items-center">
                            <a asp-action="Index" class="btn btn-light border px-4 rounded-pill fw-bold">
                                <i class="fas fa-chevron-left me-1"></i> Quay lại
                            </a>
                            <button type="submit" class="btn btn-primary px-5 rounded-pill fw-bold shadow-sm">
                                <i class="fas fa-check-circle me-1"></i> Tạo Khách Hàng
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .bg-primary-subtle { background-color: #e0f2fe; }
        .form-control:focus {
            box-shadow: none;
            border-color: var(--sidebar-active);
        }
        .input-group .btn:hover { background: none; color: #333; }
    </style>
}

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        // Nút ẩn/hiện mật khẩu cho xịn
        document.getElementById('togglePassword').addEventListener('click', function() {
            const pwdInput = document.getElementById('passwordInput');
            const icon = this.querySelector('i');
            if (pwdInput.type === 'password') {
                pwdInput.type = 'text';
                icon.classList.replace('fa-eye', 'fa-eye-slash');
            } else {
                pwdInput.type = 'password';
                icon.classList.replace('fa-eye-slash', 'fa-eye');
            }
        });
    </script>
}