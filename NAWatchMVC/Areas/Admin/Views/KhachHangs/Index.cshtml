@model IEnumerable<NAWatchMVC.Data.KhachHang>

@{
    ViewData["Title"] = "Danh sách Khách hàng";
}

<div class="card shadow-sm border-0">
    <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
        <h5 class="m-0 font-weight-bold text-indigo text-uppercase" style="color: #4f46e5;">
            <i class="fas fa-users me-2"></i>Cộng đồng Khách hàng
        </h5>
        <a asp-action="Create" class="btn btn-indigo btn-sm rounded-pill px-3 shadow-sm text-white" style="background-color: #4f46e5;">
            <i class="fas fa-user-plus me-1"></i> Thêm khách hàng
        </a>
    </div>

    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle" width="100%">
                <thead class="table-light text-secondary">
                    <tr>
                        <th style="width: 60px;">#</th>
                        <th>Thông tin khách</th>
                        <th>Liên hệ</th>
                        <th>Địa chỉ</th>
                        <th class="text-center">Trạng thái</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-center">
                                <img src="https://ui-avatars.com/api/?name=@item.HoTen&background=random&color=fff"
                                     class="rounded-circle shadow-sm" width="40" height="40" alt="avatar" />
                            </td>

                            <td>
                                <div class="fw-bold text-dark">@item.HoTen</div>
                                @* Nếu TenDangNhap bị null thì hiện "Khách vãn lai" *@
                                <small class="text-muted">
                                    <i class="fas fa-user-tag me-1"></i>
                                    @(item.TenDangNhap ?? "Khách vãn lai")
                                </small>
                            </td>

                            <td>
                                <div class="small mb-1"><i class="fas fa-envelope me-2 text-muted"></i>@item.Email</div>
                                <div class="small"><i class="fas fa-phone me-2 text-muted"></i>@item.DienThoai</div>
                            </td>

                            <td class="small text-muted">
                                <div class="text-truncate" style="max-width: 200px;" title="@item.DiaChi">
                                    @item.DiaChi
                                </div>
                            </td>

                            <td class="text-center">
                                @if (item.HieuLuc == true)
                                {
                                    <span class="badge bg-success-subtle text-success border border-success-subtle px-3 rounded-pill">Hoạt động</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle px-3 rounded-pill">Đã khóa</span>
                                }
                            </td>

                            <td class="text-center">
                                <div class="btn-group shadow-sm">
                                    <a asp-action="Edit" asp-route-id="@item.MaKh" class="btn btn-sm btn-outline-primary" title="Chỉnh sửa hồ sơ">
                                        <i class="fas fa-user-edit"></i>
                                    </a>
                                    <a asp-action="Details" asp-route-id="@item.MaKh" class="btn btn-sm btn-outline-info" title="Xem chi tiết">
                                        <i class="fas fa-id-card"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.MaKh" class="btn btn-sm btn-outline-danger" title="Khóa tài khoản">
                                        <i class="fas fa-user-slash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Styles {
    <style>
        /* Màu Badge nhẹ nhàng kiểu Pro */
        .bg-success-subtle { background-color: #dcfce7 !important; }
        .bg-secondary-subtle { background-color: #f1f5f9 !important; }

        /* Cấu trúc nút bấm */
        .btn-indigo:hover { background-color: #4338ca; }
        .table > tbody > tr > td { padding: 12px 8px; }

        /* Badge style */
        .badge { font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; }
    </style>
}