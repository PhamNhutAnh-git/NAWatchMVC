@model NAWatchMVC.Data.KhachHang

@{
    ViewData["Title"] = "Cập nhật Khách hàng";
}

<div class="container-fluid">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb small mb-4">
            <li class="breadcrumb-item"><a asp-controller="HomeAdmin" asp-action="Index" class="text-decoration-none text-muted">Admin</a></li>
            <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none text-muted">Khách hàng</a></li>
            <li class="breadcrumb-item active text-primary" aria-current="page">Chỉnh sửa hồ sơ</li>
        </ol>
    </nav>

    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-white py-3 border-bottom d-flex align-items-center justify-content-between">
                    <div class="d-flex align-items-center">
                        <div class="bg-primary-subtle p-2 rounded-circle me-3">
                            <i class="fas fa-user-edit text-primary"></i>
                        </div>
                        <h5 class="m-0 font-weight-bold text-dark">Chỉnh sửa: <span class="text-primary">@Model.HoTen</span></h5>
                    </div>
                    <span class="badge bg-light text-dark border px-3 rounded-pill">ID: #@Model.MaKh</span>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        @* Giữ lại ID bí mật *@
                        <input type="hidden" asp-for="MaKh" />
                        <input type="hidden" asp-for="Hinh" />

                        <div class="row">
                            <div class="col-md-7 border-end">
                                <h6 class="fw-bold text-uppercase small text-muted mb-3"><i class="fas fa-id-card me-2"></i>Thông tin cá nhân</h6>

                                <div class="mb-3">
                                    <label asp-for="HoTen" class="form-label fw-bold small">Họ và Tên</label>
                                    <input asp-for="HoTen" class="form-control border-2" />
                                    <span asp-validation-for="HoTen" class="text-danger small"></span>
                                </div>

                                <div class="row mb-3">
                                    <div class="col-md-6">
                                        <label asp-for="GioiTinh" class="form-label fw-bold small">Giới tính</label>
                                        <select asp-for="GioiTinh" class="form-select border-2">
                                            <option value="true">Nam</option>
                                            <option value="false">Nữ</option>
                                        </select>
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="NgaySinh" class="form-label fw-bold small">Ngày sinh</label>
                                        <input asp-for="NgaySinh" type="date" class="form-control border-2" />
                                    </div>
                                </div>

                                <div class="row mb-3">
                                    <div class="col-md-6">
                                        <label asp-for="Email" class="form-label fw-bold small">Email</label>
                                        <input asp-for="Email" class="form-control border-2" />
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="DienThoai" class="form-label fw-bold small">Số điện thoại</label>
                                        <input asp-for="DienThoai" class="form-control border-2" />
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="DiaChi" class="form-label fw-bold small">Địa chỉ</label>
                                    <textarea asp-for="DiaChi" class="form-control border-2" rows="3"></textarea>
                                </div>
                            </div>

                            <div class="col-md-5 ps-md-4">
                                <h6 class="fw-bold text-uppercase small text-muted mb-3"><i class="fas fa-shield-alt me-2"></i>Bảo mật & Trạng thái</h6>

                                <div class="mb-3">
                                    <label asp-for="TenDangNhap" class="form-label fw-bold small">Tên đăng nhập</label>
                                    <input asp-for="TenDangNhap" class="form-control border-2 bg-light" readonly />
                                    <small class="text-muted italic">Tên đăng nhập không thể thay đổi.</small>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="MatKhau" class="form-label fw-bold small">Mật khẩu mới</label>
                                    <div class="input-group">
                                        <input asp-for="MatKhau" type="password" class="form-control border-2 border-end-0" id="passwordInput" />
                                        <button class="btn btn-outline-secondary border-2 border-start-0" type="button" id="togglePassword">
                                            <i class="fas fa-eye"></i>
                                        </button>
                                    </div>
                                    <small class="text-muted small">Để trống nếu không muốn đổi mật khẩu.</small>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="RandomKey" class="form-label fw-bold small text-muted">Mã RandomKey</label>
                                    <input asp-for="RandomKey" class="form-control border-2 bg-light" readonly />
                                </div>

                                <div class="p-3 rounded-3 bg-light border mt-4">
                                    <label class="form-label fw-bold small text-muted text-uppercase d-block mb-3">Kiểm soát tài khoản</label>

                                    <div class="mb-3">
                                        <label asp-for="HieuLuc" class="form-label fw-bold small text-muted">TRẠNG THÁI TÀI KHOẢN</label>
                                        <select asp-for="HieuLuc" class="form-select border-2">
                                            <option value="true">Kích hoạt (Hoạt động)</option>
                                            <option value="false">Khóa (Vô hiệu hóa)</option>
                                        </select>
                                        <span asp-validation-for="HieuLuc" class="text-danger small"></span>
                                    </div>

                                    <div class="mb-0">
                                        <label asp-for="VaiTro" class="form-label fw-bold small">Cấp độ khách hàng</label>
                                        <select asp-for="VaiTro" class="form-select border-2">
                                            <option value="0">Khách hàng thường</option>
                                            <option value="1">Khách hàng VIP</option>
                                        </select>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <hr class="my-4 opacity-10">

                        <div class="d-flex justify-content-between align-items-center">
                            <a asp-action="Index" class="btn btn-light border px-4 rounded-pill fw-bold">
                                <i class="fas fa-arrow-left me-1"></i> Quay lại
                            </a>
                            <button type="submit" class="btn btn-primary px-5 rounded-pill fw-bold shadow">
                                <i class="fas fa-save me-1"></i> Cập Nhật Hồ Sơ
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .bg-primary-subtle { background-color: #e0f2fe; }
        .form-control:focus, .form-select:focus {
            box-shadow: none;
            border-color: #3b82f6;
        }
        .custom-switch .form-check-input {
            width: 2.8em;
            height: 1.4em;
            cursor: pointer;
        }
        .custom-switch .form-check-input:checked {
            background-color: #10b981;
            border-color: #10b981;
        }
        .italic { font-style: italic; font-size: 0.8rem; }
    </style>
}

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        // Ẩn hiện mật khẩu
        document.getElementById('togglePassword').addEventListener('click', function() {
            const pwdInput = document.getElementById('passwordInput');
            const icon = this.querySelector('i');
            if (pwdInput.type === 'password') {
                pwdInput.type = 'text';
                icon.classList.replace('fa-eye', 'fa-eye-slash');
            } else {
                pwdInput.type = 'password';
                icon.classList.replace('fa-eye-slash', 'fa-eye');
            }
        });

        // Đổi nhãn trạng thái khi gạt switch
        document.getElementById('statusSwitch').addEventListener('change', function() {
            const label = this.nextElementSibling;
            label.innerText = this.checked ? "Đang hoạt động" : "Đã bị khóa";
            label.className = this.checked ? "form-check-label fw-bold ms-2 text-success" : "form-check-label fw-bold ms-2 text-danger";
        });
    </script>
}