@model NAWatchMVC.Data.Voucher

@{
    ViewData["Title"] = "Chỉnh sửa Voucher";
    Layout = "_LayoutAdmin";
}

<div class="container-fluid p-4">
    @* --- Tiêu đề & Breadcrumb --- *@
    <div class="mb-4">
        <h2 class="fw-bold text-primary"><i class="fas fa-edit me-2"></i>Cập Nhật Thông Tin Voucher</h2>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-action="Index">Quản lý Voucher</a></li>
                <li class="breadcrumb-item active" aria-current="page">Chỉnh sửa: @Model.MaVoucher</li>
            </ol>
        </nav>
    </div>

    <div class="card shadow border-0 rounded-3">
        <div class="card-header bg-primary text-white py-3">
            <h5 class="mb-0"><i class="fas fa-info-circle me-2"></i>Chỉnh sửa mã: <span class="badge bg-white text-primary">@Model.MaVoucher</span></h5>
        </div>
        <div class="card-body p-4">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                @* Khóa chính ẩn đi để gửi về Server *@
                <input type="hidden" asp-for="MaVoucher" />

                <div class="row">
                    @* --- Cột trái: Thông tin loại voucher --- *@
                    <div class="col-md-6 border-end">
                        <div class="mb-3">
                            <label class="form-label fw-bold text-muted">Mã Voucher (Không thể sửa)</label>
                            <input class="form-control rounded-pill bg-light" value="@Model.MaVoucher" disabled />
                        </div>

                        <div class="mb-3">
                            <label asp-for="LoaiVoucher" class="form-label fw-bold">Loại Voucher</label>
                            <select asp-for="LoaiVoucher" class="form-select rounded-pill border-primary">
                                <option value="0">Giảm tiền hàng</option>
                                <option value="1">Giảm phí vận chuyển (Freeship)</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label asp-for="LoaiGiamGia" class="form-label fw-bold">Hình thức giảm giá</label>
                            <select asp-for="LoaiGiamGia" class="form-select rounded-pill">
                                <option value="0">Giảm số tiền cụ thể (đ)</option>
                                <option value="1">Giảm theo phần trăm (%)</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label asp-for="GiaTriGiam" class="form-label fw-bold">Giá trị giảm hiện tại</label>
                            <div class="input-group">
                                <input asp-for="GiaTriGiam" class="form-control rounded-start-pill border-primary" />
                                <span class="input-group-text rounded-end-pill bg-light">đ / %</span>
                            </div>
                            <span asp-validation-for="GiaTriGiam" class="text-danger small"></span>
                        </div>
                    </div>

                    @* --- Cột phải: Điều kiện & Trạng thái --- *@
                    <div class="col-md-6 ps-4">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="GiaTriDonHangToiThieu" class="form-label fw-bold">Đơn tối thiểu</label>
                                <input asp-for="GiaTriDonHangToiThieu" class="form-control rounded-pill" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="GiamToiDa" class="form-label fw-bold">Giảm tối đa</label>
                                <input asp-for="GiamToiDa" class="form-control rounded-pill" />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="NgayBatDau" class="form-label fw-bold">Ngày bắt đầu</label>
                                <input asp-for="NgayBatDau" class="form-control rounded-pill" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="NgayKetThuc" class="form-label fw-bold">Ngày kết thúc</label>
                                <input asp-for="NgayKetThuc" class="form-control rounded-pill" />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="SoLuongToiDa" class="form-label fw-bold">Tổng lượt dùng</label>
                                <input asp-for="SoLuongToiDa" class="form-control rounded-pill" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="SoLuongDaDung" class="form-label fw-bold text-muted">Đã sử dụng</label>
                                <input asp-for="SoLuongDaDung" class="form-control rounded-pill bg-light" readonly />
                            </div>
                        </div>

                        <div class="mb-3 mt-3 p-3 bg-light rounded-3 border">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" asp-for="TrangThai">
                                <label class="form-check-label fw-bold" asp-for="TrangThai">Kích hoạt mã</label>
                            </div>
                            <small class="text-muted italic">Tắt nếu ní muốn tạm ngưng chương trình này.</small>
                        </div>
                    </div>
                </div>

                <hr class="my-4">

                <div class="d-flex justify-content-between align-items-center">
                    <a asp-action="Index" class="btn btn-link text-secondary text-decoration-none">
                        <i class="fas fa-arrow-left me-1"></i> Quay lại danh sách
                    </a>
                    <div class="d-flex gap-2">
                        <button type="reset" class="btn btn-outline-secondary rounded-pill px-4">Hủy thay đổi</button>
                        <button type="submit" class="btn btn-primary rounded-pill px-5 shadow">
                            <i class="fas fa-save me-2"></i>Cập Nhật Ngay
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}