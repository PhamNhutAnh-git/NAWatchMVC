@model IEnumerable<NAWatchMVC.Data.HoaDon>

@{
    ViewData["Title"] = "Quản lý Đơn hàng";
}

<div class="container-fluid px-4 py-3">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb small mb-1">
                    <li class="breadcrumb-item"><a asp-controller="HomeAdmin" asp-action="Index" class="text-decoration-none text-muted">Hệ thống</a></li>
                    <li class="breadcrumb-item active text-indigo fw-bold">Đơn hàng</li>
                </ol>
            </nav>
            <h4 class="fw-bold m-0 text-dark">Quản lý Đơn hàng</h4>
        </div>
        <a asp-action="Create" class="btn btn-indigo shadow-sm rounded-pill px-4 py-2">
            <i class="fas fa-plus-circle me-2"></i>Tạo đơn hàng mới
        </a>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-3 d-flex align-items-center">
                    <div class="icon-shape bg-primary-soft text-primary rounded-4 me-3">
                        <i class="fas fa-file-invoice"></i>
                    </div>
                    <div>
                        <div class="text-muted small fw-bold">TỔNG ĐƠN</div>
                        <h4 class="fw-bold mb-0">@Model.Count()</h4>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-3 d-flex align-items-center">
                    <div class="icon-shape bg-success-soft text-success rounded-4 me-3">
                        <i class="fas fa-dollar-sign"></i>
                    </div>
                    <div>
                        <div class="text-muted small fw-bold">DOANH THU</div>
                        <h4 class="fw-bold mb-0">@Model.Sum(h => h.TongTien ?? 0).ToString("N0")đ</h4>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-3 d-flex align-items-center">
                    <div class="icon-shape bg-warning-soft text-warning rounded-4 me-3">
                        <i class="fas fa-truck"></i>
                    </div>
                    <div>
                        <div class="text-muted small fw-bold">ĐANG GIAO</div>
                        <h4 class="fw-bold mb-0">@Model.Count(h => h.MaTrangThai == 1)</h4>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-3 d-flex align-items-center">
                    <div class="icon-shape bg-danger-soft text-danger rounded-4 me-3">
                        <i class="fas fa-ban"></i>
                    </div>
                    <div>
                        <div class="text-muted small fw-bold">ĐÃ HỦY</div>
                        <h4 class="fw-bold mb-0">@Model.Count(h => h.MaTrangThai == 3)</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-3">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label small fw-bold text-muted">Trạng thái đơn</label>
                    <select name="status" class="form-select border-light-2 rounded-3">
                        <option value="">-- Tất cả --</option>
                        <option value="0">Mới đặt</option>
                        <option value="1">Đang giao</option>
                        <option value="2">Hoàn thành</option>
                        <option value="3">Đã hủy</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label small fw-bold text-muted">Ngày đặt (Từ - Đến)</label>
                    <div class="input-group">
                        <input type="date" name="fromDate" class="form-control border-light-2" />
                        <span class="input-group-text bg-light border-light-2">-</span>
                        <input type="date" name="toDate" class="form-control border-light-2" />
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-bold text-muted">Thanh toán</label>
                    <select name="payment" class="form-select border-light-2 rounded-3">
                        <option value="">Tất cả phương thức</option>
                        <option value="COD">Tiền mặt (COD)</option>
                        <option value="Online">Chuyển khoản / Momo</option>
                    </select>
                </div>
                <div class="col-md-2 d-flex gap-2">
                    <button type="submit" class="btn btn-indigo w-100 rounded-3">Lọc</button>
                    <a asp-action="Index" class="btn btn-outline-secondary w-100 rounded-3">Reset</a>
                </div>
            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive" style="max-height: 550px;">
            <table class="table table-hover align-middle mb-0" id="dataTable">
                <thead class="bg-light sticky-top shadow-sm">
                    <tr>
                        <th class="ps-4 py-3 border-0 text-uppercase small fw-bold">ID & Khách hàng</th>
                        <th class="py-3 border-0 text-uppercase small fw-bold">Ngày đặt</th>
                        <th class="py-3 border-0 text-uppercase small fw-bold text-center">Số SP</th>
                        <th class="py-3 border-0 text-uppercase small fw-bold text-end">Tổng tiền</th>
                        <th class="py-3 border-0 text-uppercase small fw-bold text-center">Trạng thái</th>
                        <th class="py-3 border-0 text-uppercase small fw-bold text-center">Duyệt nhanh</th>
                        <th class="pe-4 py-3 border-0 text-uppercase small fw-bold text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 py-3">
                                <div class="fw-bold text-indigo">#@item.MaHd</div>
                                <div class="text-dark fw-bold">@item.HoTen</div>
                                <small class="text-muted">@item.DienThoai</small>
                            </td>
                            <td>
                                <div class="small">@item.NgayDat?.ToString("dd/MM/yyyy")</div>
                                <div class="text-muted small">@item.NgayDat?.ToString("HH:mm")</div>
                            </td>
                            <td class="text-center">
                                <span class="badge bg-secondary-soft text-secondary rounded-pill">
                                    @(item.ChiTietHds?.Count() ?? 0)
                                </span>
                            </td>
                            <td class="text-end fw-bold text-indigo">
                                @item.TongTien?.ToString("N0")đ
                            </td>
                            <td class="text-center">
                                @{
                                    var (badgeClass, statusIcon) = item.MaTrangThai switch
                                    {
                                        0 => ("bg-blue-soft text-blue", "fa-clock"),
                                        1 => ("bg-warning-soft text-warning", "fa-shipping-fast"),
                                        2 => ("bg-success-soft text-success", "fa-check-circle"),
                                        3 => ("bg-danger-soft text-danger", "fa-times-circle"),
                                        _ => ("bg-secondary-soft text-secondary", "fa-question")
                                    };
                                }
                                <span class="badge @badgeClass py-2 px-3 rounded-pill fw-bold">
                                    <i class="fas @statusIcon me-1"></i> @(item.MaTrangThaiNavigation?.TenTrangThai ?? "N/A")
                                </span>
                            </td>
                            <td class="text-center">
                                @if (item.MaTrangThai == 0)
                                {
                                    <form asp-action="Approve" asp-route-id="@item.MaHd" method="post" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-success rounded-pill px-3 shadow-sm">
                                            Duyệt đơn
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <i class="fas fa-check-double text-muted" title="Đã xử lý"></i>
                                }
                            </td>
                            <td class="text-center pe-4">
                                <div class="btn-group">
                                    <a asp-action="Details" asp-route-id="@item.MaHd" class="btn btn-soft-info btn-sm rounded-circle me-1" title="Xem">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.MaHd" class="btn btn-soft-warning btn-sm rounded-circle me-1" title="Sửa">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <button type="button" class="btn btn-soft-danger btn-sm rounded-circle" onclick="deleteOrder(@item.MaHd)" title="Xóa">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="card-footer bg-white py-3 border-0 d-flex justify-content-center">
            <nav>
                <ul class="pagination pagination-indigo mb-0">
                    <li class="page-item disabled"><a class="page-link" href="#"><i class="fas fa-chevron-left"></i></a></li>
                    <li class="page-item active"><a class="page-link" href="#">1</a></li>
                    <li class="page-item"><a class="page-link" href="#">2</a></li>
                    <li class="page-item"><a class="page-link" href="#"><i class="fas fa-chevron-right"></i></a></li>
                </ul>
            </nav>
        </div>
    </div>
</div>

@section Styles {
    <style>
        :root {
            --indigo: #4f46e5;
            --blue: #3b82f6;
        }

        body {
            background-color: #f8fafc;
        }

        .text-indigo {
            color: var(--indigo);
        }

        .btn-indigo {
            background-color: var(--indigo);
            color: white;
        }

            .btn-indigo:hover {
                background-color: #4338ca;
                color: white;
            }

        /* Card Statistics Style */
        .icon-shape {
            width: 48px;
            height: 48px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.25rem;
        }

        /* Soft Badges Colors */
        .bg-primary-soft {
            background-color: #e0e7ff;
            color: var(--indigo);
        }

        .bg-success-soft {
            background-color: #dcfce7;
            color: #15803d;
        }

        .bg-warning-soft {
            background-color: #fef3c7;
            color: #b45309;
        }

        .bg-danger-soft {
            background-color: #fee2e2;
            color: #b91c1c;
        }

        .bg-blue-soft {
            background-color: #dbeafe;
            color: #1e40af;
        }

        .bg-secondary-soft {
            background-color: #f1f5f9;
            color: #475569;
        }

        .text-blue {
            color: #2563eb;
        }

        /* Table Style */
        #dataTable thead th {
            letter-spacing: 0.05rem;
        }

        .table-hover tbody tr:hover {
            background-color: #f1f5f9;
            transition: background 0.2s;
        }

        .sticky-top {
            top: -1px;
            z-index: 1020;
        }

        .border-light-2 {
            border: 2px solid #f1f5f9;
        }

        /* Soft Buttons */
        .btn-soft-info {
            background-color: #e0f2fe;
            color: #0369a1;
            border: none;
        }

        .btn-soft-warning {
            background-color: #fef3c7;
            color: #b45309;
            border: none;
        }

        .btn-soft-danger {
            background-color: #fee2e2;
            color: #b91c1c;
            border: none;
        }

            .btn-soft-info:hover, .btn-soft-warning:hover, .btn-soft-danger:hover {
                filter: brightness(0.9);
            }

        /* Pagination Indigo */
        .pagination-indigo .page-link {
            color: var(--indigo);
            border: none;
            margin: 0 3px;
            border-radius: 8px;
        }

        .pagination-indigo .page-item.active .page-link {
            background-color: var(--indigo);
            color: white;
        }
    </style>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // Xử lý xóa hóa đơn với SweetAlert2
        function deleteOrder(id) {
            Swal.fire({
                title: 'Xóa hóa đơn #' + id + '?',
                text: "Dữ liệu này sẽ không thể khôi phục lại!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#6b7280',
                confirmButtonText: 'Đúng, xóa luôn!',
                cancelButtonText: 'Hủy'
            }).then((result) => {
                if (result.isConfirmed) {
                    // Redirect tới action delete hoặc gọi AJAX
                    window.location.href = '/Admin/HoaDons/Delete/' + id;
                }
            })
        }

        // Thông báo thành công từ TempData
        @if (TempData["Success"] != null)
        {
            <text>
                    Swal.fire({
                        icon: 'success',
                    title: 'Thành công!',
                    text: '@TempData["Success"]',
                    timer: 2000,
                    showConfirmButton: false
                        });
            </text>
        }
    </script>
}