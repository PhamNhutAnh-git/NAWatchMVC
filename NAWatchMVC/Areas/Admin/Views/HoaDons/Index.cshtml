@model IEnumerable<NAWatchMVC.Data.HoaDon>

@{
    ViewData["Title"] = "Quản lý Đơn hàng";
}

<div class="container-fluid px-4 py-3">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb small mb-1">
                    <li class="breadcrumb-item"><a asp-controller="HomeAdmin" asp-action="Index" class="text-decoration-none text-muted">Hệ thống</a></li>
                    <li class="breadcrumb-item active text-indigo fw-bold">Đơn hàng</li>
                </ol>
            </nav>
            <h4 class="fw-bold m-0 text-dark">Quản lý Đơn hàng</h4>
        </div>
        <a asp-action="Create" class="btn btn-indigo shadow-sm rounded-pill px-4 py-2">
            <i class="fas fa-plus-circle me-2"></i>Tạo đơn hàng mới 1
        </a>
    </div>
    @* các card *@
    <div class="row g-3 mb-4">
        <div class="col-md-2">
            <div class="card border-0 shadow-sm rounded-4 h-100 bg-primary text-white">
                <div class="card-body p-3 text-center">
                    <div class="small fw-bold opacity-75">MỚI ĐẶT (0)</div>
                    <h3 class="fw-bold mb-0">@Model.Count(h => h.MaTrangThai == 0)</h3>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card border-0 shadow-sm rounded-4 h-100 bg-info text-white">
                <div class="card-body p-3 text-center">
                    <div class="small fw-bold opacity-75">VNPAY (1)</div>
                    <h3 class="fw-bold mb-0">@Model.Count(h => h.MaTrangThai == 1)</h3>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card border-0 shadow-sm rounded-4 h-100 bg-warning text-white">
                <div class="card-body p-3 text-center">
                    <div class="small fw-bold opacity-75">ĐANG GIAO (2)</div>
                    <h3 class="fw-bold mb-0">@Model.Count(h => h.MaTrangThai == 2)</h3>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card border-0 shadow-sm rounded-4 h-100 bg-success text-white">
                <div class="card-body p-3 text-center">
                    <div class="small fw-bold opacity-75">THÀNH CÔNG (3)</div>
                    <h3 class="fw-bold mb-0">@Model.Count(h => h.MaTrangThai == 3)</h3>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card border-0 shadow-sm rounded-4 h-100 bg-danger text-white">
                <div class="card-body p-3 text-center">
                    <div class="small fw-bold opacity-75">ĐÃ HỦY (4)</div>
                    <h3 class="fw-bold mb-0">@Model.Count(h => h.MaTrangThai == 4)</h3>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card border-0 shadow-sm rounded-4 h-100 bg-secondary text-white">
                <div class="card-body p-3 text-center">
                    <div class="small fw-bold opacity-75">HOÀN TIỀN (5)</div>
                    <h3 class="fw-bold mb-0">@Model.Count(h => h.MaTrangThai == 5)</h3>
                </div>
            </div>
        </div>
    </div>
    @* tìm kiếm *@
    <div class="card border-0 shadow-sm rounded-4 mb-3">
        <div class="card-body p-3">
            <form method="get" asp-action="Index" class="row g-2">
                <div class="col-md-9">
                    <div class="input-group">
                        <span class="input-group-text bg-light border-0"><i class="fas fa-search text-muted"></i></span>
                        <input type="text" name="searchString" value="@Context.Request.Query["searchString"]"
                               class="form-control border-0 bg-light" placeholder="Nhập ID đơn, Tên khách hàng hoặc Số điện thoại để tìm kiếm...">
                    </div>
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-primary w-100 rounded-3 fw-bold shadow-sm">
                        <i class="fas fa-search me-1"></i> TÌM
                    </button>

                    @if (!string.IsNullOrEmpty(Context.Request.Query["searchString"]))
                    {
                        <a asp-action="Index" class="btn btn-outline-danger w-100 rounded-3 fw-bold shadow-sm">
                            <i class="fas fa-times me-1"></i> HỦY
                        </a>
                    }
                    else
                    {
                        @* Nếu chưa tìm gì thì nút Hủy để màu xám nhẹ cho tinh tế *@
                        <button type="button" class="btn btn-light w-100 rounded-3 fw-bold text-muted border-0" disabled>
                            <i class="fas fa-times me-1"></i> HỦY
                        </button>
                    }
                </div>
            </form>
        </div>
    </div>
    @* các bộ lọc  *@
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-3">
            <form method="get" class="row g-2 align-items-center">
                <div class="col-md-2">
                    <select name="status" class="form-select border-0 bg-light">
                        <option value="">-- Tất cả Trạng thái --</option>
                        <option value="0" selected="@(Context.Request.Query["status"] == "0")">Mới đặt chờ xác nhận</option>
                        <option value="1" selected="@(Context.Request.Query["status"] == "1")">VNPAY (Chờ xác nhận)</option>
                        <option value="2" selected="@(Context.Request.Query["status"] == "2")">Đang giao hàng</option>
                        <option value="3" selected="@(Context.Request.Query["status"] == "3")">Hoàn tất thành công</option>
                        <option value="4" selected="@(Context.Request.Query["status"] == "4")">Đã hủy đơn</option>
                        <option value="5" selected="@(Context.Request.Query["status"] == "5")">Hoàn tiền</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <select name="month" class="form-select border-0 bg-light">
                        <option value="">-- Chọn tháng --</option>
                        @for (int i = 1; i <= 12; i++)
                        {
                            <option value="@i" selected="@(Context.Request.Query["month"] == i.ToString() ? "selected" : null)">Tháng @i</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <select name="payment" class="form-select border-0 bg-light">
                        <option value="">-- Thanh toán --</option>
                        <option value="COD">COD</option>
                        <option value="VNPAY">VNPAY</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <select name="isPaid" class="form-select border-0 bg-light fw-bold text-indigo">
                        <option value="">-- Tình trạng Thu tiền --</option>
                        <option value="true" selected="@(Context.Request.Query["isPaid"] == "true")">✅ Đã thu tiền (Paid)</option>
                        <option value="false" selected="@(Context.Request.Query["isPaid"] == "false")">❌ Chưa thu tiền (Unpaid)</option>
                    </select>
                </div>
                <div class="col-md-2 d-flex gap-1">
                    <button type="submit" class="btn btn-primary w-100 rounded-3">Lọc</button>
                    <a asp-action="Index" class="btn btn-light w-100 rounded-3">Reset</a>
                </div>
                @* hiển thị các trạng thái đang lọc *@
                @if (!string.IsNullOrEmpty(Context.Request.Query["status"]) ||
                !string.IsNullOrEmpty(Context.Request.Query["month"]) ||
                !string.IsNullOrEmpty(Context.Request.Query["payment"]) ||
                !string.IsNullOrEmpty(Context.Request.Query["isPaid"]) ||
                !string.IsNullOrEmpty(Context.Request.Query["searchString"]))
                {
                    <div class="col-12 mt-2 animated fadeIn">
                        <small class="text-muted fw-bold">
                            <i class="fas fa-filter me-1"></i> Đang áp dụng lọc:
                            <span class="badge bg-indigo-soft text-indigo p-2">
                                @if (!string.IsNullOrEmpty(Context.Request.Query["searchString"]))
                                {
                                    <span>🔍 Từ khóa: "@Context.Request.Query["searchString"]" |</span>
                                }

                                @if (!string.IsNullOrEmpty(Context.Request.Query["status"]))
                                {
                                    <span>
                                        Trạng thái: @(Context.Request.Query["status"].ToString() switch
                                        {
                                            "0" => "Mới",
                                            "1" => "VNPay",
                                            "2" => "Đang giao",
                                            "3" => "Hoàn tất",
                                            "4" => "Đã hủy",
                                            "5" => "Hoàn tiền",
                                            _ => ""
                                        }) |
                                    </span>
                                }

                                @if (!string.IsNullOrEmpty(Context.Request.Query["month"]))
                                {
                                    <span> Tháng @Context.Request.Query["month"] |</span>
                                }

                                @if (!string.IsNullOrEmpty(Context.Request.Query["payment"]))
                                {
                                    <span> PT: @Context.Request.Query["payment"] |</span>
                                }

                                @if (!string.IsNullOrEmpty(Context.Request.Query["isPaid"]))
                                {
                                    <span> Thu tiền: @(Context.Request.Query["isPaid"] == "true" ? "Đã thu" : "Chưa thu")</span>
                                }
                            </span>
                            <a asp-action="Index" class="text-danger ms-2 text-decoration-none small"><i class="fas fa-times-circle"></i> Xóa tất cả</a>
                        </small>
                    </div>
                }
            </form>
        </div>
    </div>

   @* body *@
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive" style="max-height: 550px;">
            <table class="table table-hover align-middle mb-0" id="dataTable">
                <thead class="bg-light sticky-top shadow-sm">
                    <tr>
                        <th class="ps-4 py-3 border-0 text-uppercase small fw-bold">ID & Khách hàng</th>
                        <th class="py-3 border-0 text-uppercase small fw-bold">Ngày đặt</th>
                        <th class="py-3 border-0 text-uppercase small fw-bold text-center">Số SP</th>
                        <th class="py-3 border-0 text-uppercase small fw-bold text-end">Tổng tiền</th>
                        <th class="py-3 border-0 text-uppercase small fw-bold text-center">Trạng thái</th>
                        <th class="py-3 border-0 text-uppercase small fw-bold text-center">Duyệt nhanh</th>
                        <th class="pe-4 py-3 border-0 text-uppercase small fw-bold text-center">Thao tác</th>
                        <th class="py-3 border-0 text-uppercase small fw-bold text-center">Thanh toán</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 py-3">
                                <div class="fw-bold text-indigo">#@item.MaHd</div>
                                <div class="text-dark fw-bold">@item.HoTen</div>
                                <small class="text-muted">@item.DienThoai</small>
                            </td>
                            <td>
                                <div class="small">@item.NgayDat?.ToString("dd/MM/yyyy")</div>
                                <div class="text-muted small">@item.NgayDat?.ToString("HH:mm")</div>
                            </td>
                            <td class="text-center">
                                <span class="badge bg-secondary-soft text-secondary rounded-pill">
                                    @(item.ChiTietHds?.Count() ?? 0)
                                </span>
                            </td>
                            <td class="text-end fw-bold text-indigo">
                                @item.TongTien?.ToString("N0")đ
                            </td>
                            <td class="text-center">
                                @{
                                    var (badgeClass, statusIcon) = item.MaTrangThai switch
                                    {
                                        0 => ("bg-blue-soft text-blue", "fa-clock"),            // Mới đặt
                                        1 => ("bg-info-soft text-info", "fa-credit-card"),      // VNPay (Đã thanh toán)
                                        2 => ("bg-warning-soft text-warning", "fa-truck"),      // Đang giao
                                        3 => ("bg-success-soft text-success", "fa-check-circle"), // Hoàn tất (XANH LÁ)
                                        4 => ("bg-danger-soft text-danger", "fa-times-circle"), // Đã hủy (ĐỎ)
                                        5 => ("bg-secondary-soft text-secondary", "fa-undo"),    // Hoàn tiền
                                        _ => ("bg-light text-dark", "fa-question")
                                    };
                                }
                                <span class="badge @badgeClass py-2 px-3 rounded-pill fw-bold">
                                    <i class="fas @statusIcon me-1"></i> @(item.MaTrangThaiNavigation?.TenTrangThai ?? "N/A")
                                </span>
                            </td>
                            <td class="text-center col-duyet-nhanh">
                                @if (item.MaTrangThai == 0 || item.MaTrangThai == 1)
                                {
                                    <button type="button" class="btn btn-sm btn-primary rounded-pill px-3 shadow-sm"
                                            onclick="handleAction('@Url.Action("Approve", "HoaDons", new { id = item.MaHd })', 'Duyệt đơn này?')">
                                        Duyệt đơn
                                    </button>
                                }
                                else if (item.MaTrangThai == 2)
                                {
                                    if (item.DaThanhToan == true)
                                    {
                                        <button type="button" class="btn btn-sm btn-success rounded-pill px-3 shadow-sm"
                                                onclick="handleAction('@Url.Action("Complete", "HoaDons", new { id = item.MaHd })', 'Xác nhận đơn hàng thành công?')">
                                            Hoàn tất
                                        </button>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-muted border">Chờ thu tiền</span>
                                    }
                                }
                            </td>
                            <td class="text-center pe-4">
                                <div class="btn-group">
                                    <a asp-action="Details" asp-route-id="@item.MaHd" class="btn btn-soft-info btn-sm rounded-circle me-1" title="Xem">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.MaHd" class="btn btn-soft-warning btn-sm rounded-circle me-1" title="Sửa">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    @* <button type="button" class="btn btn-soft-danger btn-sm rounded-circle" onclick="deleteOrder(@item.MaHd)" title="Xóa">
                                        <i class="fas fa-trash"></i>
                                    </button> *@
                                </div>
                            </td>
                            <td class="text-center">
                                <div class="form-check form-switch d-inline-block">
                                    @* Thêm logic kiểm tra MaTrangThai để disabled và đổi cursor *@
                                    <input class="form-check-input @(item.MaTrangThai == 4 || item.MaTrangThai == 5 ? "" : "cursor-pointer")"
                                           type="checkbox"
                                           style="transform: scale(1.2);"
                                    @(item.DaThanhToan == true ? "checked" : "")
                                    @* KHÓA NÚT Ở ĐÂY NÈ NÍ *@
                                    @(item.MaTrangThai == 4 || item.MaTrangThai == 5 ? "disabled" : "")
                                           onclick="togglePaid(@item.MaHd, this)"
                                           title="@(item.MaTrangThai == 4 || item.MaTrangThai == 5 ? "Đơn hàng đã kết thúc, không thể thay đổi trạng thái thanh toán" : "Bật/Tắt thanh toán")">
                                </div>
                                <div class="text-thanh-toan small fw-bold @(item.DaThanhToan == true ? "text-success" : "text-danger")">
                                    @(item.DaThanhToan == true ? "Đã thu" : "Chưa thu")
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="card-footer bg-white py-3 border-0 d-flex justify-content-center">
            <nav>
                <ul class="pagination pagination-indigo mb-0">
                    <li class="page-item disabled"><a class="page-link" href="#"><i class="fas fa-chevron-left"></i></a></li>
                    <li class="page-item active"><a class="page-link" href="#">1</a></li>
                    <li class="page-item"><a class="page-link" href="#">2</a></li>
                    <li class="page-item"><a class="page-link" href="#"><i class="fas fa-chevron-right"></i></a></li>
                </ul>
            </nav>
        </div>
    </div>
</div>

@section Styles {
    <style>
        :root {
            --indigo: #4f46e5;
            --blue: #3b82f6;
        }

        body {
            background-color: #f8fafc;
        }

        .text-indigo {
            color: var(--indigo);
        }

        .btn-indigo {
            background-color: var(--indigo);
            color: white;
        }

            .btn-indigo:hover {
                background-color: #4338ca;
                color: white;
            }

        /* Card Statistics Style */
        .icon-shape {
            width: 48px;
            height: 48px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.25rem;
        }

        /* Soft Badges Colors */
        .bg-primary-soft {
            background-color: #e0e7ff;
            color: var(--indigo);
        }

        .bg-success-soft {
            background-color: #dcfce7;
            color: #15803d;
        }

        .bg-warning-soft {
            background-color: #fef3c7;
            color: #b45309;
        }

        .bg-danger-soft {
            background-color: #fee2e2;
            color: #b91c1c;
        }

        .bg-blue-soft {
            background-color: #dbeafe;
            color: #1e40af;
        }

        .bg-secondary-soft {
            background-color: #f1f5f9;
            color: #475569;
        }

        .text-blue {
            color: #2563eb;
        }

        /* Table Style */
        #dataTable thead th {
            letter-spacing: 0.05rem;
        }

        .table-hover tbody tr:hover {
            background-color: #f1f5f9;
            transition: background 0.2s;
        }

        .sticky-top {
            top: -1px;
            z-index: 1020;
        }

        .border-light-2 {
            border: 2px solid #f1f5f9;
        }

        /* Soft Buttons */
        .btn-soft-info {
            background-color: #e0f2fe;
            color: #0369a1;
            border: none;
        }

        .btn-soft-warning {
            background-color: #fef3c7;
            color: #b45309;
            border: none;
        }

        .btn-soft-danger {
            background-color: #fee2e2;
            color: #b91c1c;
            border: none;
        }

            .btn-soft-info:hover, .btn-soft-warning:hover, .btn-soft-danger:hover {
                filter: brightness(0.9);
            }

        /* Pagination Indigo */
        .pagination-indigo .page-link {
            color: var(--indigo);
            border: none;
            margin: 0 3px;
            border-radius: 8px;
        }

        .pagination-indigo .page-item.active .page-link {
            background-color: var(--indigo);
            color: white;
        }
    </style>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // Xử lý xóa hóa đơn với SweetAlert2
        function deleteOrder(id) {
            Swal.fire({
                title: 'Xóa hóa đơn #' + id + '?',
                text: "Dữ liệu này sẽ không thể khôi phục lại!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#6b7280',
                confirmButtonText: 'Đúng, xóa luôn!',
                cancelButtonText: 'Hủy'
            }).then((result) => {
                if (result.isConfirmed) {
                    // Redirect tới action delete hoặc gọi AJAX
                    window.location.href = '/Admin/HoaDons/Delete/' + id;
                }
            })
        }

        // Thông báo thành công từ TempData
        @if (TempData["Success"] != null)
        {
            <text>
                    Swal.fire({
                        icon: 'success',
                    title: 'Thành công!',
                    text: '@TempData["Success"]',
                    timer: 2000,
                    showConfirmButton: false
                        });
            </text>
        }
        // mới để duyệt
            function handleAction(url, titleText) {
                Swal.fire({
                    title: titleText,
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonColor: '#4f46e5',
                    cancelButtonColor: '#6b7280',
                    confirmButtonText: 'Đồng ý',
                    cancelButtonText: 'Hủy'
                }).then((result) => {
                    if (result.isConfirmed) {
                        $.ajax({
                            url: url,
                            type: 'POST',
                            success: function (res) {
                                if (res.success) {
                                    Swal.fire({
                                        icon: 'success',
                                        title: 'Thành công!',
                                        text: res.message,
                                        timer: 1500,
                                        showConfirmButton: false
                                    }).then(() => {
                                        location.reload(); // Load lại để cập nhật bảng và card
                                    });
                                } else {
                                    Swal.fire('Lỗi!', res.message, 'error');
                                }
                            },
                            error: function () {
                                Swal.fire('Lỗi!', 'Không thể kết nối với máy chủ ní ơi!', 'error');
                            }
                        });
                    }
                });
            }
        //Thêm cái này vào để Admin bấm cái "tách" là cập nhật thanh toán luôn:
        // function togglePaid(id, element) {
        //     $.post('/Admin/HoaDons/TogglePaid/' + id, function (res) {
        //         if (res.success) {
        //             const Toast = Swal.mixin({ toast: true, position: 'top-end', showConfirmButton: false, timer: 2000 });
        //             Toast.fire({ icon: 'success', title: 'Đã cập nhật thanh toán!' });
        //         } else {
        //             element.checked = !element.checked; // Trả lại trạng thái cũ nếu lỗi
        //             Swal.fire('Lỗi', 'Không thể cập nhật!', 'error');
        //         }
        //     });
        // }
        function togglePaid(id, checkbox) {
            // 1. Gửi yêu cầu lưu vào Database chạy ngầm
            $.ajax({
                url: '/Admin/HoaDons/TogglePaid/' + id,
                type: 'POST',
                success: function (res) {
                    if (res.success) {
                        // TÌM CÁI DÒNG (TR) HIỆN TẠI ĐỂ CẬP NHẬT
                        let row = $(checkbox).closest('tr');
                        let textThanhToan = row.find('.text-thanh-toan'); // Cái chữ Đã thu/Chưa thu
                        let colDuyetNhanh = row.find('.col-duyet-nhanh'); // Cột chứa nút Duyệt nhanh

                        if (checkbox.checked) {
                            // --- TRƯỜNG HỢP: VỪA BẬT THÀNH "ĐÃ THU" ---
                            textThanhToan.text('Đã thu').removeClass('text-danger').addClass('text-success');

                            // Nếu đơn đang ở trạng thái 2 (Đang giao), ta biến cái nút "Chờ thu tiền" thành "Hoàn tất"
                            // Tui giả định ní dùng hàm quickApprove cho nút Hoàn tất nhé
                            let btnHoanTat = `<button type="button" class="btn btn-sm btn-success rounded-pill px-3 shadow-sm"
                                                      onclick="quickApprove(${id})">Hoàn tất</button>`;

                            // Chỉ cập nhật nếu trước đó nó đang là "Chờ thu tiền"
                            if (colDuyetNhanh.text().includes("Chờ thu tiền") || colDuyetNhanh.find('button').is(':disabled')) {
                                colDuyetNhanh.html(btnHoanTat);
                            }
                        } else {
                            // --- TRƯỜNG HỢP: VỪA TẮT THÀNH "CHƯA THU" ---
                            textThanhToan.text('Chưa thu').removeClass('text-success').addClass('text-danger');

                            // Biến nút "Hoàn tất" thành "Chờ thu tiền" (Vô hiệu hóa)
                            let btnChoThu = `<span class="badge bg-light text-muted border py-2 px-3">Chờ thu tiền</span>`;
                            colDuyetNhanh.html(btnChoThu);
                        }

                        // Hiện thông báo nhỏ cho Pro
                        const Toast = Swal.mixin({ toast: true, position: 'top-end', showConfirmButton: false, timer: 1500 });
                        Toast.fire({ icon: 'success', title: 'Đã cập nhật Database!' });
                    } else {
                        checkbox.checked = !checkbox.checked; // Trả lại vị trí cũ nếu lỗi
                        Swal.fire('Lỗi', res.message, 'error');
                    }
                }
            });
        }
    </script>
}