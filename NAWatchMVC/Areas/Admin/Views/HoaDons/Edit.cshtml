@model NAWatchMVC.Data.HoaDon

@{
    ViewData["Title"] = "Cập nhật đơn hàng #" + Model.MaHd;
}

<div class="container-fluid">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb small mb-4">
            <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none text-muted">Đơn hàng</a></li>
            <li class="breadcrumb-item active text-primary" aria-current="page">Chỉnh sửa đơn #@Model.MaHd</li>
        </ol>
    </nav>

    <div class="row justify-content-center">
        <div class="col-lg-11">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-white py-3 border-bottom d-flex align-items-center justify-content-between">
                    <div class="d-flex align-items-center">
                        <div class="bg-warning-subtle p-2 rounded-circle me-3">
                            <i class="fas fa-edit text-warning"></i>
                        </div>
                        <h5 class="m-0 font-weight-bold text-dark">Cập nhật thông tin đơn hàng: <span class="text-primary">#@Model.MaHd</span></h5>
                    </div>
                    <span class="badge bg-light text-dark border">Ngày đặt: @Model.NgayDat?.ToString("dd/MM/yyyy HH:mm")</span>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <input type="hidden" asp-for="MaHd" />
                        <input type="hidden" asp-for="NgayDat" /> @* Giữ nguyên ngày đặt không cho sửa *@

                        <div class="row g-4">
                            <div class="col-md-6 border-end">
                                <h6 class="fw-bold text-uppercase small text-muted mb-4"><i class="fas fa-shipping-fast me-2"></i>Địa chỉ & Người nhận</h6>

                                <div class="mb-3">
                                    <label asp-for="HoTen" class="form-label fw-bold small">Họ và Tên khách hàng</label>
                                    <input asp-for="HoTen" class="form-control border-2" />
                                    <span asp-validation-for="HoTen" class="text-danger small"></span>
                                </div>

                                <div class="row mb-3">
                                    <div class="col-md-6">
                                        <label asp-for="DienThoai" class="form-label fw-bold small">Số điện thoại</label>
                                        <input asp-for="DienThoai" class="form-control border-2" />
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="MaKh" class="form-label fw-bold small text-muted">ID Khách thành viên</label>
                                        <select asp-for="MaKh" class="form-select border-2 bg-light" asp-items="ViewBag.MaKh"></select>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="DiaChi" class="form-label fw-bold small">Địa chỉ nhận hàng</label>
                                    <textarea asp-for="DiaChi" class="form-control border-2" rows="3"></textarea>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="GhiChu" class="form-label fw-bold small">Ghi chú từ khách/Admin</label>
                                    <textarea asp-for="GhiChu" class="form-control border-2" rows="2"></textarea>
                                </div>
                            </div>

                            <div class="col-md-6 ps-md-4">
                                <h6 class="fw-bold text-uppercase small text-muted mb-4"><i class="fas fa-tasks me-2"></i>Xử lý & Thanh toán</h6>

                                <div class="p-3 bg-light rounded-3 border mb-4">
                                    <div class="mb-3">
                                        <label asp-for="MaTrangThai" class="form-label fw-bold small text-primary">TRẠNG THÁI ĐƠN HÀNG</label>
                                        <select asp-for="MaTrangThai" class="form-select border-2 border-primary fw-bold" asp-items="ViewBag.MaTrangThai"></select>
                                    </div>

                                    <div class="row">
                                        <div class="col-md-6 mb-3">
                                            <label asp-for="CachThanhToan" class="form-label fw-bold small">PT Thanh toán</label>
                                            <input asp-for="CachThanhToan" class="form-control border-2" />
                                        </div>
                                        <div class="col-md-6 mb-3">
                                            <label asp-for="CachVanChuyen" class="form-label fw-bold small">Đơn vị vận chuyển</label>
                                            <input asp-for="CachVanChuyen" class="form-control border-2" />
                                        </div>
                                    </div>
                                </div>

                                <div class="row mb-3">
                                    <div class="col-md-6">
                                        <label asp-for="NgayGiao" class="form-label fw-bold small">Ngày giao thực tế</label>
                                        <input asp-for="NgayGiao" type="date" class="form-control border-2" />
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="MaNv" class="form-label fw-bold small">Nhân viên phụ trách</label>
                                        <select asp-for="MaNv" class="form-select border-2" asp-items="ViewBag.MaNv"></select>
                                    </div>
                                </div>

                                <div class="row mb-3 mt-4">
                                    <div class="col-md-6">
                                        <label asp-for="PhiVanChuyen" class="form-label fw-bold small">Phí vận chuyển (đ)</label>
                                        <input asp-for="PhiVanChuyen" class="form-control border-2 text-end fw-bold" />
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="TongTien" class="form-label fw-bold small text-danger">TỔNG TIỀN PHẢI THU (đ)</label>
                                        <input asp-for="TongTien" class="form-control border-2 text-end fw-bold text-danger bg-white" />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <hr class="my-4 opacity-10">

                        <div class="d-flex justify-content-between align-items-center">
                            <a asp-action="Index" class="btn btn-light border px-4 rounded-pill fw-bold text-muted">
                                <i class="fas fa-arrow-left me-1"></i> Quay lại
                            </a>
                            <button type="submit" class="btn btn-primary px-5 rounded-pill fw-bold shadow">
                                <i class="fas fa-save me-1"></i> Lưu thay đổi
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .bg-warning-subtle {
            background-color: #fef3c7;
        }

        .form-control:focus, .form-select:focus {
            box-shadow: none;
            border-color: #3b82f6;
        }

        textarea {
            resize: none;
        }
    </style>
}

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}