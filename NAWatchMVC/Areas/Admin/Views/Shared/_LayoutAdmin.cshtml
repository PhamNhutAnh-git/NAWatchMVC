<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - NAWatch Admin</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.4/css/dataTables.bootstrap5.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        :root {
            --sidebar-bg: #1e293b;
            --sidebar-hover: #334155;
            --sidebar-active: #3b82f6;
            --accent-color: #fbbf24;
            --body-bg: #f1f5f9;
        }

        body {
            background-color: var(--body-bg);
            font-family: 'Inter', sans-serif;
            color: #1e293b;
            overflow-x: hidden; /* Chống tràn ngang */
        }

        /* --- SIDEBAR CỐ ĐỊNH & GỌN GÀNG --- */
        #sidebar {
            min-width: 250px;
            max-width: 250px;
            background: var(--sidebar-bg);
            color: #fff;
            /* Cố định Sidebar */
            position: sticky;
            top: 0;
            height: 100vh; /* Cao bằng màn hình */
            /* Cuộn độc lập */
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            transition: all 0.3s;
            z-index: 1000;
        }

            /* Làm mượt thanh cuộn của riêng Sidebar */
            #sidebar::-webkit-scrollbar {
                width: 5px;
            }

            #sidebar::-webkit-scrollbar-thumb {
                background: rgba(255,255,255,0.1);
                border-radius: 10px;
            }

            #sidebar:hover::-webkit-scrollbar-thumb {
                background: rgba(255,255,255,0.3);
            }

            #sidebar .sidebar-header {
                padding: 20px 15px; /* Thu gọn header */
                background: rgba(0,0,0,0.1);
                border-bottom: 1px solid rgba(255,255,255,0.05);
            }

        /* Thu hẹp khoảng cách các tiêu đề nhóm */
        .sidebar-heading {
            padding: 1rem 1.25rem 0.25rem; /* Giảm padding rõ rệt */
            font-size: 0.65rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.1rem;
            color: #94a3b8;
        }

        /* Thu hẹp khoảng cách các mục Menu */
        #sidebar ul li a {
            padding: 8px 16px; /* Giảm từ 12px xuống 8px */
            margin: 2px 10px; /* Giảm margin giữa các mục */
            display: flex;
            align-items: center;
            color: #cbd5e1;
            text-decoration: none;
            transition: 0.2s;
            border-radius: 6px;
            font-size: 0.88rem;
        }

            #sidebar ul li a i {
                width: 22px;
                font-size: 1rem;
            }

        #sidebar hr {
            margin: 0.5rem 1.25rem; /* Thu gọn đường kẻ phân cách */
            border-top: 1px solid rgba(255, 255, 255, 0.08);
            opacity: 1;
        }

        /* Hiệu ứng Active & Hover */
        #sidebar ul li a:hover {
            color: #fff;
            background: var(--sidebar-hover);
        }

        #sidebar ul li.active > a {
            color: #fff;
            background: var(--sidebar-active);
            box-shadow: 0 2px 8px rgba(59, 130, 246, 0.3);
        }

        /* MAIN CONTENT */
        .main-content {
            flex: 1; /* Tự động chiếm phần còn lại */
            padding: 20px;
            min-height: 100vh;
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="d-flex">
        <nav id="sidebar">
            <div class="sidebar-header text-center">
                <div class="d-flex align-items-center justify-content-center mb-1">
                    <i class="fas fa-watch fa-2x text-primary me-2"></i>
                    <h3 class="fw-bold mb-0" style="letter-spacing: 2px;">NAWATCH</h3>
                </div>
                <small class="text-uppercase" style="font-size: 0.6rem; color: var(--accent-color);">Premium Watch Store</small>
            </div>

            <ul class="list-unstyled components mt-2">
                <div class="sidebar-heading">Hệ Thống</div>
                <li class="@(ViewContext.RouteData.Values["Controller"].ToString() == "HomeAdmin" ? "active" : "")">
                    <a asp-area="Admin" asp-controller="HomeAdmin" asp-action="Index">
                        <i class="fas fa-chart-pie"></i> <span>Bảng điều khiển</span>
                    </a>
                </li>

                <hr>

                <div class="sidebar-heading">Quản Lý Kho</div>
                <li class="@(ViewContext.RouteData.Values["Controller"].ToString() == "HangHoas" ? "active" : "")">
                    <a asp-area="Admin" asp-controller="HangHoas" asp-action="Index">
                        <i class="fas fa-boxes"></i> <span>Sản phẩm</span>
                    </a>
                </li>
                <li class="@(ViewContext.RouteData.Values["Controller"].ToString() == "Loais" ? "active" : "")">
                    <a asp-area="Admin" asp-controller="Loais" asp-action="Index">
                        <i class="fas fa-tags"></i> <span>Danh mục</span>
                    </a>
                </li>
                <li class="@(ViewContext.RouteData.Values["Controller"].ToString() == "NhaCungCaps" ? "active" : "")">
                    <a asp-area="Admin" asp-controller="NhaCungCaps" asp-action="Index">
                        <i class="fas fa-truck-loading"></i> <span>Nhà cung cấp</span>
                    </a>
                </li>

                <hr>

                <div class="sidebar-heading">Kinh Doanh</div>
                <li class="@(ViewContext.RouteData.Values["Controller"].ToString() == "HoaDons" ? "active" : "")">
                    <a asp-area="Admin" asp-controller="HoaDons" asp-action="Index">
                        <i class="fas fa-receipt"></i> <span>Đơn hàng</span>
                        <span class="badge bg-danger rounded-pill ms-auto" style="font-size: 0.6rem;">Mới</span>
                    </a>
                </li>
                <li class="@(ViewContext.RouteData.Values["Controller"].ToString() == "KhachHangs" ? "active" : "")">
                    <a asp-area="Admin" asp-controller="KhachHangs" asp-action="Index">
                        <i class="fas fa-user-friends"></i> <span>Khách hàng</span>
                    </a>
                </li>

                <hr>

                <div class="sidebar-heading">Nhân Sự</div>
                <li class="@(ViewContext.RouteData.Values["Controller"].ToString() == "NhanViens" ? "active" : "")">
                    <a asp-area="Admin" asp-controller="NhanViens" asp-action="Index">
                        <i class="fas fa-id-card"></i> <span>Nhân viên</span>
                    </a>
                </li>

                <hr>

                <div class="sidebar-heading">Tương tác</div>
                <li class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "AdminReview" ? "active" : "")">
                    <a asp-area="Admin" asp-controller="AdminReview" asp-action="Index">
                        <i class="fas fa-star"></i> <span>Quản lý Đánh giá</span>
                    </a>
                </li>
                <hr class="mt-4">

                <li>
                    <a href="/" target="_blank" class="text-info">
                        <i class="fas fa-external-link-alt"></i> <span>Xem Website</span>
                    </a>
                </li>
                @* Tìm đoạn này trong Sidebar và sửa lại *@
                <li>
                    <a href="/KhachHang/DangXuat" class="text-danger nav-link">
                        <i class="fas fa-power-off"></i> <span>Đăng xuất</span>
                    </a>
                </li>
            </ul>
        </nav>

        <div class="main-content">
            <div class="nav-profile d-flex justify-content-between align-items-center">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-0">
                        <li class="breadcrumb-item small"><a href="#" class="text-decoration-none text-muted">Admin</a></li>
                        <li class="breadcrumb-item active small" aria-current="page">@ViewData["Title"]</li>
                    </ol>
                </nav>

                <div class="dropdown">
                    <div class="d-flex align-items-center" role="button" data-bs-toggle="dropdown" style="cursor: pointer;">
                        <div class="text-end me-3 d-none d-md-block">
                            <div class="fw-bold small">@User.Identity.Name</div>
                            <div class="text-muted" style="font-size: 0.7rem;">Quản trị viên</div>
                        </div>
                        <img src="https://ui-avatars.com/api/?name=@User.Identity.Name&background=3b82f6&color=fff"
                             class="rounded-circle shadow-sm" width="40" height="40" alt="avatar">
                    </div>
                    <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2">
                        <li><a class="dropdown-item py-2" href="#"><i class="fas fa-user me-2 small text-muted"></i> Hồ sơ</a></li>
                        <li><a class="dropdown-item py-2" href="#"><i class="fas fa-cog me-2 small text-muted"></i> Cài đặt</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            @* Viết đường dẫn trực tiếp như vầy để không bị dính chữ /Admin/ *@
                            <a href="/KhachHang/DangXuat" class="text-danger nav-link">
                                <i class="fas fa-power-off"></i> <span>Đăng xuất</span>
                            </a>
                        </li>
                    </ul>
                </div>
            </div>

            <div class="animate__animated animate__fadeIn">
                @RenderBody()
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.4/js/dataTables.bootstrap5.min.js"></script>

    <script>
        $(document).ready(function () {
            // 1. Cấu hình mặc định cho DataTable (ní giữ nguyên cái cũ của ní)
            $('.datatable').DataTable({
                "language": {
                    "url": "//cdn.datatables.net/plug-ins/1.13.4/i18n/vi.json"
                },
                "pageLength": 10,
                "responsive": true,
                "ordering": false // <--- THÊM DÒNG NÀY: Xóa sổ mấy cái mũi tên ở tiêu đề cột
            });

            // 2. XỬ LÝ THÔNG BÁO TỪ TEMP DATA (Độ lại cho mượt)
        @if (TempData["Success"] != null)
        {
            <text>
                        Swal.fire({
                            icon: 'success',
                        title: 'Thành công!',
                        html: '@Html.Raw(TempData["Success"])', // 
                        timer: 3000,
                        timerProgressBar: true,
                        showConfirmButton: false
                        });
            </text>
        }

        @if (TempData["Error"] != null)
        {
            <text>
                        Swal.fire({
                            icon: 'error',
                        title: 'Lỗi rồi ní ơi!',
                        html: '@Html.Raw(TempData["Error"])',
                        confirmButtonText: 'Đã rõ'
                        });
            </text>
        }
            });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>