@model IEnumerable<NAWatchMVC.Data.NhanVien>

@{
    ViewData["Title"] = "Danh sách nhân sự";
}

<div class="card shadow-sm border-0">
    <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
        <h5 class="m-0 font-weight-bold text-primary text-uppercase">
            <i class="fas fa-users-cog me-2"></i>Đội ngũ nhân sự
        </h5>
        <a asp-action="Create" class="btn btn-primary btn-sm rounded-pill px-3 shadow-sm">
            <i class="fas fa-user-plus me-1"></i> Thêm nhân viên mới
        </a>
    </div>

    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle datatable" width="100%">
                <thead class="table-light text-secondary">
                    <tr>
                        <th style="width: 60px;">#</th>
                        <th>Nhân viên</th>
                        <th>Email</th>
                        <th class="text-center">Vai trò</th>
                        <th class="text-center">Trạng thái</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-center">
                                <img src="https://ui-avatars.com/api/?name=@item.HoTen&background=random&color=fff"
                                     class="rounded-circle shadow-sm" width="40" height="40" alt="avatar" />
                            </td>
                            <td>
                                <div class="fw-bold text-dark">@item.HoTen</div>
                                <small class="text-muted">ID: @item.MaNv</small>
                            </td>
                            <td>
                                <a href="mailto:@item.Email" class="text-decoration-none small">
                                    <i class="fas fa-envelope me-1 opacity-50"></i>@item.Email
                                </a>
                            </td>
                            <td class="text-center">
                                @if (item.VaiTro == 1)
                                {
                                    <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-3 rounded-pill">
                                        Admin
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-info-subtle text-info border border-info-subtle px-3 rounded-pill">
                                        Nhân viên
                                    </span>
                                }
                            </td>
                            <td class="text-center">
                                @if (item.HieuLuc == true)
                                {
                                    <span class="badge bg-success-subtle text-success border border-success-subtle px-3 rounded-pill">
                                        Hoạt động
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle px-3 rounded-pill">
                                        Đã khóa
                                    </span>
                                }
                            </td>
                            <td class="text-center">
                                <div class="btn-group shadow-sm">
                                    <a asp-action="Edit" asp-route-id="@item.MaNv" class="btn btn-sm btn-outline-primary" title="Chỉnh sửa">
                                        <i class="fas fa-user-edit"></i>
                                    </a>
                                    <a asp-action="Details" asp-route-id="@item.MaNv" class="btn btn-sm btn-outline-info" title="Xem chi tiết">
                                        <i class="fas fa-id-card"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.MaNv" class="btn btn-sm btn-outline-danger" title="Vô hiệu hóa">
                                        <i class="fas fa-user-slash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Styles {
    <style>
        /* Tùy chỉnh màu Subtle cho Badge nhìn sang hơn */
        .bg-success-subtle { background-color: #dcfce7 !important; }
        .bg-danger-subtle { background-color: #fee2e2 !important; }
        .bg-info-subtle { background-color: #e0f2fe !important; }
        .bg-secondary-subtle { background-color: #f1f5f9 !important; }

        /* Chỉnh lại font size badge cho gọn */
        .badge {
            font-size: 0.75rem;
            font-weight: 600;
        }

        /* Hiệu ứng rê chuột vào hàng */
        .table-hover tbody tr:hover {
            background-color: rgba(59, 130, 246, 0.02);
            transition: 0.2s;
        }

        .btn-group .btn {
            border-width: 1px;
            padding: 0.35rem 0.6rem;
        }
    </style>
}