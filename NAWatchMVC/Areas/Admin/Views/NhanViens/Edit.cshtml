@model NAWatchMVC.Data.NhanVien

@{
    ViewData["Title"] = "Cập nhật nhân sự";
}

<div class="container-fluid">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb small mb-4">
            <li class="breadcrumb-item"><a asp-controller="HomeAdmin" asp-action="Index" class="text-decoration-none text-muted">Admin</a></li>
            <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none text-muted">Nhân viên</a></li>
            <li class="breadcrumb-item active text-primary" aria-current="page">Chỉnh sửa tài khoản</li>
        </ol>
    </nav>

    <div class="row justify-content-center">
        <div class="col-lg-9">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-white py-3 border-bottom d-flex align-items-center justify-content-between">
                    <div class="d-flex align-items-center">
                        <div class="bg-warning-subtle p-2 rounded-circle me-3">
                            <i class="fas fa-user-edit text-warning"></i>
                        </div>
                        <h5 class="m-0 font-weight-bold text-dark">Thiết lập tài khoản: <span class="text-primary">@Model.HoTen</span></h5>
                    </div>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="row">
                            <div class="col-md-8 border-end">
                                <div class="row mb-3">
                                    <div class="col-md-6">
                                        <label asp-for="MaNv" class="form-label fw-bold small text-muted text-uppercase">Mã nhân viên (Cố định)</label>
                                        @* Dùng readonly và bg-light để chặn sửa *@
                                        <input asp-for="MaNv" class="form-control bg-light border-2 fw-bold text-muted" readonly />
                                        <small class="text-info mt-1 d-block"><i class="fas fa-info-circle me-1"></i>Mã định danh không thể thay đổi.</small>
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="HoTen" class="form-label fw-bold small text-muted text-uppercase">Họ và Tên</label>
                                        <input asp-for="HoTen" class="form-control border-2" />
                                        <span asp-validation-for="HoTen" class="text-danger small"></span>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="Email" class="form-label fw-bold small text-muted text-uppercase">Email công việc</label>
                                    <input asp-for="Email" class="form-control border-2" />
                                    <span asp-validation-for="Email" class="text-danger small"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="MatKhau" class="form-label fw-bold small text-muted text-uppercase">Mật khẩu mới</label>
                                    <div class="input-group">
                                        <input asp-for="MatKhau" type="password" class="form-control border-2 border-end-0" id="passwordInput" />
                                        <span class="input-group-text bg-white border-2 border-start-0" id="togglePassword" style="cursor: pointer;">
                                            <i class="fas fa-eye text-muted"></i>
                                        </span>
                                    </div>
                                    <span asp-validation-for="MatKhau" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="col-md-4 ps-md-4">
                                <div class="mb-4">
                                    <label asp-for="VaiTro" class="form-label fw-bold small text-muted text-uppercase">Phân quyền</label>
                                    <select asp-for="VaiTro" class="form-select border-2">
                                        <option value="1">Quản trị viên (Admin)</option>
                                        <option value="0">Nhân viên (Staff)</option>
                                    </select>
                                    <span asp-validation-for="VaiTro" class="text-danger small"></span>
                                </div>

                                <div class="p-3 rounded-3 bg-light border">
                                    <label class="form-label fw-bold small text-muted text-uppercase d-block mb-3">Trạng thái tài khoản</label>
                                    <div class="form-check form-switch custom-switch">
                                        <input class="form-check-input" type="checkbox" asp-for="HieuLuc" id="flexSwitchCheckDefault">
                                        <label class="form-check-label fw-bold ms-2" for="flexSwitchCheckDefault" id="statusLabel">
                                            @(Model.HieuLuc == true ? "Đang hoạt động" : "Tạm khóa")
                                        </label>
                                    </div>
                                    <small class="text-muted mt-2 d-block">Gạt sang phải để kích hoạt quyền truy cập cho nhân viên.</small>
                                </div>
                            </div>
                        </div>

                        <hr class="my-4 opacity-10">

                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-light border px-4 rounded-pill fw-bold">
                                <i class="fas fa-chevron-left me-1"></i> Quay lại
                            </a>
                            <button type="submit" class="btn btn-warning px-5 rounded-pill fw-bold text-dark shadow-sm">
                                <i class="fas fa-save me-1"></i> Lưu thay đổi
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .bg-warning-subtle { background-color: #fff9db; }
        .form-control:focus, .form-select:focus {
            box-shadow: none;
            border-color: #f59e0b;
        }
        /* Style cho nút Switch to hơn tí */
        .custom-switch .form-check-input {
            width: 3em;
            height: 1.5em;
            cursor: pointer;
        }
        .custom-switch .form-check-input:checked {
            background-color: #198754;
            border-color: #198754;
        }
    </style>
}

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        // Hiện/Ẩn mật khẩu
        const togglePassword = document.querySelector('#togglePassword');
        const password = document.querySelector('#passwordInput');

        togglePassword.addEventListener('click', function (e) {
            const type = password.getAttribute('type') === 'password' ? 'text' : 'password';
            password.setAttribute('type', type);
            this.querySelector('i').classList.toggle('fa-eye-slash');
        });

        // Đổi chữ khi gạt Switch Trạng thái
        document.getElementById('flexSwitchCheckDefault').addEventListener('change', function() {
            const label = document.getElementById('statusLabel');
            label.innerText = this.checked ? "Đang hoạt động" : "Tạm khóa";
            label.className = this.checked ? "form-check-label fw-bold ms-2 text-success" : "form-check-label fw-bold ms-2 text-danger";
        });
    </script>
}